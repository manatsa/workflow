{
  "_comment": "Bulk / Contract Order — large wholesale order with special pricing, needing override approval.",
  "name": "Bulk Order / Pricing Override",
  "code": "WBO",
  "description": "Large wholesale order with special pricing / margin override requiring commercial approval.",
  "icon": "shopping_bag",
  "displayOrder": 89,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "WHOLESALE",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{orderRef} - @{customerName} (@{orderValue})",
  "reminderEnabled": true, "reminderFrequencyHours": 12, "reminderMaxCount": 3, "reminderStartAfterHours": 6,
  "escalationEnabled": true, "escalationAfterHours": 24, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Order", "displayOrder": 0, "icon": "shopping_bag" },
      { "id": "temp_screen_2", "title": "Line Items", "displayOrder": 1, "icon": "list" },
      { "id": "temp_screen_3", "title": "Pricing & Margin", "displayOrder": 2, "icon": "payments" },
      { "id": "temp_screen_4", "title": "Review", "displayOrder": 3, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Customer", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Items", "displayOrder": 2, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Pricing", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" }
    ],
    "fields": [
      { "name": "orderRef", "label": "Order Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"WBO-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "orderDate", "label": "Order Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "salesRep", "label": "Sales Rep", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "deliveryDate", "label": "Required Delivery Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required() AND DateAfter(\"today\", \"Date must be future\")" },
      { "name": "customerCode", "label": "Customer Code", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "customerName", "label": "Customer Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "creditAvailable", "label": "Credit Available", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND Min(0)" },
      { "name": "paymentTerms", "label": "Payment Terms", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "lineItems", "label": "Line Items", "fieldType": "TABLE", "isMandatory": true, "displayOrder": 20, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "tableMinRows": 1, "tableMaxRows": 500, "tableStriped": true, "tableBordered": true,
        "tableColumns": "[{\"name\":\"sku\",\"label\":\"SKU\",\"type\":\"TEXT\",\"width\":140,\"required\":true},{\"name\":\"productName\",\"label\":\"Product\",\"type\":\"TEXT\",\"width\":260,\"required\":true},{\"name\":\"quantity\",\"label\":\"Qty\",\"type\":\"NUMBER\",\"width\":100,\"required\":true},{\"name\":\"listPrice\",\"label\":\"List Price\",\"type\":\"NUMBER\",\"width\":110,\"required\":true},{\"name\":\"discountPercent\",\"label\":\"Disc %\",\"type\":\"NUMBER\",\"width\":100,\"defaultValue\":\"0\"},{\"name\":\"netPrice\",\"label\":\"Net Price\",\"type\":\"NUMBER\",\"width\":110,\"required\":true},{\"name\":\"lineTotal\",\"label\":\"Line Total\",\"type\":\"NUMBER\",\"width\":130,\"computed\":\"MULTIPLY(@{quantity}, @{netPrice})\"}]", "validation": "MinRows(1, \"At least one line item required\")" },
      { "name": "orderValue", "label": "Total Order Value", "fieldType": "CURRENCY", "isReadonly": true, "isLimited": true, "inSummary": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "defaultValue": "SUM_COLUMN(\"lineItems\", \"lineTotal\")" },
      { "name": "weightedDiscountPercent", "label": "Weighted Discount %", "fieldType": "NUMBER", "isMandatory": true, "inSummary": true, "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Min(0) AND Max(100)" },
      { "name": "marginPercent", "label": "Gross Margin %", "fieldType": "NUMBER", "isMandatory": true, "inSummary": true, "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4", "validation": "Required()" },
      { "name": "withinStandardTerms", "label": "Within Standard Price Terms?", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "true", "inSummary": true, "displayOrder": 33, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4" },
      { "name": "justification", "label": "Justification for Override", "fieldType": "TEXTAREA", "displayOrder": 34, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "visibilityExpression": "@{withinStandardTerms} == false",
        "validation": "ValidWhen(@{withinStandardTerms} == true OR HAS_MIN_LENGTH(@{justification}, 30), \"Justification required for override\")" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Sales Manager", "approverType": "ROLE", "roleName": "SALES_MANAGER", "amountLimit": 10000, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Commercial Director", "approverType": "ROLE", "roleName": "COMMERCIAL_DIRECTOR", "amountLimit": 100000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "CEO", "approverType": "ROLE", "roleName": "CEO", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
