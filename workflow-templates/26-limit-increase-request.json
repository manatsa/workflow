{
  "_comment": "Customer Limit Increase Request — overdraft, card, or transfer limit changes with credit/risk approval.",
  "name": "Customer Limit Increase Request",
  "code": "LIR",
  "description": "Request a permanent or temporary increase in customer limits (overdraft, card, transfer, ATM).",
  "icon": "trending_up",
  "displayOrder": 26,
  "requiresApproval": true,
  "commentsMandatory": false,
  "commentsMandatoryOnReject": true,
  "commentsMandatoryOnEscalate": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "titleTemplate": "@{requestRef} - @{customerName} (@{limitType})",
  "reminderEnabled": true,
  "reminderFrequencyHours": 24,
  "reminderMaxCount": 3,
  "reminderStartAfterHours": 24,
  "escalationEnabled": true,
  "escalationAfterHours": 72,
  "escalationAction": "NOTIFY_ADMIN",
  "reminderEmailSubject": "Reminder: Limit Increase @{referenceNumber} pending",
  "reminderEmailBody": "<p>Limit increase request <strong>@{referenceNumber}</strong> awaiting your decision.</p>",
  "forms": [
    {
      "name": "Main Form",
      "displayOrder": 0,
      "screens": [
        {
          "id": "temp_screen_1",
          "title": "Request",
          "displayOrder": 0,
          "icon": "info"
        },
        {
          "id": "temp_screen_2",
          "title": "Customer",
          "displayOrder": 1,
          "icon": "person"
        },
        {
          "id": "temp_screen_3",
          "title": "Limit Details",
          "displayOrder": 2,
          "icon": "tune"
        },
        {
          "id": "temp_screen_4",
          "title": "Justification",
          "displayOrder": 3,
          "icon": "edit_note"
        },
        {
          "id": "temp_screen_5",
          "title": "Documents",
          "displayOrder": 4,
          "icon": "attach_file"
        },
        {
          "id": "temp_screen_6",
          "title": "Review & Submit",
          "displayOrder": 5,
          "icon": "fact_check",
          "isSummaryScreen": true
        }
      ],
      "fieldGroups": [
        {
          "id": "temp_grp_1",
          "title": "Reference",
          "displayOrder": 0,
          "columns": 2,
          "isCollapsible": false,
          "screenId": "temp_screen_1"
        },
        {
          "id": "temp_grp_2",
          "title": "Customer",
          "displayOrder": 1,
          "columns": 2,
          "isCollapsible": false,
          "screenId": "temp_screen_2"
        },
        {
          "id": "temp_grp_3",
          "title": "Current vs Requested Limit",
          "displayOrder": 2,
          "columns": 2,
          "isCollapsible": false,
          "screenId": "temp_screen_3"
        },
        {
          "id": "temp_grp_4",
          "title": "Customer Profile",
          "displayOrder": 3,
          "columns": 2,
          "isCollapsible": false,
          "screenId": "temp_screen_3"
        },
        {
          "id": "temp_grp_5",
          "title": "Justification",
          "displayOrder": 4,
          "columns": 1,
          "isCollapsible": false,
          "screenId": "temp_screen_4"
        },
        {
          "id": "temp_grp_6",
          "title": "Supporting Documents",
          "displayOrder": 5,
          "columns": 1,
          "isCollapsible": false,
          "screenId": "temp_screen_5"
        }
      ],
      "fields": [
        {
          "name": "requestRef",
          "label": "Request Reference",
          "fieldType": "TEXT",
          "defaultValue": "SEQUENCE(\"LIR-\")",
          "isReadonly": true,
          "isTitle": true,
          "inSummary": true,
          "displayOrder": 0,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_1"
        },
        {
          "name": "requestDate",
          "label": "Request Date",
          "fieldType": "DATE",
          "defaultValue": "TODAY()",
          "isReadonly": true,
          "inSummary": true,
          "displayOrder": 1,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_1"
        },
        {
          "name": "officer",
          "label": "Requesting Officer",
          "fieldType": "TEXT",
          "defaultValue": "CURRENT_USER()",
          "isReadonly": true,
          "displayOrder": 2,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_1"
        },
        {
          "name": "branch",
          "label": "Branch",
          "fieldType": "TEXT",
          "isMandatory": true,
          "displayOrder": 3,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_1",
          "validation": "Required()"
        },
        {
          "name": "customerNumber",
          "label": "Customer Number",
          "fieldType": "TEXT",
          "isMandatory": true,
          "inSummary": true,
          "displayOrder": 10,
          "columnSpan": 1,
          "screenId": "temp_screen_2",
          "fieldGroupId": "temp_grp_2",
          "validation": "Required()"
        },
        {
          "name": "customerName",
          "label": "Customer Name",
          "fieldType": "TEXT",
          "isMandatory": true,
          "isTitle": true,
          "inSummary": true,
          "displayOrder": 11,
          "columnSpan": 1,
          "screenId": "temp_screen_2",
          "fieldGroupId": "temp_grp_2",
          "validation": "Required()"
        },
        {
          "name": "accountNumber",
          "label": "Account / Card Number",
          "fieldType": "TEXT",
          "isMandatory": true,
          "inSummary": true,
          "displayOrder": 12,
          "columnSpan": 1,
          "screenId": "temp_screen_2",
          "fieldGroupId": "temp_grp_2",
          "validation": "Required()"
        },
        {
          "name": "customerSegment",
          "label": "Customer Segment",
          "fieldType": "SELECT",
          "displayOrder": 13,
          "columnSpan": 1,
          "screenId": "temp_screen_2",
          "fieldGroupId": "temp_grp_2",
          "options": [
            {
              "value": "MASS",
              "label": "Mass Market",
              "displayOrder": 0
            },
            {
              "value": "AFFLUENT",
              "label": "Affluent",
              "displayOrder": 1
            },
            {
              "value": "PRIVATE",
              "label": "Private Banking",
              "displayOrder": 2
            },
            {
              "value": "SME",
              "label": "SME",
              "displayOrder": 3
            },
            {
              "value": "CORPORATE",
              "label": "Corporate",
              "displayOrder": 4
            }
          ]
        },
        {
          "name": "limitType",
          "label": "Limit Type",
          "fieldType": "SELECT",
          "isMandatory": true,
          "inSummary": true,
          "displayOrder": 20,
          "columnSpan": 1,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_3",
          "options": [
            {
              "value": "OVERDRAFT",
              "label": "Overdraft",
              "displayOrder": 0
            },
            {
              "value": "CREDIT_CARD",
              "label": "Credit Card",
              "displayOrder": 1
            },
            {
              "value": "DEBIT_CARD_DAILY",
              "label": "Debit Card Daily",
              "displayOrder": 2
            },
            {
              "value": "ATM_DAILY",
              "label": "ATM Daily Withdrawal",
              "displayOrder": 3
            },
            {
              "value": "INTERNET_TRANSFER",
              "label": "Internet Transfer Daily",
              "displayOrder": 4
            },
            {
              "value": "MOBILE_TRANSFER",
              "label": "Mobile Transfer Daily",
              "displayOrder": 5
            },
            {
              "value": "POS_DAILY",
              "label": "POS Daily",
              "displayOrder": 6
            }
          ],
          "validation": "Required()"
        },
        {
          "name": "increaseNature",
          "label": "Nature",
          "fieldType": "SELECT",
          "isMandatory": true,
          "defaultValue": "PERMANENT",
          "inSummary": true,
          "displayOrder": 21,
          "columnSpan": 1,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_3",
          "options": [
            {
              "value": "PERMANENT",
              "label": "Permanent",
              "displayOrder": 0
            },
            {
              "value": "TEMPORARY",
              "label": "Temporary",
              "displayOrder": 1
            }
          ],
          "validation": "Required()"
        },
        {
          "name": "currentLimit",
          "label": "Current Limit",
          "fieldType": "CURRENCY",
          "isMandatory": true,
          "inSummary": true,
          "displayOrder": 22,
          "columnSpan": 1,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_3",
          "validation": "Required() AND Min(0)"
        },
        {
          "name": "requestedLimit",
          "label": "Requested Limit",
          "fieldType": "CURRENCY",
          "isMandatory": true,
          "isLimited": true,
          "inSummary": true,
          "displayOrder": 23,
          "columnSpan": 1,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_3",
          "validation": "Required() AND Min(0) AND ValidWhen(@{requestedLimit} > @{currentLimit}, \"Requested limit must exceed current limit\")"
        },
        {
          "name": "increaseAmount",
          "label": "Increase Amount",
          "fieldType": "CURRENCY",
          "isReadonly": true,
          "inSummary": true,
          "displayOrder": 24,
          "columnSpan": 1,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_3",
          "defaultValue": "SUBTRACT(@{requestedLimit}, @{currentLimit})"
        },
        {
          "name": "increasePercent",
          "label": "Increase %",
          "fieldType": "NUMBER",
          "isReadonly": true,
          "displayOrder": 25,
          "columnSpan": 1,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_3",
          "defaultValue": "PERCENTAGE(SUBTRACT(@{requestedLimit}, @{currentLimit}), @{currentLimit})"
        },
        {
          "name": "effectiveFrom",
          "label": "Effective From",
          "fieldType": "DATE",
          "isMandatory": true,
          "defaultValue": "TODAY()",
          "displayOrder": 26,
          "columnSpan": 1,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_3",
          "validation": "Required()"
        },
        {
          "name": "effectiveTo",
          "label": "Effective To",
          "fieldType": "DATE",
          "displayOrder": 27,
          "columnSpan": 1,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_3",
          "visibilityExpression": "@{increaseNature} == 'TEMPORARY'",
          "validation": "ValidWhen(@{increaseNature} != 'TEMPORARY' OR IS_NOT_EMPTY(@{effectiveTo}), \"End date required for temporary increase\")"
        },
        {
          "name": "monthlyIncome",
          "label": "Customer Monthly Income",
          "fieldType": "CURRENCY",
          "isMandatory": true,
          "displayOrder": 30,
          "columnSpan": 1,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_4",
          "validation": "Required() AND Min(0)"
        },
        {
          "name": "relationshipYears",
          "label": "Years with Bank",
          "fieldType": "NUMBER",
          "isMandatory": true,
          "displayOrder": 31,
          "columnSpan": 1,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_4",
          "validation": "Required() AND Min(0)"
        },
        {
          "name": "creditScore",
          "label": "Internal Credit Score",
          "fieldType": "NUMBER",
          "displayOrder": 32,
          "columnSpan": 1,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_4"
        },
        {
          "name": "hasArrears",
          "label": "Customer in Arrears?",
          "fieldType": "YES_NO",
          "isMandatory": true,
          "defaultValue": "false",
          "inSummary": true,
          "displayOrder": 33,
          "columnSpan": 1,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_4"
        },
        {
          "name": "reason",
          "label": "Reason for Increase",
          "fieldType": "TEXTAREA",
          "isMandatory": true,
          "inSummary": true,
          "displayOrder": 40,
          "columnSpan": 2,
          "screenId": "temp_screen_4",
          "fieldGroupId": "temp_grp_5",
          "validation": "Required() AND MinLength(30)"
        },
        {
          "name": "officerRecommendation",
          "label": "Officer Recommendation",
          "fieldType": "TEXTAREA",
          "isMandatory": true,
          "displayOrder": 41,
          "columnSpan": 2,
          "screenId": "temp_screen_4",
          "fieldGroupId": "temp_grp_5",
          "validation": "Required() AND MinLength(20)"
        },
        {
          "name": "customerRequest",
          "label": "Customer Written Request",
          "fieldType": "FILE",
          "isMandatory": true,
          "displayOrder": 50,
          "columnSpan": 2,
          "screenId": "temp_screen_5",
          "fieldGroupId": "temp_grp_6",
          "allowedFileTypes": "pdf,jpg,jpeg,png",
          "maxFileSize": 10485760,
          "validation": "Required(\"Signed customer request is required\")"
        },
        {
          "name": "incomeProof",
          "label": "Latest Income Proof",
          "fieldType": "FILE",
          "displayOrder": 51,
          "columnSpan": 2,
          "screenId": "temp_screen_5",
          "fieldGroupId": "temp_grp_6",
          "allowedFileTypes": "pdf,jpg,jpeg,png",
          "maxFileSize": 10485760
        },
        {
          "name": "additionalDocs",
          "label": "Additional Documents",
          "fieldType": "FILE",
          "multiple": true,
          "displayOrder": 52,
          "columnSpan": 2,
          "screenId": "temp_screen_5",
          "fieldGroupId": "temp_grp_6",
          "allowedFileTypes": "pdf,jpg,jpeg,png,doc,docx",
          "maxFileSize": 10485760,
          "maxFiles": 10
        }
      ]
    }
  ],
