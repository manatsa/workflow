{
  "_comment": "Adverse Event / Pharmacovigilance — capture and report an ADR / adverse event to regulators.",
  "name": "Adverse Event Report",
  "code": "PAE",
  "description": "Capture, assess and report an adverse drug reaction (ADR) or adverse event to regulators (e.g. FDA, EMA, local NRA).",
  "icon": "report",
  "displayOrder": 79,
  "requiresApproval": true,
  "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "NON_FINANCIAL",
  "industryCode": "PHARMA",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{aeRef} - @{productName} (@{seriousness})",
  "reminderEnabled": true, "reminderFrequencyHours": 6, "reminderMaxCount": 5, "reminderStartAfterHours": 2,
  "escalationEnabled": true, "escalationAfterHours": 24, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Case", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Patient", "displayOrder": 1, "icon": "person" },
      { "id": "temp_screen_3", "title": "Product & Event", "displayOrder": 2, "icon": "medication" },
      { "id": "temp_screen_4", "title": "Assessment", "displayOrder": 3, "icon": "assessment" },
      { "id": "temp_screen_5", "title": "Documents", "displayOrder": 4, "icon": "attach_file" },
      { "id": "temp_screen_6", "title": "Review", "displayOrder": 5, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Case Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Reporter", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Patient", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Medical History", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Suspect Product", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_6", "title": "Event", "displayOrder": 5, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_7", "title": "Causality & Reporting", "displayOrder": 6, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_4" },
      { "id": "temp_grp_8", "title": "Documents", "displayOrder": 7, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_5" }
    ],
    "fields": [
      { "name": "aeRef", "label": "Case Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"PAE-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "receivedDate", "label": "Date Received", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "seriousness", "label": "Seriousness", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [ { "value": "NON_SERIOUS", "label": "Non-Serious", "displayOrder": 0 }, { "value": "SERIOUS", "label": "Serious", "displayOrder": 1 }, { "value": "LIFE_THREAT", "label": "Life-Threatening", "displayOrder": 2 }, { "value": "DEATH", "label": "Death", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "expectedness", "label": "Expectedness", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [ { "value": "EXPECTED", "label": "Expected (in label)", "displayOrder": 0 }, { "value": "UNEXPECTED", "label": "Unexpected", "displayOrder": 1 } ], "validation": "Required()" },
      { "name": "reporterType", "label": "Reporter Type", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "HCP", "label": "Healthcare Professional", "displayOrder": 0 }, { "value": "CONSUMER", "label": "Consumer / Patient", "displayOrder": 1 }, { "value": "MFR", "label": "Manufacturer / MAH", "displayOrder": 2 }, { "value": "REGULATOR", "label": "Regulator", "displayOrder": 3 }, { "value": "LITERATURE", "label": "Literature", "displayOrder": 4 } ], "validation": "Required()" },
      { "name": "reporterName", "label": "Reporter Name", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "reporterContact", "label": "Reporter Contact", "fieldType": "TEXT", "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2" },
      { "name": "patientInitials", "label": "Patient Initials", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required() AND MaxLength(10)" },
      { "name": "age", "label": "Age", "fieldType": "NUMBER", "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Min(0) AND Max(150)" },
      { "name": "gender", "label": "Gender", "fieldType": "SELECT", "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "F", "label": "Female", "displayOrder": 0 }, { "value": "M", "label": "Male", "displayOrder": 1 }, { "value": "O", "label": "Other / Unknown", "displayOrder": 2 } ] },
      { "name": "weight", "label": "Weight (kg)", "fieldType": "NUMBER", "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Min(0)" },
      { "name": "medicalHistory", "label": "Relevant Medical History", "fieldType": "TEXTAREA", "displayOrder": 30, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "concomitantMeds", "label": "Concomitant Medications", "fieldType": "TEXTAREA", "displayOrder": 31, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "productName", "label": "Suspect Product", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "Required()" },
      { "name": "batchNumber", "label": "Batch / Lot Number", "fieldType": "TEXT", "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5" },
      { "name": "dose", "label": "Dose & Route", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "Required()" },
      { "name": "therapyStart", "label": "Therapy Start Date", "fieldType": "DATE", "displayOrder": 43, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5" },
      { "name": "indication", "label": "Indication for Use", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 44, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "Required()" },
      { "name": "eventDescription", "label": "Event Description", "fieldType": "TEXTAREA", "isMandatory": true, "inSummary": true, "displayOrder": 50, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "validation": "Required() AND MinLength(50)" },
      { "name": "eventOnset", "label": "Event Onset Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 51, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "validation": "Required()" },
      { "name": "outcome", "label": "Outcome", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 52, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6",
        "options": [ { "value": "RECOVERED", "label": "Recovered / Resolved", "displayOrder": 0 }, { "value": "RECOVERING", "label": "Recovering", "displayOrder": 1 }, { "value": "NOT_RECOVERED", "label": "Not Recovered", "displayOrder": 2 }, { "value": "SEQUELAE", "label": "With Sequelae", "displayOrder": 3 }, { "value": "FATAL", "label": "Fatal", "displayOrder": 4 }, { "value": "UNKNOWN", "label": "Unknown", "displayOrder": 5 } ], "validation": "Required()" },
      { "name": "causalityAssessment", "label": "Causality Assessment", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 60, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_7",
        "options": [ { "value": "CERTAIN", "label": "Certain", "displayOrder": 0 }, { "value": "PROBABLE", "label": "Probable", "displayOrder": 1 }, { "value": "POSSIBLE", "label": "Possible", "displayOrder": 2 }, { "value": "UNLIKELY", "label": "Unlikely", "displayOrder": 3 }, { "value": "UNASSESSABLE", "label": "Unassessable", "displayOrder": 4 } ], "validation": "Required()" },
      { "name": "regulatoryDeadline", "label": "Regulatory Submission Deadline", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 61, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_7", "validation": "Required()" },
      { "name": "submittedToRegulator", "label": "Submitted to Regulator", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 62, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_7" },
      { "name": "regulatoryCaseId", "label": "Regulatory Case ID", "fieldType": "TEXT", "displayOrder": 63, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_7", "visibilityExpression": "@{submittedToRegulator} == true" },
      { "name": "cioms", "label": "CIOMS / MedWatch Form", "fieldType": "FILE", "isMandatory": true, "displayOrder": 70, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_8", "allowedFileTypes": "pdf,xml", "maxFileSize": 10485760, "validation": "Required()" },
      { "name": "clinicalDocs", "label": "Clinical / Source Documents", "fieldType": "FILE", "multiple": true, "displayOrder": 71, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_8", "allowedFileTypes": "pdf,jpg,jpeg,png,doc,docx", "maxFileSize": 10485760, "maxFiles": 10 }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "PV Case Processor", "approverType": "ROLE", "roleName": "PV_PROCESSOR", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "PV Physician / Medical Reviewer", "approverType": "ROLE", "roleName": "PV_PHYSICIAN", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Qualified Person for PV (QPPV)", "approverType": "ROLE", "roleName": "QPPV", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
