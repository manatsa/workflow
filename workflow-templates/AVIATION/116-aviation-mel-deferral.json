{
  "_comment": "Aircraft MEL Deferral — defer an unserviceable item under the Minimum Equipment List.",
  "name": "Aircraft MEL Deferral",
  "code": "AMD",
  "description": "Defer an aircraft unserviceable item under the Minimum Equipment List (MEL) with approved rectification interval.",
  "icon": "build",
  "displayOrder": 116,
  "requiresApproval": true, "commentsMandatoryOnReject": true, "commentsMandatoryOnEscalate": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "NON_FINANCIAL",
  "industryCode": "AVIATION",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{melRef} - @{tailNumber} (@{melCategory})",
  "reminderEnabled": true, "reminderFrequencyHours": 2, "reminderMaxCount": 4, "reminderStartAfterHours": 1,
  "escalationEnabled": true, "escalationAfterHours": 8, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Aircraft & Defect", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "MEL Reference", "displayOrder": 1, "icon": "menu_book" },
      { "id": "temp_screen_3", "title": "Review", "displayOrder": 2, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Aircraft", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Defect", "displayOrder": 2, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_4", "title": "MEL Item", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Operational Conditions", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" }
    ],
    "fields": [
      { "name": "melRef", "label": "MEL Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"AMD-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "raisedDateTime", "label": "Raised Date/Time", "fieldType": "DATE", "defaultValue": "TODAY()", "isMandatory": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()" },
      { "name": "engineerName", "label": "Licensed Engineer", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "engineerLicence", "label": "Engineer Licence #", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "tailNumber", "label": "Aircraft Registration", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "aircraftType", "label": "Aircraft Type", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "station", "label": "Station / Base", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "flightHours", "label": "A/C Flight Hours", "fieldType": "NUMBER", "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Min(0)" },
      { "name": "defectDescription", "label": "Defect Description", "fieldType": "TEXTAREA", "isMandatory": true, "inSummary": true, "displayOrder": 20, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required() AND MinLength(20)" },
      { "name": "discoveredHow", "label": "How Discovered", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 21, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "PIREP", "label": "Pilot Report (PIREP)", "displayOrder": 0 }, { "value": "INSPECTION", "label": "Inspection", "displayOrder": 1 }, { "value": "MONITORING", "label": "Monitoring System", "displayOrder": 2 }, { "value": "MAINTENANCE", "label": "Maintenance Check", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "melChapter", "label": "MEL Chapter / Item", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required()" },
      { "name": "melCategory", "label": "MEL Category", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "options": [ { "value": "A", "label": "Category A (Specified Interval)", "displayOrder": 0 }, { "value": "B", "label": "Category B (3 Days)", "displayOrder": 1 }, { "value": "C", "label": "Category C (10 Days)", "displayOrder": 2 }, { "value": "D", "label": "Category D (120 Days)", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "rectificationInterval", "label": "Max Rectification Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 32, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND DateAfter(\"today\", \"Rectification must be future\")" },
      { "name": "oCondition", "label": "(O) Operational Procedures Applied", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5" },
      { "name": "mCondition", "label": "(M) Maintenance Procedures Applied", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5" },
      { "name": "placardFitted", "label": "Placard Fitted", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{placardFitted} == true, \"Placard must be fitted\")" },
      { "name": "techLogEntered", "label": "Tech Log Entry Made", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 43, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{techLogEntered} == true, \"Tech log entry required\")" },
      { "name": "operationalImpact", "label": "Operational Impact / Limitations", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 44, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "Required() AND MinLength(20)" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Licensed Maintenance Engineer", "approverType": "ROLE", "roleName": "LAE", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 2, "name": "Duty Maintenance Manager", "approverType": "ROLE", "roleName": "DUTY_MAINT_MANAGER", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Nominated Person Maintenance (CAMO)", "approverType": "ROLE", "roleName": "NP_MAINTENANCE", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
