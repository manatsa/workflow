{
  "_comment": "Media Buy Authorisation — authorise a media buy / insertion order across TV/digital/print/OOH.",
  "name": "Media Buy Authorisation",
  "code": "AMB",
  "description": "Authorise a media buy / insertion order across TV, digital, print, OOH or radio.",
  "icon": "live_tv",
  "displayOrder": 158,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "ADVERTISING",
  "workflowTypeCode": "FINANCE",
  "titleTemplate": "@{mediaRef} - @{campaignName} (@{totalBuy})",
  "reminderEnabled": true, "reminderFrequencyHours": 12, "reminderMaxCount": 3, "reminderStartAfterHours": 12,
  "escalationEnabled": true, "escalationAfterHours": 48, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Campaign", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Media Plan", "displayOrder": 1, "icon": "list" },
      { "id": "temp_screen_3", "title": "Review", "displayOrder": 2, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Campaign & Client", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Media Plan Lines", "displayOrder": 2, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Totals & Commission", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" }
    ],
    "fields": [
      { "name": "mediaRef", "label": "Media Buy Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"AMB-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "submissionDate", "label": "Submission Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "planner", "label": "Media Planner", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "briefRef", "label": "Linked Brief Reference", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "clientName", "label": "Client", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "campaignName", "label": "Campaign", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "flightStart", "label": "Flight Start", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND DateAfter(\"today\", \"Must be future\")" },
      { "name": "flightEnd", "label": "Flight End", "fieldType": "DATE", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "mediaPlan", "label": "Media Plan Lines", "fieldType": "TABLE", "isMandatory": true, "displayOrder": 20, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "tableMinRows": 1, "tableMaxRows": 200, "tableStriped": true, "tableBordered": true,
        "tableColumns": "[{\"name\":\"channel\",\"label\":\"Channel\",\"type\":\"SELECT\",\"width\":140,\"required\":true,\"options\":[\"TV\",\"Radio\",\"Print\",\"OOH\",\"Digital\",\"Social\",\"Cinema\",\"Influencer\"]},{\"name\":\"vendor\",\"label\":\"Publisher / Vendor\",\"type\":\"TEXT\",\"width\":200,\"required\":true},{\"name\":\"placement\",\"label\":\"Placement\",\"type\":\"TEXT\",\"width\":240,\"required\":true},{\"name\":\"impressions\",\"label\":\"Impressions / GRPs\",\"type\":\"NUMBER\",\"width\":150},{\"name\":\"cost\",\"label\":\"Net Cost\",\"type\":\"NUMBER\",\"width\":130,\"required\":true}]", "validation": "MinRows(1, \"At least one media line required\")" },
      { "name": "netMediaSpend", "label": "Net Media Spend", "fieldType": "CURRENCY", "isReadonly": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "defaultValue": "SUM_COLUMN(\"mediaPlan\", \"cost\")" },
      { "name": "commissionPercent", "label": "Agency Commission %", "fieldType": "NUMBER", "isMandatory": true, "defaultValue": "15", "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Min(0) AND Max(25)" },
      { "name": "commissionAmount", "label": "Commission Amount", "fieldType": "CURRENCY", "isReadonly": true, "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "defaultValue": "PERCENT_OF(@{netMediaSpend}, @{commissionPercent})" },
      { "name": "totalBuy", "label": "Total Buy (Gross)", "fieldType": "CURRENCY", "isReadonly": true, "isLimited": true, "inSummary": true, "displayOrder": 33, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "defaultValue": "SUM(@{netMediaSpend}, @{commissionAmount})" },
      { "name": "clientPONumber", "label": "Client PO Number", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 34, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "creativeApproved", "label": "Creative Approved", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 35, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "ValidWhen(@{creativeApproved} == true, \"Creative approval required\")" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Media Planner", "approverType": "ROLE", "roleName": "MEDIA_PLANNER", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Media Director", "approverType": "ROLE", "roleName": "MEDIA_DIRECTOR", "amountLimit": 100000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Account Director", "approverType": "ROLE", "roleName": "ACCOUNT_DIRECTOR", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
