          "label": "Initial Deposit",
          "fieldType": "CURRENCY",
          "isMandatory": true,
          "isLimited": true,
          "inSummary": true,
          "displayOrder": 6,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_2",
          "validation": "Required() AND Min(0, \"Deposit cannot be negative\")"
        },
        {
          "name": "fdTermMonths",
          "label": "Fixed Deposit Term (months)",
          "fieldType": "NUMBER",
          "displayOrder": 7,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_2",
          "visibilityExpression": "@{accountType} == 'FIXED_DEPOSIT'",
          "validation": "ValidWhen(@{accountType} != 'FIXED_DEPOSIT' OR @{fdTermMonths} >= 1, \"Term must be at least 1 month\")"
        },
        {
          "name": "title",
          "label": "Title",
          "fieldType": "SELECT",
          "displayOrder": 10,
