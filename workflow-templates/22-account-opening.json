        {
          "id": "temp_grp_8",
          "title": "Source of Funds",
          "displayOrder": 7,
          "columns": 2,
          "isCollapsible": false,
          "screenId": "temp_screen_4"
        },
        {
          "id": "temp_grp_9",
          "title": "KYC Document Uploads",
          "displayOrder": 8,
          "columns": 1,
          "isCollapsible": false,
          "screenId": "temp_screen_5"
        },
        {
          "id": "temp_grp_10",
          "title": "Risk Assessment",
          "displayOrder": 9,
          "columns": 2,
          "isCollapsible": false,
          "screenId": "temp_screen_6"
        },
        {
          "id": "temp_grp_11",
          "title": "Declarations",
          "displayOrder": 10,
          "columns": 1,
          "isCollapsible": false,
          "screenId": "temp_screen_6"
        }
      ],
      "fields": [
        {
          "name": "aoNumber",
          "label": "Application Number",
          "fieldType": "TEXT",
          "defaultValue": "SEQUENCE(\"AO-\")",
          "isReadonly": true,
          "isTitle": true,
          "inSummary": true,
          "displayOrder": 0,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_1"
        },
        {
          "name": "applicationDate",
          "label": "Application Date",
          "fieldType": "DATE",
          "defaultValue": "TODAY()",
          "isReadonly": true,
          "inSummary": true,
          "displayOrder": 1,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_1"
        },
        {
          "name": "branch",
          "label": "Branch",
          "fieldType": "TEXT",
          "isMandatory": true,
          "inSummary": true,
          "displayOrder": 2,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_1",
          "validation": "Required()"
        },
        {
          "name": "openedBy",
          "label": "Opened By (Officer)",
          "fieldType": "TEXT",
          "defaultValue": "CURRENT_USER()",
          "isReadonly": true,
          "inSummary": true,
          "displayOrder": 3,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_1"
        },
        {
          "name": "accountType",
          "label": "Account Type",
          "fieldType": "SELECT",
          "isMandatory": true,
          "inSummary": true,
          "displayOrder": 4,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_2",
          "options": [
            {
              "value": "SAVINGS",
              "label": "Savings",
              "displayOrder": 0
            },
            {
              "value": "CURRENT",
              "label": "Current / Cheque",
              "displayOrder": 1
            },
            {
              "value": "FIXED_DEPOSIT",
              "label": "Fixed Deposit",
              "displayOrder": 2
            },
            {
              "value": "STUDENT",
              "label": "Student",
              "displayOrder": 3
            },
            {
              "value": "SENIOR",
              "label": "Senior Citizen",
              "displayOrder": 4
            }
          ],
          "validation": "Required()"
        },
        {
          "name": "currency",
          "label": "Currency",
          "fieldType": "SELECT",
          "isMandatory": true,
          "defaultValue": "USD",
          "inSummary": true,
          "displayOrder": 5,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_2",
          "options": [
            {
              "value": "USD",
              "label": "US Dollar (USD)",
              "displayOrder": 0
            },
            {
              "value": "EUR",
              "label": "Euro (EUR)",
              "displayOrder": 1
            },
            {
              "value": "GBP",
              "label": "British Pound (GBP)",
              "displayOrder": 2
            },
            {
              "value": "ZAR",
              "label": "South African Rand (ZAR)",
              "displayOrder": 3
            },
            {
              "value": "ZWL",
              "label": "Zimbabwe Dollar (ZWL)",
              "displayOrder": 4
            }
          ],
          "validation": "Required()"
