{
  "_comment": "Retail Account Opening — KYC capture, identity verification, risk rating, and tiered approval.",
  "name": "Account Opening (Retail KYC)",
  "code": "AO",
  "description": "Open a new retail customer account with KYC, source-of-funds, and risk-based approval routing.",
  "icon": "account_balance",
  "displayOrder": 22,
  "requiresApproval": true,
  "commentsMandatory": false,
  "commentsMandatoryOnReject": true,
  "commentsMandatoryOnEscalate": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "titleTemplate": "@{aoNumber} - @{firstName} @{lastName} (@{accountType})",
  "reminderEnabled": true,
  "reminderFrequencyHours": 24,
  "reminderMaxCount": 3,
  "reminderStartAfterHours": 24,
  "escalationEnabled": true,
  "escalationAfterHours": 48,
  "escalationAction": "NOTIFY_ADMIN",
  "reminderIncludeSubmitter": true,
  "reminderEmailSubject": "Reminder @{reminderNumber}/@{reminderMax}: Account Opening @{referenceNumber} pending",
  "reminderEmailBody": "<p>Dear @{approverName},</p><p>Account Opening request <strong>@{referenceNumber}</strong> from @{submitterName} is awaiting your review (pending @{daysPending} day(s)).</p>",
  "forms": [
    {
      "name": "Main Form",
      "displayOrder": 0,
      "screens": [
        {
          "id": "temp_screen_1",
          "title": "Account Type",
          "description": "Type of account being opened",
          "displayOrder": 0,
          "icon": "savings"
        },
        {
          "id": "temp_screen_2",
          "title": "Personal Details",
          "description": "Customer identity",
          "displayOrder": 1,
          "icon": "person"
        },
        {
          "id": "temp_screen_3",
          "title": "Address & Contact",
          "description": "Where to reach the customer",
          "displayOrder": 2,
          "icon": "home"
        },
        {
          "id": "temp_screen_4",
          "title": "Employment & Income",
          "description": "Source of funds",
          "displayOrder": 3,
          "icon": "work"
        },
        {
          "id": "temp_screen_5",
          "title": "KYC Documents",
          "description": "Identity & address proofs",
          "displayOrder": 4,
          "icon": "badge"
        },
        {
          "id": "temp_screen_6",
          "title": "Risk & Declarations",
          "description": "Risk rating and customer declarations",
          "displayOrder": 5,
          "icon": "verified_user"
        },
        {
          "id": "temp_screen_7",
          "title": "Review & Submit",
          "description": "Final review",
          "displayOrder": 6,
          "icon": "fact_check",
          "isSummaryScreen": true
        }
      ],
      "fieldGroups": [
        {
          "id": "temp_grp_1",
          "title": "Application Reference",
          "displayOrder": 0,
          "columns": 2,
          "isCollapsible": false,
          "screenId": "temp_screen_1"
        },
        {
          "id": "temp_grp_2",
          "title": "Account Setup",
          "displayOrder": 1,
          "columns": 2,
          "isCollapsible": false,
          "screenId": "temp_screen_1"
        },
        {
          "id": "temp_grp_3",
          "title": "Identity",
          "displayOrder": 2,
          "columns": 2,
          "isCollapsible": false,
          "screenId": "temp_screen_2"
        },
        {
          "id": "temp_grp_4",
          "title": "Demographics",
          "displayOrder": 3,
          "columns": 2,
          "isCollapsible": false,
          "screenId": "temp_screen_2"
        },
        {
          "id": "temp_grp_5",
          "title": "Residential Address",
          "displayOrder": 4,
          "columns": 2,
          "isCollapsible": false,
          "screenId": "temp_screen_3"
        },
        {
          "id": "temp_grp_6",
          "title": "Contact Details",
          "displayOrder": 5,
          "columns": 2,
          "isCollapsible": false,
          "screenId": "temp_screen_3"
        },
        {
          "id": "temp_grp_7",
          "title": "Employment",
          "displayOrder": 6,
          "columns": 2,
          "isCollapsible": false,
          "screenId": "temp_screen_4"
