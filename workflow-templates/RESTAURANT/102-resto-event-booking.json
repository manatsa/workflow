{
  "_comment": "Restaurant Event Booking — book a private event / function (banquet, wedding, conference) at an outlet.",
  "name": "Restaurant Event Booking",
  "code": "REB",
  "description": "Book a private event or function at a restaurant outlet (banquet, wedding, conference).",
  "icon": "celebration",
  "displayOrder": 102,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "RESTAURANT",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{eventRef} - @{clientName} (@{eventDate})",
  "reminderEnabled": true, "reminderFrequencyHours": 12, "reminderMaxCount": 4, "reminderStartAfterHours": 4,
  "escalationEnabled": true, "escalationAfterHours": 48, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Client & Event", "displayOrder": 0, "icon": "event" },
      { "id": "temp_screen_2", "title": "Menu & Services", "displayOrder": 1, "icon": "restaurant" },
      { "id": "temp_screen_3", "title": "Financials", "displayOrder": 2, "icon": "payments" },
      { "id": "temp_screen_4", "title": "Review", "displayOrder": 3, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference & Client", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Event", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Menu", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Additional Services", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Billing", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" }
    ],
    "fields": [
      { "name": "eventRef", "label": "Event Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"REB-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "bookingDate", "label": "Booking Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "clientName", "label": "Client Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()" },
      { "name": "phone", "label": "Phone", "fieldType": "PHONE", "isMandatory": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required() AND Phone()" },
      { "name": "email", "label": "Email", "fieldType": "EMAIL", "isMandatory": true, "displayOrder": 4, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required() AND ValidWhen(IS_EMAIL(@{email}), \"Enter valid email\")" },
      { "name": "eventType", "label": "Event Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "WEDDING", "label": "Wedding", "displayOrder": 0 }, { "value": "BIRTHDAY", "label": "Birthday", "displayOrder": 1 }, { "value": "CORPORATE", "label": "Corporate / Meeting", "displayOrder": 2 }, { "value": "CONFERENCE", "label": "Conference", "displayOrder": 3 }, { "value": "FUNERAL", "label": "Funeral / Memorial", "displayOrder": 4 }, { "value": "OTHER", "label": "Other", "displayOrder": 5 } ], "validation": "Required()" },
      { "name": "outlet", "label": "Outlet / Venue", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "eventDate", "label": "Event Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND DateAfter(\"today\", \"Date must be future\")" },
      { "name": "startTime", "label": "Start Time", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "endTime", "label": "End Time", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 14, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "guestCount", "label": "Guest Count", "fieldType": "NUMBER", "isMandatory": true, "inSummary": true, "displayOrder": 15, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND Min(1)" },
      { "name": "menuPackage", "label": "Menu Package", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "BRONZE", "label": "Bronze", "displayOrder": 0 }, { "value": "SILVER", "label": "Silver", "displayOrder": 1 }, { "value": "GOLD", "label": "Gold", "displayOrder": 2 }, { "value": "CUSTOM", "label": "Custom", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "dietaryRequirements", "label": "Dietary Requirements / Allergies", "fieldType": "TEXTAREA", "displayOrder": 21, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3" },
      { "name": "openBar", "label": "Open Bar", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "decor", "label": "Decor / Setup Included", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "av", "label": "AV / PA System", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "specialRequests", "label": "Special Requests", "fieldType": "TEXTAREA", "displayOrder": 33, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "pricePerGuest", "label": "Price per Guest", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "Required() AND Min(0)" },
      { "name": "subtotal", "label": "Subtotal", "fieldType": "CURRENCY", "isReadonly": true, "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5",
        "defaultValue": "MULTIPLY(@{guestCount}, @{pricePerGuest})" },
      { "name": "additionalCharges", "label": "Additional Charges", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "Min(0)" },
      { "name": "discount", "label": "Discount", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 43, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "Min(0)" },
      { "name": "totalAmount", "label": "Total Amount", "fieldType": "CURRENCY", "isReadonly": true, "isLimited": true, "inSummary": true, "displayOrder": 44, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5",
        "defaultValue": "SUBTRACT(SUM(@{subtotal}, @{additionalCharges}), @{discount})" },
      { "name": "depositReceived", "label": "Deposit Received", "fieldType": "CURRENCY", "isMandatory": true, "defaultValue": "0", "inSummary": true, "displayOrder": 45, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "Required() AND Min(0)" },
      { "name": "balanceDue", "label": "Balance Due", "fieldType": "CURRENCY", "isReadonly": true, "displayOrder": 46, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5",
        "defaultValue": "SUBTRACT(@{totalAmount}, @{depositReceived})" },
      { "name": "balanceDueDate", "label": "Balance Due Date", "fieldType": "DATE", "isMandatory": true, "displayOrder": 47, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "Required()" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Events Coordinator", "approverType": "ROLE", "roleName": "EVENTS_COORDINATOR", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Outlet Manager", "approverType": "ROLE", "roleName": "OUTLET_MANAGER", "amountLimit": 10000, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 3, "name": "Operations Manager", "approverType": "ROLE", "roleName": "OPS_MANAGER", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
