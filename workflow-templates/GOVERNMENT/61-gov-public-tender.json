{
  "_comment": "Public Procurement Tender — open, evaluate and award a public-sector tender per procurement regulations.",
  "name": "Public Procurement Tender",
  "code": "PPT",
  "description": "Open, evaluate and award a public-sector tender in line with procurement regulations.",
  "icon": "gavel",
  "displayOrder": 61,
  "requiresApproval": true,
  "commentsMandatoryOnReject": true,
  "commentsMandatoryOnEscalate": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "GOVERNMENT",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{tenderRef} - @{tenderTitle} (@{awardAmount})",
  "reminderEnabled": true,
  "reminderFrequencyHours": 48,
  "reminderMaxCount": 4,
  "reminderStartAfterHours": 48,
  "escalationEnabled": true,
  "escalationAfterHours": 168,
  "escalationAction": "NOTIFY_ADMIN",

  "forms": [{
    "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Tender", "displayOrder": 0, "icon": "description" },
      { "id": "temp_screen_2", "title": "Bidders", "displayOrder": 1, "icon": "groups" },
      { "id": "temp_screen_3", "title": "Evaluation", "displayOrder": 2, "icon": "assessment" },
      { "id": "temp_screen_4", "title": "Award", "displayOrder": 3, "icon": "emoji_events" },
      { "id": "temp_screen_5", "title": "Documents", "displayOrder": 4, "icon": "attach_file" },
      { "id": "temp_screen_6", "title": "Review & Submit", "displayOrder": 5, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Tender Info", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Budget & Method", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Bidders Submitted", "displayOrder": 2, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Evaluation Scores", "displayOrder": 3, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_5", "title": "Award", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_4" },
      { "id": "temp_grp_6", "title": "Documents", "displayOrder": 5, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_5" }
    ],
    "fields": [
      { "name": "tenderRef", "label": "Tender Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"PPT-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "issueDate", "label": "Issue Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "tenderTitle", "label": "Tender Title", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 2, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "validation": "Required() AND MinLength(10)" },
      { "name": "ministryOrAgency", "label": "Procuring Entity", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "validation": "Required()" },
      { "name": "category", "label": "Procurement Category", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 4, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [
          { "value": "GOODS", "label": "Goods", "displayOrder": 0 },
          { "value": "WORKS", "label": "Works / Construction", "displayOrder": 1 },
          { "value": "SERVICES", "label": "Services", "displayOrder": 2 },
          { "value": "CONSULTING", "label": "Consulting", "displayOrder": 3 }
        ], "validation": "Required()" },
      { "name": "closingDate", "label": "Bid Closing Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 5, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "validation": "Required() AND DateAfter(\"today\", \"Closing date must be future\")" },
      { "name": "budgetLine", "label": "Budget Line", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "estimatedValue", "label": "Estimated Tender Value", "fieldType": "CURRENCY", "isMandatory": true, "isLimited": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "validation": "Required() AND Min(0.01)" },
      { "name": "procurementMethod", "label": "Procurement Method", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [
          { "value": "OPEN", "label": "Open Competitive", "displayOrder": 0 },
          { "value": "RESTRICTED", "label": "Restricted", "displayOrder": 1 },
          { "value": "SELECTIVE", "label": "Selective / Pre-Qualified", "displayOrder": 2 },
          { "value": "DIRECT", "label": "Direct Procurement", "displayOrder": 3 },
          { "value": "RFQ", "label": "Request for Quotation", "displayOrder": 4 }
        ], "validation": "Required()" },
      { "name": "fundingSource", "label": "Funding Source", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [
          { "value": "TREASURY", "label": "Treasury / Government", "displayOrder": 0 },
          { "value": "DONOR", "label": "Donor-Funded", "displayOrder": 1 },
          { "value": "LOAN", "label": "Loan / Concessional", "displayOrder": 2 },
          { "value": "OWN_FUNDS", "label": "Agency Own Funds", "displayOrder": 3 }
        ], "validation": "Required()" },
      { "name": "bidders", "label": "Bidders Submitted", "fieldType": "TABLE", "isMandatory": true, "displayOrder": 20, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "tableMinRows": 1, "tableMaxRows": 50, "tableStriped": true, "tableBordered": true,
        "tableColumns": "[{\"name\":\"bidderName\",\"label\":\"Bidder\",\"type\":\"TEXT\",\"width\":240,\"required\":true},{\"name\":\"country\",\"label\":\"Country\",\"type\":\"TEXT\",\"width\":140},{\"name\":\"bidAmount\",\"label\":\"Bid Amount\",\"type\":\"NUMBER\",\"width\":140,\"required\":true},{\"name\":\"bidBond\",\"label\":\"Bid Bond\",\"type\":\"NUMBER\",\"width\":140},{\"name\":\"compliant\",\"label\":\"Compliant?\",\"type\":\"SELECT\",\"width\":120,\"options\":[\"YES\",\"NO\"]}]",
        "validation": "MinRows(1, \"At least one bidder required\")" },
      { "name": "numBidders", "label": "Number of Bidders", "fieldType": "NUMBER", "isReadonly": true, "inSummary": true, "displayOrder": 21, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "defaultValue": "COUNT(\"bidders\")" },
      { "name": "evaluationScores", "label": "Evaluation Scores (Technical & Financial)", "fieldType": "TABLE", "isMandatory": true, "displayOrder": 30, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "tableMinRows": 1, "tableMaxRows": 50, "tableStriped": true, "tableBordered": true,
        "tableColumns": "[{\"name\":\"bidderName\",\"label\":\"Bidder\",\"type\":\"TEXT\",\"width\":220,\"required\":true},{\"name\":\"technicalScore\",\"label\":\"Technical\",\"type\":\"NUMBER\",\"width\":120,\"required\":true},{\"name\":\"financialScore\",\"label\":\"Financial\",\"type\":\"NUMBER\",\"width\":120,\"required\":true},{\"name\":\"combinedScore\",\"label\":\"Combined\",\"type\":\"NUMBER\",\"width\":120},{\"name\":\"rank\",\"label\":\"Rank\",\"type\":\"NUMBER\",\"width\":80}]" },
      { "name": "awardDecision", "label": "Award Decision", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "options": [
          { "value": "AWARDED", "label": "Awarded", "displayOrder": 0 },
          { "value": "CANCELLED", "label": "Cancelled", "displayOrder": 1 },
          { "value": "RE_TENDER", "label": "Re-Tender", "displayOrder": 2 }
        ], "validation": "Required()" },
      { "name": "winningBidder", "label": "Winning Bidder", "fieldType": "TEXT", "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "visibilityExpression": "@{awardDecision} == 'AWARDED'",
        "validation": "ValidWhen(@{awardDecision} != 'AWARDED' OR IS_NOT_EMPTY(@{winningBidder}), \"Winning bidder required\")" },
      { "name": "awardAmount", "label": "Award Amount", "fieldType": "CURRENCY", "inSummary": true, "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "visibilityExpression": "@{awardDecision} == 'AWARDED'",
        "validation": "ValidWhen(@{awardDecision} != 'AWARDED' OR @{awardAmount} > 0, \"Award amount required\")" },
      { "name": "justification", "label": "Award Justification", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 43, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "Required() AND MinLength(30)" },
      { "name": "tenderDocument", "label": "Tender Document / ToR", "fieldType": "FILE", "isMandatory": true, "displayOrder": 50, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "pdf,doc,docx", "maxFileSize": 20971520, "validation": "Required()" },
      { "name": "evaluationReport", "label": "Evaluation Committee Report", "fieldType": "FILE", "isMandatory": true, "displayOrder": 51, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "pdf,doc,docx", "maxFileSize": 20971520, "validation": "Required()" },
      { "name": "openingMinutes", "label": "Bid Opening Minutes", "fieldType": "FILE", "displayOrder": 52, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "pdf,doc,docx", "maxFileSize": 10485760 }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Procurement Officer", "approverType": "ROLE", "roleName": "PROCUREMENT_OFFICER", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Procurement Committee", "approverType": "ROLE", "roleName": "PROCUREMENT_COMMITTEE", "amountLimit": 500000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Accounting Officer", "approverType": "ROLE", "roleName": "ACCOUNTING_OFFICER", "amountLimit": 5000000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 4, "name": "Procurement Regulatory Authority", "approverType": "ROLE", "roleName": "PROCUREMENT_AUTHORITY", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
