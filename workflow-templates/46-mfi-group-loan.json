{
  "_comment": "MFI Group Loan — solidarity-group / village-banking loan cycle application.",
  "name": "MFI Group Loan Application",
  "code": "MGL",
  "description": "Solidarity-group/village-banking loan application; members guarantee each other.",
  "icon": "diversity_3",
  "displayOrder": 46,
  "requiresApproval": true,
  "commentsMandatory": false,
  "commentsMandatoryOnReject": true,
  "commentsMandatoryOnEscalate": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "MICROFINANCE",
  "workflowTypeCode": "FINANCE",
  "titleTemplate": "@{loanRef} - @{groupName} (@{totalLoanAmount})",

  "reminderEnabled": true,
  "reminderFrequencyHours": 24,
  "reminderMaxCount": 3,
  "reminderStartAfterHours": 24,
  "escalationEnabled": true,
  "escalationAfterHours": 72,
  "escalationAction": "NOTIFY_ADMIN",
  "reminderEmailSubject": "Reminder: Group Loan @{referenceNumber} pending",
  "reminderEmailBody": "<p>Group loan <strong>@{referenceNumber}</strong> awaiting your decision.</p>",

  "forms": [{
    "name": "Main Form",
    "displayOrder": 0,

    "screens": [
      { "id": "temp_screen_1", "title": "Reference", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Group", "displayOrder": 1, "icon": "groups" },
      { "id": "temp_screen_3", "title": "Members & Amounts", "displayOrder": 2, "icon": "list" },
      { "id": "temp_screen_4", "title": "Loan Terms", "displayOrder": 3, "icon": "payments" },
      { "id": "temp_screen_5", "title": "Documents", "displayOrder": 4, "icon": "attach_file" },
      { "id": "temp_screen_6", "title": "Review & Submit", "displayOrder": 5, "icon": "fact_check", "isSummaryScreen": true }
    ],

    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Group Info", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_3", "title": "Group Performance", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Member Allocations", "displayOrder": 3, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_5", "title": "Terms", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_4" },
      { "id": "temp_grp_6", "title": "Documents", "displayOrder": 5, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_5" }
    ],

    "fields": [
      { "name": "loanRef", "label": "Loan Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"MGL-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "applicationDate", "label": "Application Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "officer", "label": "Field Officer", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "branch", "label": "Branch", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "validation": "Required()" },

      { "name": "groupId", "label": "Group Number", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "groupName", "label": "Group Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "groupChairperson", "label": "Chairperson", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "chairpersonPhone", "label": "Chairperson Phone", "fieldType": "PHONE", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required() AND Phone()" },
      { "name": "meetingLocation", "label": "Weekly Meeting Location", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 14, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },

      { "name": "cycleNumber", "label": "Loan Cycle Number", "fieldType": "NUMBER", "isMandatory": true, "defaultValue": "1", "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Required() AND Min(1)" },
      { "name": "previousRepaymentRate", "label": "Previous Cycle Repayment %", "fieldType": "NUMBER", "defaultValue": "100", "inSummary": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Min(0) AND Max(100)" },
      { "name": "groupSavingsBalance", "label": "Group Savings Balance", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Required() AND Min(0)" },
      { "name": "activeMembersCount", "label": "Active Members", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Required() AND Min(3)" },

      { "name": "memberLoans", "label": "Member Loan Allocations", "fieldType": "TABLE", "isMandatory": true, "displayOrder": 30, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "tableMinRows": 3, "tableMaxRows": 50, "tableStriped": true, "tableBordered": true,
        "tableColumns": "[{\"name\":\"memberNo\",\"label\":\"Member #\",\"type\":\"TEXT\",\"width\":120,\"required\":true},{\"name\":\"memberName\",\"label\":\"Name\",\"type\":\"TEXT\",\"width\":220,\"required\":true},{\"name\":\"activity\",\"label\":\"Activity\",\"type\":\"TEXT\",\"width\":180},{\"name\":\"loanAmount\",\"label\":\"Loan Amount\",\"type\":\"NUMBER\",\"width\":140,\"required\":true},{\"name\":\"purpose\",\"label\":\"Purpose\",\"type\":\"TEXT\",\"width\":240,\"required\":true}]",
        "validation": "MinRows(3, \"Group loans require at least 3 members\")" },
      { "name": "totalLoanAmount", "label": "Total Loan Amount", "fieldType": "CURRENCY", "isReadonly": true, "isLimited": true, "inSummary": true, "displayOrder": 31, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "defaultValue": "SUM_COLUMN(\"memberLoans\", \"loanAmount\")" },

      { "name": "interestRate", "label": "Interest Rate (% p.a.)", "fieldType": "NUMBER", "isMandatory": true, "inSummary": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "Required() AND Min(0) AND Max(200)" },
      { "name": "termWeeks", "label": "Term (weeks)", "fieldType": "NUMBER", "isMandatory": true, "defaultValue": "24", "inSummary": true, "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "Required() AND Min(4) AND Max(104)" },
      { "name": "repaymentFrequency", "label": "Repayment Frequency", "fieldType": "SELECT", "isMandatory": true, "defaultValue": "WEEKLY", "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "options": [
          { "value": "WEEKLY", "label": "Weekly", "displayOrder": 0 },
          { "value": "FORTNIGHTLY", "label": "Fortnightly", "displayOrder": 1 },
          { "value": "MONTHLY", "label": "Monthly", "displayOrder": 2 }
        ],
        "validation": "Required()" },
      { "name": "disbursementDate", "label": "Requested Disbursement", "fieldType": "DATE", "isMandatory": true, "displayOrder": 43, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "Required() AND DateAfter(\"today\", \"Date must be future\")" },
      { "name": "securityDescription", "label": "Group Guarantee / Security", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 44, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "Required() AND MinLength(20)" },

      { "name": "groupMinutes", "label": "Group Meeting Minutes", "fieldType": "FILE", "isMandatory": true, "displayOrder": 50, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 10485760,
        "validation": "Required()" },
      { "name": "memberSignatures", "label": "Member Signatures Sheet", "fieldType": "FILE", "isMandatory": true, "displayOrder": 51, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 10485760,
        "validation": "Required()" },
      { "name": "appraisalReport", "label": "Officer Appraisal Report", "fieldType": "FILE", "displayOrder": 52, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "pdf,doc,docx", "maxFileSize": 10485760 }
    ]
  }],

  "approvers": [
    { "level": 1, "name": "Field Officer", "approverType": "ROLE", "roleName": "FIELD_OFFICER", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Branch Credit Committee", "approverType": "ROLE", "roleName": "BRANCH_CREDIT", "amountLimit": 10000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Head of Credit", "approverType": "ROLE", "roleName": "HEAD_OF_CREDIT", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
