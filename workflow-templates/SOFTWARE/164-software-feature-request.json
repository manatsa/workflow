{
  "_comment": "Feature Request Triage — review and prioritise a new feature / enhancement request.",
  "name": "Feature Request Triage",
  "code": "SFR",
  "description": "Review, size and prioritise a new product feature / enhancement request.",
  "icon": "lightbulb",
  "displayOrder": 164,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "NON_FINANCIAL",
  "industryCode": "SOFTWARE",
  "workflowTypeCode": "REQUEST",
  "titleTemplate": "@{requestRef} - @{title} (@{priority})",
  "reminderEnabled": true, "reminderFrequencyHours": 24, "reminderMaxCount": 3, "reminderStartAfterHours": 24,
  "escalationEnabled": true, "escalationAfterHours": 96, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Request", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Triage", "displayOrder": 1, "icon": "tune" },
      { "id": "temp_screen_3", "title": "Review", "displayOrder": 2, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Request Detail", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Triage & Sizing", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Decision", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" }
    ],
    "fields": [
      { "name": "requestRef", "label": "Request Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"SFR-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "raisedDate", "label": "Raised Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "requester", "label": "Requester", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "requesterRole", "label": "Requester Role", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [ { "value": "INTERNAL", "label": "Internal Stakeholder", "displayOrder": 0 }, { "value": "CUSTOMER", "label": "Customer", "displayOrder": 1 }, { "value": "PARTNER", "label": "Partner", "displayOrder": 2 }, { "value": "SUPPORT", "label": "Support / CS", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "title", "label": "Feature Title", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 10, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND MinLength(5)" },
      { "name": "problem", "label": "Problem Statement", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 11, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND MinLength(30)" },
      { "name": "proposedSolution", "label": "Proposed Solution", "fieldType": "TEXTAREA", "displayOrder": 12, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2" },
      { "name": "userImpact", "label": "Estimated Users Impacted", "fieldType": "NUMBER", "isMandatory": true, "isLimited": true, "inSummary": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND Min(0)" },
      { "name": "revenueImpact", "label": "Revenue Impact (annual)", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 14, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Min(0)" },
      { "name": "priority", "label": "Priority", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "P0", "label": "P0 - Critical", "displayOrder": 0 }, { "value": "P1", "label": "P1 - High", "displayOrder": 1 }, { "value": "P2", "label": "P2 - Medium", "displayOrder": 2 }, { "value": "P3", "label": "P3 - Low", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "tShirtSize", "label": "T-Shirt Size", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "XS", "label": "XS (<1 day)", "displayOrder": 0 }, { "value": "S", "label": "S (1-3 days)", "displayOrder": 1 }, { "value": "M", "label": "M (1-2 wk)", "displayOrder": 2 }, { "value": "L", "label": "L (3-6 wk)", "displayOrder": 3 }, { "value": "XL", "label": "XL (>6 wk)", "displayOrder": 4 } ], "validation": "Required()" },
      { "name": "targetRelease", "label": "Target Release / Quarter", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "dependencies", "label": "Dependencies / Risks", "fieldType": "TEXTAREA", "displayOrder": 23, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3" },
      { "name": "decision", "label": "Decision", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "options": [ { "value": "ACCEPTED", "label": "Accepted - Add to Backlog", "displayOrder": 0 }, { "value": "DEFERRED", "label": "Deferred", "displayOrder": 1 }, { "value": "REJECTED", "label": "Rejected", "displayOrder": 2 }, { "value": "DUPLICATE", "label": "Duplicate", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "rationale", "label": "Decision Rationale", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 31, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND MinLength(20)" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Product Manager", "approverType": "ROLE", "roleName": "PRODUCT_MANAGER", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 2, "name": "Engineering Manager", "approverType": "ROLE", "roleName": "ENG_MANAGER", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Head of Product", "approverType": "ROLE", "roleName": "HEAD_PRODUCT", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
