{
  "_comment": "Permit / Licence Application — citizen or business application for a government permit, licence or certificate.",
  "name": "Permit / Licence Application",
  "code": "PLA2",
  "description": "Citizen or business application for a government permit, licence or certificate.",
  "icon": "badge",
  "displayOrder": 62,
  "requiresApproval": true,
  "commentsMandatoryOnReject": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "NON_FINANCIAL",
  "industryCode": "GOVERNMENT",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{applicationRef} - @{applicantName} (@{permitType})",
  "reminderEnabled": true,
  "reminderFrequencyHours": 48,
  "reminderMaxCount": 3,
  "reminderStartAfterHours": 48,
  "escalationEnabled": true,
  "escalationAfterHours": 168,
  "escalationAction": "NOTIFY_ADMIN",

  "forms": [{
    "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Applicant", "displayOrder": 0, "icon": "person" },
      { "id": "temp_screen_2", "title": "Permit", "displayOrder": 1, "icon": "badge" },
      { "id": "temp_screen_3", "title": "Inspection / Review", "displayOrder": 2, "icon": "search" },
      { "id": "temp_screen_4", "title": "Fees", "displayOrder": 3, "icon": "payments" },
      { "id": "temp_screen_5", "title": "Documents", "displayOrder": 4, "icon": "attach_file" },
      { "id": "temp_screen_6", "title": "Review & Submit", "displayOrder": 5, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Applicant Info", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Permit Info", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_3", "title": "Officer Review", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_4", "title": "Fees & Receipts", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_4" },
      { "id": "temp_grp_5", "title": "Documents", "displayOrder": 4, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_5" }
    ],
    "fields": [
      { "name": "applicationRef", "label": "Application Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"PLA-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "submissionDate", "label": "Submission Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "applicantType", "label": "Applicant Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [
          { "value": "INDIVIDUAL", "label": "Individual", "displayOrder": 0 },
          { "value": "BUSINESS", "label": "Business / Company", "displayOrder": 1 },
          { "value": "NGO", "label": "NGO / Non-Profit", "displayOrder": 2 }
        ], "validation": "Required()" },
      { "name": "applicantName", "label": "Applicant Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "validation": "Required() AND MinLength(2)" },
      { "name": "idOrReg", "label": "ID / Reg Number", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 4, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "phone", "label": "Phone", "fieldType": "PHONE", "isMandatory": true, "displayOrder": 5, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "validation": "Required() AND Phone()" },
      { "name": "address", "label": "Address", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 6, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "validation": "Required() AND MinLength(10)" },
      { "name": "permitType", "label": "Permit / Licence Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "options": [
          { "value": "BUSINESS", "label": "Business Licence", "displayOrder": 0 },
          { "value": "TRADE", "label": "Trade Permit", "displayOrder": 1 },
          { "value": "HEALTH", "label": "Health / Food Licence", "displayOrder": 2 },
          { "value": "BUILDING", "label": "Building Permit", "displayOrder": 3 },
          { "value": "IMPORT_EXPORT", "label": "Import / Export Licence", "displayOrder": 4 },
          { "value": "VEHICLE", "label": "Vehicle / Driving Licence", "displayOrder": 5 },
          { "value": "EVENT", "label": "Event / Gathering Permit", "displayOrder": 6 },
          { "value": "PROFESSIONAL", "label": "Professional Practice Licence", "displayOrder": 7 },
          { "value": "OTHER", "label": "Other", "displayOrder": 8 }
        ], "validation": "Required()" },
      { "name": "requestedValidity", "label": "Requested Validity (months)", "fieldType": "NUMBER", "isMandatory": true, "defaultValue": "12", "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required() AND Min(1) AND Max(60)" },
      { "name": "purpose", "label": "Purpose / Activity", "fieldType": "TEXTAREA", "isMandatory": true, "inSummary": true, "displayOrder": 12, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required() AND MinLength(20)" },
      { "name": "locationOfActivity", "label": "Location of Activity", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 13, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "inspectionRequired", "label": "Site Inspection Required?", "fieldType": "YES_NO", "defaultValue": "false", "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3" },
      { "name": "inspectionDate", "label": "Inspection Date", "fieldType": "DATE", "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "visibilityExpression": "@{inspectionRequired} == true" },
      { "name": "inspectionOutcome", "label": "Inspection Outcome", "fieldType": "SELECT", "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "visibilityExpression": "@{inspectionRequired} == true",
        "options": [
          { "value": "PASS", "label": "Pass", "displayOrder": 0 },
          { "value": "CONDITIONAL", "label": "Conditional", "displayOrder": 1 },
          { "value": "FAIL", "label": "Fail", "displayOrder": 2 }
        ] },
      { "name": "officerNotes", "label": "Officer Notes", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 23, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "validation": "Required() AND MinLength(10)" },
      { "name": "applicationFee", "label": "Application Fee", "fieldType": "CURRENCY", "isMandatory": true, "defaultValue": "0", "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_4",
        "validation": "Required() AND Min(0)" },
      { "name": "licenceFee", "label": "Licence Fee", "fieldType": "CURRENCY", "isMandatory": true, "defaultValue": "0", "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_4",
        "validation": "Required() AND Min(0)" },
      { "name": "totalFee", "label": "Total Fee", "fieldType": "CURRENCY", "isReadonly": true, "isLimited": true, "inSummary": true, "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_4",
        "defaultValue": "SUM(@{applicationFee}, @{licenceFee})" },
      { "name": "paid", "label": "Fees Paid?", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 33, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_4",
        "validation": "ValidWhen(@{paid} == true, \"Fees must be paid before issuance\")" },
      { "name": "receiptNumber", "label": "Receipt Number", "fieldType": "TEXT", "displayOrder": 34, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_4",
        "visibilityExpression": "@{paid} == true",
        "validation": "ValidWhen(@{paid} == false OR IS_NOT_EMPTY(@{receiptNumber}), \"Receipt required\")" },
      { "name": "idCopy", "label": "ID / Registration Copy", "fieldType": "FILE", "isMandatory": true, "displayOrder": 40, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_5",
        "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 10485760, "validation": "Required()" },
      { "name": "supportingDocs", "label": "Supporting Documents", "fieldType": "FILE", "multiple": true, "displayOrder": 41, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_5",
        "allowedFileTypes": "pdf,jpg,jpeg,png,doc,docx", "maxFileSize": 10485760, "maxFiles": 15 }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Permits Officer", "approverType": "ROLE", "roleName": "PERMITS_OFFICER", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Licensing Manager", "approverType": "ROLE", "roleName": "LICENSING_MANAGER", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 3, "name": "Director / Registrar", "approverType": "ROLE", "roleName": "REGISTRAR", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
