{
  "_comment": "Passenger Ticket Refund — refund / compensation for a passenger rail ticket.",
  "name": "Rail Ticket Refund",
  "code": "RTR",
  "description": "Process a passenger rail ticket refund or service-disruption compensation.",
  "icon": "confirmation_number",
  "displayOrder": 119,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "RAIL",
  "workflowTypeCode": "FINANCE",
  "titleTemplate": "@{refundRef} - @{passengerName} (@{refundAmount})",
  "reminderEnabled": true, "reminderFrequencyHours": 12, "reminderMaxCount": 3, "reminderStartAfterHours": 12,
  "escalationEnabled": true, "escalationAfterHours": 48, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Ticket", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Refund", "displayOrder": 1, "icon": "payments" },
      { "id": "temp_screen_3", "title": "Review", "displayOrder": 2, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Passenger & Ticket", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Journey", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_4", "title": "Reason & Calculation", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Payment", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" }
    ],
    "fields": [
      { "name": "refundRef", "label": "Refund Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"RTR-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "requestDate", "label": "Request Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "ticketNumber", "label": "Ticket Number", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "passengerName", "label": "Passenger Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "contactEmail", "label": "Email", "fieldType": "EMAIL", "isMandatory": true, "displayOrder": 4, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND ValidWhen(IS_EMAIL(@{contactEmail}), \"Enter valid email\")" },
      { "name": "purchaseChannel", "label": "Purchase Channel", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 5, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "STATION", "label": "Station Counter", "displayOrder": 0 }, { "value": "WEB", "label": "Website", "displayOrder": 1 }, { "value": "APP", "label": "Mobile App", "displayOrder": 2 }, { "value": "AGENT", "label": "Travel Agent", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "travelDate", "label": "Travel Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "origin", "label": "From", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "destination", "label": "To", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "class", "label": "Class", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "FIRST", "label": "First", "displayOrder": 0 }, { "value": "BUSINESS", "label": "Business", "displayOrder": 1 }, { "value": "STANDARD", "label": "Standard", "displayOrder": 2 }, { "value": "ECONOMY", "label": "Economy", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "reasonType", "label": "Refund Reason", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "options": [ { "value": "SERVICE_DISRUPTION", "label": "Service Disruption / Cancellation", "displayOrder": 0 }, { "value": "DELAY", "label": "Delay Compensation", "displayOrder": 1 }, { "value": "CUSTOMER_CANCEL", "label": "Customer Cancellation", "displayOrder": 2 }, { "value": "DUPLICATE", "label": "Duplicate Charge", "displayOrder": 3 }, { "value": "GOODWILL", "label": "Goodwill Gesture", "displayOrder": 4 } ], "validation": "Required()" },
      { "name": "delayMinutes", "label": "Delay (minutes)", "fieldType": "NUMBER", "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "visibilityExpression": "@{reasonType} == 'DELAY'", "validation": "Min(0)" },
      { "name": "fareAmount", "label": "Original Fare Paid", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Min(0)" },
      { "name": "cancellationFee", "label": "Cancellation / Admin Fee", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Min(0)" },
      { "name": "refundAmount", "label": "Refund Amount", "fieldType": "CURRENCY", "isMandatory": true, "isLimited": true, "inSummary": true, "displayOrder": 24, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Min(0)" },
      { "name": "refundMethod", "label": "Refund Method", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5",
        "options": [ { "value": "ORIGINAL", "label": "Original Payment Method", "displayOrder": 0 }, { "value": "VOUCHER", "label": "Travel Voucher", "displayOrder": 1 }, { "value": "BANK", "label": "Bank Transfer", "displayOrder": 2 }, { "value": "CASH", "label": "Cash", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "accountDetails", "label": "Account Details", "fieldType": "TEXT", "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "visibilityExpression": "@{refundMethod} == 'BANK'" },
      { "name": "notes", "label": "Notes", "fieldType": "TEXTAREA", "displayOrder": 32, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Station / Ticket Office Supervisor", "approverType": "ROLE", "roleName": "STATION_SUPERVISOR", "amountLimit": 200, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Revenue Manager", "approverType": "ROLE", "roleName": "REVENUE_MANAGER", "amountLimit": 5000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Head of Commercial", "approverType": "ROLE", "roleName": "HEAD_COMMERCIAL", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
