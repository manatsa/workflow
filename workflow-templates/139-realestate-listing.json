{
  "_comment": "Property Listing — list a new property for sale or rent on the agency's portfolio.",
  "name": "Property Listing",
  "code": "REL",
  "description": "List a new property for sale or rent, with valuation, compliance and marketing plan.",
  "icon": "home_work",
  "displayOrder": 139,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "REAL_ESTATE",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{listingRef} - @{address} (@{listingType})",
  "reminderEnabled": true, "reminderFrequencyHours": 24, "reminderMaxCount": 3, "reminderStartAfterHours": 24,
  "escalationEnabled": true, "escalationAfterHours": 72, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Property", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Pricing & Owner", "displayOrder": 1, "icon": "payments" },
      { "id": "temp_screen_3", "title": "Review", "displayOrder": 2, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Property Details", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Features", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_4", "title": "Pricing", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Owner / Mandate", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" }
    ],
    "fields": [
      { "name": "listingRef", "label": "Listing Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"REL-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "listingDate", "label": "Listing Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "agent", "label": "Listing Agent", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "listingType", "label": "Listing Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [ { "value": "SALE", "label": "For Sale", "displayOrder": 0 }, { "value": "RENT", "label": "To Rent", "displayOrder": 1 }, { "value": "AUCTION", "label": "Auction", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "propertyType", "label": "Property Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "HOUSE", "label": "House", "displayOrder": 0 }, { "value": "APARTMENT", "label": "Apartment / Flat", "displayOrder": 1 }, { "value": "TOWNHOUSE", "label": "Townhouse / Cluster", "displayOrder": 2 }, { "value": "COMMERCIAL", "label": "Commercial", "displayOrder": 3 }, { "value": "INDUSTRIAL", "label": "Industrial / Warehouse", "displayOrder": 4 }, { "value": "LAND", "label": "Vacant Land", "displayOrder": 5 }, { "value": "FARM", "label": "Farm", "displayOrder": 6 } ], "validation": "Required()" },
      { "name": "address", "label": "Full Address", "fieldType": "TEXTAREA", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 11, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND MinLength(10)" },
      { "name": "suburb", "label": "Suburb / Area", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "city", "label": "City", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "titleDeed", "label": "Title Deed Number", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 14, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "bedrooms", "label": "Bedrooms", "fieldType": "NUMBER", "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Min(0)" },
      { "name": "bathrooms", "label": "Bathrooms", "fieldType": "NUMBER", "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Min(0)" },
      { "name": "erfSqm", "label": "Land Size (m²)", "fieldType": "NUMBER", "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Min(0)" },
      { "name": "floorSqm", "label": "Floor Area (m²)", "fieldType": "NUMBER", "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Min(0)" },
      { "name": "description", "label": "Description", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 24, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required() AND MinLength(50)" },
      { "name": "askingPrice", "label": "Asking Price / Rent", "fieldType": "CURRENCY", "isMandatory": true, "isLimited": true, "inSummary": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Min(0)" },
      { "name": "valuation", "label": "Professional Valuation", "fieldType": "CURRENCY", "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Min(0)" },
      { "name": "commissionPercent", "label": "Commission %", "fieldType": "NUMBER", "isMandatory": true, "defaultValue": "5", "inSummary": true, "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Min(0) AND Max(20)" },
      { "name": "ratesAmount", "label": "Monthly Rates / Levies", "fieldType": "CURRENCY", "displayOrder": 33, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Min(0)" },
      { "name": "ownerName", "label": "Owner Name", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "Required()" },
      { "name": "ownerPhone", "label": "Owner Phone", "fieldType": "PHONE", "isMandatory": true, "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "Required() AND Phone()" },
      { "name": "mandateType", "label": "Mandate Type", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5",
        "options": [ { "value": "SOLE", "label": "Sole Mandate", "displayOrder": 0 }, { "value": "OPEN", "label": "Open Mandate", "displayOrder": 1 }, { "value": "EXCLUSIVE", "label": "Exclusive", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "mandateExpiry", "label": "Mandate Expiry", "fieldType": "DATE", "isMandatory": true, "displayOrder": 43, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "Required()" },
      { "name": "faciVerification", "label": "FICA / AML Verification Complete", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 44, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{faciVerification} == true, \"FICA/AML required\")" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Branch Manager", "approverType": "ROLE", "roleName": "BRANCH_MANAGER", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Compliance Officer", "approverType": "ROLE", "roleName": "COMPLIANCE_OFFICER", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
