{
  "_comment": "Cleaning Service Contract Approval — approve new or renewed cleaning service contracts.",
  "name": "Cleaning Service Contract Approval",
  "code": "CSC",
  "description": "Approve cleaning service contracts including scope of work, site details, staffing requirements, pricing schedules, and contract terms.",
  "icon": "cleaning_services",
  "displayOrder": 209,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "CLEANING",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{contractRef} - @{clientName} - @{siteName}",
  "reminderEnabled": true, "reminderFrequencyHours": 24, "reminderMaxCount": 3, "reminderStartAfterHours": 24,
  "escalationEnabled": true, "escalationAfterHours": 96, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Contract Details", "displayOrder": 0, "icon": "description" },
      { "id": "temp_screen_2", "title": "Scope & Staffing", "displayOrder": 1, "icon": "groups" },
      { "id": "temp_screen_3", "title": "Pricing & Terms", "displayOrder": 2, "icon": "payments" },
      { "id": "temp_screen_4", "title": "Review", "displayOrder": 3, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Client & Site", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Scope of Work", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Staffing Requirements", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Pricing", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_6", "title": "Contract Terms", "displayOrder": 5, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" }
    ],
    "fields": [
      { "name": "contractRef", "label": "Contract Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"CSC-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "submissionDate", "label": "Submission Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "clientName", "label": "Client Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "siteName", "label": "Site Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "siteAddress", "label": "Site Address", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 4, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "contractType", "label": "Contract Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 5, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "NEW", "label": "New Contract", "displayOrder": 0 }, { "value": "RENEWAL", "label": "Renewal", "displayOrder": 1 }, { "value": "AMENDMENT", "label": "Amendment", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "siteAreaSqm", "label": "Site Area (sq m)", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 6, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND Min(1)" },
      { "name": "serviceType", "label": "Service Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "OFFICE", "label": "Office Cleaning", "displayOrder": 0 }, { "value": "INDUSTRIAL", "label": "Industrial Cleaning", "displayOrder": 1 }, { "value": "MEDICAL", "label": "Medical / Healthcare", "displayOrder": 2 }, { "value": "RETAIL", "label": "Retail", "displayOrder": 3 }, { "value": "RESIDENTIAL", "label": "Residential Complex", "displayOrder": 4 }, { "value": "SPECIALIZED", "label": "Specialised Deep Clean", "displayOrder": 5 } ], "validation": "Required()" },
      { "name": "frequency", "label": "Service Frequency", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "DAILY", "label": "Daily", "displayOrder": 0 }, { "value": "TWICE_WEEKLY", "label": "Twice Weekly", "displayOrder": 1 }, { "value": "WEEKLY", "label": "Weekly", "displayOrder": 2 }, { "value": "FORTNIGHTLY", "label": "Fortnightly", "displayOrder": 3 }, { "value": "MONTHLY", "label": "Monthly", "displayOrder": 4 } ], "validation": "Required()" },
      { "name": "scopeDescription", "label": "Detailed Scope of Work", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 12, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required() AND MinLength(20)" },
      { "name": "numberOfStaff", "label": "Number of Staff Required", "fieldType": "NUMBER", "isMandatory": true, "inSummary": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Min(1)" },
      { "name": "supervisorRequired", "label": "On-Site Supervisor Required", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 14, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "shiftHours", "label": "Shift Hours", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 15, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required()" },
      { "name": "equipmentProvided", "label": "Equipment Provided by Us", "fieldType": "YES_NO", "defaultValue": "true", "inSummary": true, "displayOrder": 16, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "monthlyRate", "label": "Monthly Rate", "fieldType": "CURRENCY", "isMandatory": true, "isLimited": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "Required() AND Min(1)" },
      { "name": "contractDurationMonths", "label": "Contract Duration (months)", "fieldType": "NUMBER", "isMandatory": true, "inSummary": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "Required() AND Min(1)" },
      { "name": "totalContractValue", "label": "Total Contract Value", "fieldType": "CURRENCY", "isReadonly": true, "isLimited": true, "inSummary": true, "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5",
        "defaultValue": "MULTIPLY(@{monthlyRate}, @{contractDurationMonths})" },
      { "name": "startDate", "label": "Contract Start Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "validation": "Required() AND DateAfter(\"today\", \"Start date must be in the future\")" },
      { "name": "paymentTerms", "label": "Payment Terms", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 24, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6",
        "options": [ { "value": "NET15", "label": "Net 15 Days", "displayOrder": 0 }, { "value": "NET30", "label": "Net 30 Days", "displayOrder": 1 }, { "value": "NET60", "label": "Net 60 Days", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "noticePeriodDays", "label": "Notice Period (days)", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 25, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "validation": "Required() AND Min(7)" },
      { "name": "contractDocument", "label": "Contract Document", "fieldType": "FILE", "isMandatory": true, "displayOrder": 26, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "allowedFileTypes": "pdf,doc,docx", "maxFileSize": 10485760, "validation": "Required()" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Operations Manager", "approverType": "ROLE", "roleName": "OPS_MANAGER", "amountLimit": 50000, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Finance Manager", "approverType": "ROLE", "roleName": "FINANCE_MANAGER", "amountLimit": 200000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Managing Director", "approverType": "ROLE", "roleName": "MANAGING_DIRECTOR", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
