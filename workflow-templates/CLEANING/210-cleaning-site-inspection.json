{
  "_comment": "Site Cleanliness Inspection — inspect and rate site cleanliness against service standards.",
  "name": "Site Cleanliness Inspection",
  "code": "SCI",
  "description": "Conduct scheduled or ad-hoc site cleanliness inspections, rate areas against SLA standards, and flag non-conformances for remediation.",
  "icon": "checklist",
  "displayOrder": 210,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "NON_FINANCIAL",
  "industryCode": "CLEANING",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{inspectionRef} - @{siteName}",
  "reminderEnabled": true, "reminderFrequencyHours": 12, "reminderMaxCount": 3, "reminderStartAfterHours": 12,
  "escalationEnabled": true, "escalationAfterHours": 48, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Site Details", "displayOrder": 0, "icon": "location_on" },
      { "id": "temp_screen_2", "title": "Inspection Ratings", "displayOrder": 1, "icon": "star_rate" },
      { "id": "temp_screen_3", "title": "Findings & Evidence", "displayOrder": 2, "icon": "camera_alt" },
      { "id": "temp_screen_4", "title": "Review", "displayOrder": 3, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Site Information", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Area Ratings", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Compliance Checks", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Issues & Corrective Actions", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_6", "title": "Evidence", "displayOrder": 5, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_3" }
    ],
    "fields": [
      { "name": "inspectionRef", "label": "Inspection Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"SCI-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "inspectionDate", "label": "Inspection Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "siteName", "label": "Site Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "clientName", "label": "Client Name", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "inspectionType", "label": "Inspection Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 4, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "SCHEDULED", "label": "Scheduled", "displayOrder": 0 }, { "value": "ADHOC", "label": "Ad-Hoc", "displayOrder": 1 }, { "value": "CLIENT_REQUEST", "label": "Client Requested", "displayOrder": 2 }, { "value": "COMPLAINT_FOLLOWUP", "label": "Complaint Follow-Up", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "inspectorName", "label": "Inspector Name", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 5, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "receptionLobby", "label": "Reception / Lobby", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "5", "label": "5 - Excellent", "displayOrder": 0 }, { "value": "4", "label": "4 - Good", "displayOrder": 1 }, { "value": "3", "label": "3 - Acceptable", "displayOrder": 2 }, { "value": "2", "label": "2 - Below Standard", "displayOrder": 3 }, { "value": "1", "label": "1 - Unacceptable", "displayOrder": 4 } ], "validation": "Required()" },
      { "name": "officeAreas", "label": "Office / Work Areas", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "5", "label": "5 - Excellent", "displayOrder": 0 }, { "value": "4", "label": "4 - Good", "displayOrder": 1 }, { "value": "3", "label": "3 - Acceptable", "displayOrder": 2 }, { "value": "2", "label": "2 - Below Standard", "displayOrder": 3 }, { "value": "1", "label": "1 - Unacceptable", "displayOrder": 4 } ], "validation": "Required()" },
      { "name": "washrooms", "label": "Washrooms / Restrooms", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "5", "label": "5 - Excellent", "displayOrder": 0 }, { "value": "4", "label": "4 - Good", "displayOrder": 1 }, { "value": "3", "label": "3 - Acceptable", "displayOrder": 2 }, { "value": "2", "label": "2 - Below Standard", "displayOrder": 3 }, { "value": "1", "label": "1 - Unacceptable", "displayOrder": 4 } ], "validation": "Required()" },
      { "name": "kitchenBreakroom", "label": "Kitchen / Breakroom", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "5", "label": "5 - Excellent", "displayOrder": 0 }, { "value": "4", "label": "4 - Good", "displayOrder": 1 }, { "value": "3", "label": "3 - Acceptable", "displayOrder": 2 }, { "value": "2", "label": "2 - Below Standard", "displayOrder": 3 }, { "value": "1", "label": "1 - Unacceptable", "displayOrder": 4 } ], "validation": "Required()" },
      { "name": "externalAreas", "label": "External / Parking Areas", "fieldType": "SELECT", "displayOrder": 14, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "5", "label": "5 - Excellent", "displayOrder": 0 }, { "value": "4", "label": "4 - Good", "displayOrder": 1 }, { "value": "3", "label": "3 - Acceptable", "displayOrder": 2 }, { "value": "2", "label": "2 - Below Standard", "displayOrder": 3 }, { "value": "1", "label": "1 - Unacceptable", "displayOrder": 4 }, { "value": "NA", "label": "N/A", "displayOrder": 5 } ] },
      { "name": "suppliesStocked", "label": "Supplies Adequately Stocked", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "true", "displayOrder": 15, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "staffInUniform", "label": "Staff in Proper Uniform", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "true", "displayOrder": 16, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "safetyCompliant", "label": "Safety / PPE Compliance", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "true", "inSummary": true, "displayOrder": 17, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "slaMetric", "label": "Overall SLA Score (%)", "fieldType": "NUMBER", "isMandatory": true, "inSummary": true, "displayOrder": 18, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Min(0)" },
      { "name": "issuesDescription", "label": "Issues Found", "fieldType": "TEXTAREA", "displayOrder": 20, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5" },
      { "name": "correctiveActions", "label": "Corrective Actions Required", "fieldType": "TEXTAREA", "displayOrder": 21, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5" },
      { "name": "overallVerdict", "label": "Overall Verdict", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5",
        "options": [ { "value": "SATISFACTORY", "label": "Satisfactory", "displayOrder": 0 }, { "value": "NEEDS_IMPROVEMENT", "label": "Needs Improvement", "displayOrder": 1 }, { "value": "UNSATISFACTORY", "label": "Unsatisfactory", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "sitePhotos", "label": "Site Photographs", "fieldType": "FILE", "displayOrder": 30, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "allowedFileTypes": "jpg,png,pdf", "maxFileSize": 20971520 }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Site Supervisor", "approverType": "ROLE", "roleName": "SITE_SUPERVISOR", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Operations Manager", "approverType": "ROLE", "roleName": "OPS_MANAGER", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true }
  ]
}
