{
  "_comment": "Programme Budget Approval — approve programme / project annual or amended budget.",
  "name": "Programme Budget Approval",
  "code": "NPB",
  "description": "Approve a programme / project annual budget or budget realignment.",
  "icon": "savings",
  "displayOrder": 70,
  "requiresApproval": true,
  "commentsMandatoryOnReject": true,
  "commentsMandatoryOnEscalate": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "NGO",
  "workflowTypeCode": "FINANCE",
  "titleTemplate": "@{budgetRef} - @{programmeName} (@{totalBudget})",
  "reminderEnabled": true,
  "reminderFrequencyHours": 24,
  "reminderMaxCount": 3,
  "reminderStartAfterHours": 24,
  "escalationEnabled": true,
  "escalationAfterHours": 96,
  "escalationAction": "NOTIFY_ADMIN",

  "forms": [{
    "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Reference", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Programme", "displayOrder": 1, "icon": "account_tree" },
      { "id": "temp_screen_3", "title": "Budget Lines", "displayOrder": 2, "icon": "list" },
      { "id": "temp_screen_4", "title": "Funding Sources", "displayOrder": 3, "icon": "attach_money" },
      { "id": "temp_screen_5", "title": "Documents", "displayOrder": 4, "icon": "attach_file" },
      { "id": "temp_screen_6", "title": "Review & Submit", "displayOrder": 5, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Programme Info", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_3", "title": "Lines by Category", "displayOrder": 2, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_4", "title": "Funding Sources", "displayOrder": 3, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_4" },
      { "id": "temp_grp_5", "title": "Documents", "displayOrder": 4, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_5" }
    ],
    "fields": [
      { "name": "budgetRef", "label": "Budget Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"NPB-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "submissionDate", "label": "Submission Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "preparedBy", "label": "Prepared By", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "budgetType", "label": "Budget Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [
          { "value": "ANNUAL", "label": "Annual Budget", "displayOrder": 0 },
          { "value": "AMENDMENT", "label": "Budget Amendment", "displayOrder": 1 },
          { "value": "REALIGNMENT", "label": "Line Realignment", "displayOrder": 2 },
          { "value": "SUPPLEMENTARY", "label": "Supplementary", "displayOrder": 3 }
        ], "validation": "Required()" },
      { "name": "programmeName", "label": "Programme / Project", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "programmeCode", "label": "Programme Code", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "fiscalYear", "label": "Fiscal Year", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "periodStart", "label": "Period Start", "fieldType": "DATE", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "periodEnd", "label": "Period End", "fieldType": "DATE", "isMandatory": true, "displayOrder": 14, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "currency", "label": "Currency", "fieldType": "SELECT", "isMandatory": true, "defaultValue": "USD", "displayOrder": 15, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "options": [
          { "value": "USD", "label": "USD", "displayOrder": 0 },
          { "value": "EUR", "label": "EUR", "displayOrder": 1 },
          { "value": "GBP", "label": "GBP", "displayOrder": 2 },
          { "value": "ZAR", "label": "ZAR", "displayOrder": 3 }
        ], "validation": "Required()" },
      { "name": "narrative", "label": "Budget Narrative / Rationale", "fieldType": "TEXTAREA", "isMandatory": true, "inSummary": true, "displayOrder": 16, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required() AND MinLength(50)" },
      { "name": "budgetLines", "label": "Budget Lines", "fieldType": "TABLE", "isMandatory": true, "displayOrder": 20, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "tableMinRows": 1, "tableMaxRows": 200, "tableStriped": true, "tableBordered": true,
        "tableColumns": "[{\"name\":\"category\",\"label\":\"Category\",\"type\":\"SELECT\",\"width\":160,\"required\":true,\"options\":[\"Personnel\",\"Travel\",\"Equipment\",\"Supplies\",\"Training\",\"Sub-grants\",\"Beneficiary Transfers\",\"Admin\",\"Overhead\"]},{\"name\":\"description\",\"label\":\"Description\",\"type\":\"TEXT\",\"width\":300,\"required\":true},{\"name\":\"quantity\",\"label\":\"Qty\",\"type\":\"NUMBER\",\"width\":90,\"defaultValue\":\"1\"},{\"name\":\"unitCost\",\"label\":\"Unit Cost\",\"type\":\"NUMBER\",\"width\":120,\"required\":true},{\"name\":\"totalCost\",\"label\":\"Total\",\"type\":\"NUMBER\",\"width\":140,\"computed\":\"MULTIPLY(@{quantity}, @{unitCost})\"}]",
        "validation": "MinRows(1, \"At least one budget line required\")" },
      { "name": "subtotal", "label": "Subtotal", "fieldType": "CURRENCY", "isReadonly": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "defaultValue": "SUM_COLUMN(\"budgetLines\", \"totalCost\")" },
      { "name": "overheadPercent", "label": "Overhead / NICRA %", "fieldType": "NUMBER", "defaultValue": "10", "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "validation": "Min(0) AND Max(30)" },
      { "name": "overheadAmount", "label": "Overhead Amount", "fieldType": "CURRENCY", "isReadonly": true, "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "defaultValue": "PERCENT_OF(@{subtotal}, @{overheadPercent})" },
      { "name": "totalBudget", "label": "Total Programme Budget", "fieldType": "CURRENCY", "isReadonly": true, "isLimited": true, "inSummary": true, "displayOrder": 24, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "defaultValue": "SUM(@{subtotal}, @{overheadAmount})" },
      { "name": "fundingSources", "label": "Funding Sources", "fieldType": "TABLE", "isMandatory": true, "displayOrder": 30, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_4",
        "tableMinRows": 1, "tableMaxRows": 20, "tableStriped": true, "tableBordered": true,
        "tableColumns": "[{\"name\":\"donor\",\"label\":\"Donor / Source\",\"type\":\"TEXT\",\"width\":240,\"required\":true},{\"name\":\"grantRef\",\"label\":\"Grant Ref\",\"type\":\"TEXT\",\"width\":180},{\"name\":\"amount\",\"label\":\"Amount\",\"type\":\"NUMBER\",\"width\":140,\"required\":true},{\"name\":\"status\",\"label\":\"Status\",\"type\":\"SELECT\",\"width\":140,\"options\":[\"CONFIRMED\",\"PIPELINE\",\"PENDING\"]}]",
        "validation": "MinRows(1, \"At least one funding source required\")" },
      { "name": "fundingTotal", "label": "Total Funding", "fieldType": "CURRENCY", "isReadonly": true, "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_4",
        "defaultValue": "SUM_COLUMN(\"fundingSources\", \"amount\")" },
      { "name": "fundingGap", "label": "Funding Gap", "fieldType": "CURRENCY", "isReadonly": true, "inSummary": true, "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_4",
        "defaultValue": "SUBTRACT(@{totalBudget}, @{fundingTotal})" },
      { "name": "fullyFunded", "label": "Fully Funded?", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 33, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_4" },
      { "name": "budgetSpreadsheet", "label": "Detailed Budget Spreadsheet", "fieldType": "FILE", "isMandatory": true, "displayOrder": 40, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_5",
        "allowedFileTypes": "xls,xlsx,pdf", "maxFileSize": 10485760, "validation": "Required()" },
      { "name": "workPlan", "label": "Work Plan / LogFrame", "fieldType": "FILE", "displayOrder": 41, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_5",
        "allowedFileTypes": "pdf,doc,docx,xls,xlsx", "maxFileSize": 10485760 },
      { "name": "donorAuthorisations", "label": "Donor Pre-Approval / Amendment Letters", "fieldType": "FILE", "multiple": true, "displayOrder": 42, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_5",
        "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 10485760, "maxFiles": 10 }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Programme Manager", "approverType": "ROLE", "roleName": "PROGRAMME_MANAGER", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Finance Director", "approverType": "ROLE", "roleName": "FINANCE_DIRECTOR", "amountLimit": 1000000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Executive Director / CEO", "approverType": "ROLE", "roleName": "EXECUTIVE_DIRECTOR", "amountLimit": 10000000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 4, "name": "Board / Finance Committee", "approverType": "ROLE", "roleName": "BOARD", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
