{
  "_comment": "Field Activity Report — post-activity report from field staff (distribution, training, outreach).",
  "name": "Field Activity Report",
  "code": "NFA",
  "description": "Post-activity report from field staff: distribution, training or outreach activity details and outcomes.",
  "icon": "assignment_turned_in",
  "displayOrder": 69,
  "requiresApproval": true,
  "commentsMandatoryOnReject": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "NON_FINANCIAL",
  "industryCode": "NGO",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{reportRef} - @{activityType} (@{activityDate})",
  "reminderEnabled": true,
  "reminderFrequencyHours": 24,
  "reminderMaxCount": 3,
  "reminderStartAfterHours": 24,
  "escalationEnabled": true,
  "escalationAfterHours": 72,
  "escalationAction": "NOTIFY_ADMIN",

  "forms": [{
    "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Activity", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Participation", "displayOrder": 1, "icon": "groups" },
      { "id": "temp_screen_3", "title": "Distribution / Outputs", "displayOrder": 2, "icon": "inventory" },
      { "id": "temp_screen_4", "title": "Incidents & Learning", "displayOrder": 3, "icon": "warning" },
      { "id": "temp_screen_5", "title": "Documents", "displayOrder": 4, "icon": "attach_file" },
      { "id": "temp_screen_6", "title": "Review & Submit", "displayOrder": 5, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Activity Info", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Location", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Attendance", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Items Distributed / Outputs", "displayOrder": 3, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_5", "title": "Incidents", "displayOrder": 4, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_4" },
      { "id": "temp_grp_6", "title": "Lessons & Follow-Up", "displayOrder": 5, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_4" },
      { "id": "temp_grp_7", "title": "Documents", "displayOrder": 6, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_5" }
    ],
    "fields": [
      { "name": "reportRef", "label": "Report Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"NFA-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "reportDate", "label": "Report Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "fieldOfficer", "label": "Field Officer", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "projectRef", "label": "Project Reference", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "validation": "Required()" },
      { "name": "activityType", "label": "Activity Type", "fieldType": "SELECT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 4, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [
          { "value": "DISTRIBUTION", "label": "Cash / Goods Distribution", "displayOrder": 0 },
          { "value": "TRAINING", "label": "Training / Workshop", "displayOrder": 1 },
          { "value": "OUTREACH", "label": "Community Outreach", "displayOrder": 2 },
          { "value": "HEALTH_CAMP", "label": "Health Camp", "displayOrder": 3 },
          { "value": "AWARENESS", "label": "Awareness Campaign", "displayOrder": 4 },
          { "value": "ASSESSMENT", "label": "Needs Assessment", "displayOrder": 5 }
        ], "validation": "Required()" },
      { "name": "activityDate", "label": "Activity Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 5, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "validation": "Required()" },
      { "name": "location", "label": "Location / Village", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "district", "label": "District / Region", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "country", "label": "Country", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "gpsCoords", "label": "GPS Coordinates", "fieldType": "TEXT", "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2" },
      { "name": "plannedParticipants", "label": "Planned Participants", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Required() AND Min(0)" },
      { "name": "actualParticipants", "label": "Actual Participants", "fieldType": "NUMBER", "isMandatory": true, "inSummary": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Required() AND Min(0)" },
      { "name": "female", "label": "Female", "fieldType": "NUMBER", "defaultValue": "0", "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Min(0)" },
      { "name": "male", "label": "Male", "fieldType": "NUMBER", "defaultValue": "0", "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Min(0)" },
      { "name": "children", "label": "Children (<18)", "fieldType": "NUMBER", "defaultValue": "0", "displayOrder": 24, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Min(0)" },
      { "name": "persWithDisability", "label": "Persons with Disability", "fieldType": "NUMBER", "defaultValue": "0", "displayOrder": 25, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Min(0)" },
      { "name": "itemsDistributed", "label": "Items / Vouchers / Services Distributed", "fieldType": "TABLE", "displayOrder": 30, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "tableMinRows": 0, "tableMaxRows": 50, "tableStriped": true, "tableBordered": true,
        "tableColumns": "[{\"name\":\"item\",\"label\":\"Item / Service\",\"type\":\"TEXT\",\"width\":240,\"required\":true},{\"name\":\"plannedQty\",\"label\":\"Planned\",\"type\":\"NUMBER\",\"width\":120,\"required\":true},{\"name\":\"actualQty\",\"label\":\"Actual\",\"type\":\"NUMBER\",\"width\":120,\"required\":true},{\"name\":\"unitValue\",\"label\":\"Unit Value\",\"type\":\"NUMBER\",\"width\":120},{\"name\":\"totalValue\",\"label\":\"Total Value\",\"type\":\"NUMBER\",\"width\":140,\"computed\":\"MULTIPLY(@{actualQty}, @{unitValue})\"}]" },
      { "name": "totalValueDistributed", "label": "Total Value Distributed", "fieldType": "CURRENCY", "isReadonly": true, "inSummary": true, "displayOrder": 31, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "defaultValue": "SUM_COLUMN(\"itemsDistributed\", \"totalValue\")" },
      { "name": "incidentOccurred", "label": "Any Incidents / Protection Concerns?", "fieldType": "YES_NO", "defaultValue": "false", "inSummary": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5" },
      { "name": "incidentDescription", "label": "Incident Description", "fieldType": "TEXTAREA", "displayOrder": 41, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "visibilityExpression": "@{incidentOccurred} == true",
        "validation": "ValidWhen(@{incidentOccurred} == false OR HAS_MIN_LENGTH(@{incidentDescription}, 30), \"Describe the incident\")" },
      { "name": "incidentAction", "label": "Action Taken", "fieldType": "TEXTAREA", "displayOrder": 42, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "visibilityExpression": "@{incidentOccurred} == true" },
      { "name": "keyLessons", "label": "Key Lessons / Observations", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 50, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_6",
        "validation": "Required() AND MinLength(20)" },
      { "name": "followUpRequired", "label": "Follow-Up Required?", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 51, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_6" },
      { "name": "followUpNotes", "label": "Follow-Up Notes", "fieldType": "TEXTAREA", "displayOrder": 52, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_6",
        "visibilityExpression": "@{followUpRequired} == true" },
      { "name": "attendanceSheet", "label": "Attendance Sheet", "fieldType": "FILE", "isMandatory": true, "displayOrder": 60, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_7",
        "allowedFileTypes": "pdf,jpg,jpeg,png,xls,xlsx", "maxFileSize": 10485760, "validation": "Required()" },
      { "name": "photos", "label": "Activity Photos", "fieldType": "FILE", "multiple": true, "displayOrder": 61, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_7",
        "allowedFileTypes": "jpg,jpeg,png", "maxFileSize": 20971520, "maxFiles": 30 },
      { "name": "distributionList", "label": "Distribution List / Receipt", "fieldType": "FILE", "displayOrder": 62, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_7",
        "allowedFileTypes": "pdf,xls,xlsx,jpg,jpeg,png", "maxFileSize": 10485760 }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Field Supervisor", "approverType": "ROLE", "roleName": "FIELD_SUPERVISOR", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Programme Manager", "approverType": "ROLE", "roleName": "PROGRAMME_MANAGER", "amountLimit": null, "canEscalate": false, "requireComment": false, "emailNotification": true }
  ]
}
