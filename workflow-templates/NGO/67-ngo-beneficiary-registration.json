{
  "_comment": "Beneficiary Registration — enrol a new beneficiary into a programme (cash, food, services).",
  "name": "Beneficiary Registration",
  "code": "NBR",
  "description": "Enrol a new beneficiary / household into a programme (cash transfers, food, services) with eligibility and vulnerability assessment.",
  "icon": "groups",
  "displayOrder": 67,
  "requiresApproval": true,
  "commentsMandatoryOnReject": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "NON_FINANCIAL",
  "industryCode": "NGO",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{beneficiaryRef} - @{householdHeadName} (@{programme})",
  "reminderEnabled": true,
  "reminderFrequencyHours": 24,
  "reminderMaxCount": 3,
  "reminderStartAfterHours": 24,
  "escalationEnabled": true,
  "escalationAfterHours": 72,
  "escalationAction": "NOTIFY_ADMIN",

  "forms": [{
    "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Reference", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Household Head", "displayOrder": 1, "icon": "person" },
      { "id": "temp_screen_3", "title": "Household Composition", "displayOrder": 2, "icon": "family_restroom" },
      { "id": "temp_screen_4", "title": "Eligibility", "displayOrder": 3, "icon": "checklist" },
      { "id": "temp_screen_5", "title": "Documents", "displayOrder": 4, "icon": "attach_file" },
      { "id": "temp_screen_6", "title": "Review & Submit", "displayOrder": 5, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Household Head", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_3", "title": "Location", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Members", "displayOrder": 3, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_5", "title": "Vulnerability", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_4" },
      { "id": "temp_grp_6", "title": "Consent & Documents", "displayOrder": 5, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_5" }
    ],
    "fields": [
      { "name": "beneficiaryRef", "label": "Beneficiary Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"NBR-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "registrationDate", "label": "Registration Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "enumerator", "label": "Enumerator / Officer", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "programme", "label": "Programme", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [
          { "value": "CASH_TRANSFER", "label": "Cash Transfer", "displayOrder": 0 },
          { "value": "FOOD_AID", "label": "Food Aid", "displayOrder": 1 },
          { "value": "VOUCHER", "label": "Voucher", "displayOrder": 2 },
          { "value": "HEALTH", "label": "Health Services", "displayOrder": 3 },
          { "value": "EDUCATION", "label": "Education / Scholarship", "displayOrder": 4 },
          { "value": "WASH", "label": "WASH", "displayOrder": 5 },
          { "value": "LIVELIHOODS", "label": "Livelihoods / Agri", "displayOrder": 6 },
          { "value": "SHELTER", "label": "Shelter", "displayOrder": 7 }
        ], "validation": "Required()" },
      { "name": "householdHeadName", "label": "Household Head", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "idNumber", "label": "ID / Document No", "fieldType": "TEXT", "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2" },
      { "name": "dateOfBirth", "label": "Date of Birth", "fieldType": "DATE", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "gender", "label": "Gender", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "options": [
          { "value": "F", "label": "Female", "displayOrder": 0 },
          { "value": "M", "label": "Male", "displayOrder": 1 },
          { "value": "O", "label": "Other / Prefer not to say", "displayOrder": 2 }
        ], "validation": "Required()" },
      { "name": "phone", "label": "Phone (if any)", "fieldType": "PHONE", "displayOrder": 14, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2" },
      { "name": "maritalStatus", "label": "Marital Status", "fieldType": "SELECT", "displayOrder": 15, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "options": [
          { "value": "SINGLE", "label": "Single", "displayOrder": 0 },
          { "value": "MARRIED", "label": "Married", "displayOrder": 1 },
          { "value": "WIDOWED", "label": "Widowed", "displayOrder": 2 },
          { "value": "DIVORCED", "label": "Divorced / Separated", "displayOrder": 3 }
        ] },
      { "name": "country", "label": "Country", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Required()" },
      { "name": "region", "label": "Region / District", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Required()" },
      { "name": "village", "label": "Village / Settlement", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Required()" },
      { "name": "gpsCoords", "label": "GPS Coordinates", "fieldType": "TEXT", "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3" },
      { "name": "members", "label": "Household Members", "fieldType": "TABLE", "isMandatory": true, "displayOrder": 30, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "tableMinRows": 1, "tableMaxRows": 30, "tableStriped": true, "tableBordered": true,
        "tableColumns": "[{\"name\":\"name\",\"label\":\"Full Name\",\"type\":\"TEXT\",\"width\":220,\"required\":true},{\"name\":\"relationship\",\"label\":\"Relationship\",\"type\":\"SELECT\",\"width\":150,\"required\":true,\"options\":[\"Spouse\",\"Child\",\"Parent\",\"Sibling\",\"Grandparent\",\"Grandchild\",\"Other\"]},{\"name\":\"dob\",\"label\":\"DOB\",\"type\":\"DATE\",\"width\":130,\"required\":true},{\"name\":\"gender\",\"label\":\"Gender\",\"type\":\"SELECT\",\"width\":110,\"options\":[\"F\",\"M\",\"O\"]},{\"name\":\"isDisabled\",\"label\":\"Disability?\",\"type\":\"SELECT\",\"width\":110,\"options\":[\"YES\",\"NO\"]},{\"name\":\"inSchool\",\"label\":\"In School?\",\"type\":\"SELECT\",\"width\":110,\"options\":[\"YES\",\"NO\",\"N/A\"]}]",
        "validation": "MinRows(1, \"Provide at least one household member\")" },
      { "name": "householdSize", "label": "Household Size", "fieldType": "NUMBER", "isReadonly": true, "inSummary": true, "displayOrder": 31, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "defaultValue": "COUNT(\"members\")" },
      { "name": "vulnerabilityCategory", "label": "Vulnerability Category", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "options": [
          { "value": "FEMALE_HEADED", "label": "Female-Headed Household", "displayOrder": 0 },
          { "value": "CHILD_HEADED", "label": "Child-Headed Household", "displayOrder": 1 },
          { "value": "DISABILITY", "label": "Household with Disability", "displayOrder": 2 },
          { "value": "CHRONIC_ILLNESS", "label": "Chronic Illness", "displayOrder": 3 },
          { "value": "ELDERLY", "label": "Elderly-Headed", "displayOrder": 4 },
          { "value": "REFUGEE", "label": "Refugee / Displaced", "displayOrder": 5 },
          { "value": "EXTREME_POOR", "label": "Extreme Poverty", "displayOrder": 6 },
          { "value": "NONE", "label": "None of the Above", "displayOrder": 7 }
        ], "validation": "Required()" },
      { "name": "monthlyIncome", "label": "Household Monthly Income", "fieldType": "CURRENCY", "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "Min(0)" },
      { "name": "foodSecurityScore", "label": "Food Security Score (IPC)", "fieldType": "SELECT", "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "options": [
          { "value": "IPC_1", "label": "Phase 1 - None", "displayOrder": 0 },
          { "value": "IPC_2", "label": "Phase 2 - Stressed", "displayOrder": 1 },
          { "value": "IPC_3", "label": "Phase 3 - Crisis", "displayOrder": 2 },
          { "value": "IPC_4", "label": "Phase 4 - Emergency", "displayOrder": 3 },
          { "value": "IPC_5", "label": "Phase 5 - Famine", "displayOrder": 4 }
        ] },
      { "name": "eligibilityPassed", "label": "Meets Programme Criteria", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 43, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "ValidWhen(@{eligibilityPassed} == true, \"Does not meet eligibility criteria\")" },
      { "name": "notes", "label": "Assessment Notes", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 44, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "Required() AND MinLength(20)" },
      { "name": "consentGiven", "label": "Data Consent / PII Consent Given", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 50, "columnSpan": 1, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "validation": "ValidWhen(@{consentGiven} == true, \"Beneficiary must consent to data processing\")" },
      { "name": "photo", "label": "Household Head Photo", "fieldType": "FILE", "displayOrder": 51, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "jpg,jpeg,png", "maxFileSize": 5242880 },
      { "name": "idCopy", "label": "ID / Ration Card", "fieldType": "FILE", "displayOrder": 52, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 10485760 },
      { "name": "verificationForm", "label": "Community Verification Form", "fieldType": "FILE", "displayOrder": 53, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 10485760 }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Field Officer", "approverType": "ROLE", "roleName": "FIELD_OFFICER", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Programme Manager", "approverType": "ROLE", "roleName": "PROGRAMME_MANAGER", "amountLimit": null, "canEscalate": false, "requireComment": false, "emailNotification": true }
  ]
}
