{
  "_comment": "Savings Withdrawal — withdrawal from member's savings / compulsory-savings account.",
  "name": "Savings Withdrawal",
  "code": "MSW",
  "description": "Member request to withdraw from their voluntary savings or compulsory-savings balance.",
  "icon": "savings",
  "displayOrder": 50,
  "requiresApproval": true,
  "commentsMandatory": false,
  "commentsMandatoryOnReject": true,
  "commentsMandatoryOnEscalate": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "MICROFINANCE",
  "workflowTypeCode": "FINANCE",
  "titleTemplate": "@{withdrawalRef} - @{memberName} (@{amount})",

  "reminderEnabled": true,
  "reminderFrequencyHours": 4,
  "reminderMaxCount": 6,
  "reminderStartAfterHours": 1,
  "escalationEnabled": true,
  "escalationAfterHours": 24,
  "escalationAction": "NOTIFY_ADMIN",
  "reminderEmailSubject": "Reminder: Savings Withdrawal @{referenceNumber} pending",
  "reminderEmailBody": "<p>Savings withdrawal <strong>@{referenceNumber}</strong> awaiting your action.</p>",

  "forms": [{
    "name": "Main Form",
    "displayOrder": 0,

    "screens": [
      { "id": "temp_screen_1", "title": "Reference", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Member & Account", "displayOrder": 1, "icon": "account_balance_wallet" },
      { "id": "temp_screen_3", "title": "Withdrawal", "displayOrder": 2, "icon": "payments" },
      { "id": "temp_screen_4", "title": "Checks", "displayOrder": 3, "icon": "checklist" },
      { "id": "temp_screen_5", "title": "Documents", "displayOrder": 4, "icon": "attach_file" },
      { "id": "temp_screen_6", "title": "Review & Submit", "displayOrder": 5, "icon": "fact_check", "isSummaryScreen": true }
    ],

    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Member & Account", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_3", "title": "Amount", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_4", "title": "Payout", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_5", "title": "Pre-Payout Checks", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_4" },
      { "id": "temp_grp_6", "title": "Documents", "displayOrder": 5, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_5" }
    ],

    "fields": [
      { "name": "withdrawalRef", "label": "Withdrawal Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"MSW-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "requestDate", "label": "Request Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "teller", "label": "Teller / Officer", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "branch", "label": "Branch", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "validation": "Required()" },

      { "name": "memberNumber", "label": "Member Number", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "memberName", "label": "Member Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "accountType", "label": "Account Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "options": [
          { "value": "VOLUNTARY", "label": "Voluntary Savings", "displayOrder": 0 },
          { "value": "COMPULSORY", "label": "Compulsory Savings", "displayOrder": 1 },
          { "value": "FIXED", "label": "Fixed Deposit", "displayOrder": 2 },
          { "value": "SHARES", "label": "Shares (SACCO)", "displayOrder": 3 }
        ],
        "validation": "Required()" },
      { "name": "accountNumber", "label": "Savings Account Number", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "currentBalance", "label": "Current Balance", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 14, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required() AND Min(0)" },
      { "name": "withdrawableBalance", "label": "Available (Withdrawable) Balance", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 15, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required() AND Min(0)" },

      { "name": "amount", "label": "Withdrawal Amount", "fieldType": "CURRENCY", "isMandatory": true, "isLimited": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "validation": "Required() AND Min(0.01)" },
      { "name": "withdrawalType", "label": "Withdrawal Type", "fieldType": "SELECT", "isMandatory": true, "defaultValue": "PARTIAL", "inSummary": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "options": [
          { "value": "PARTIAL", "label": "Partial", "displayOrder": 0 },
          { "value": "FULL", "label": "Full Close-Out", "displayOrder": 1 },
          { "value": "EARLY_FD", "label": "Early FD Break", "displayOrder": 2 }
        ],
        "validation": "Required()" },
      { "name": "reason", "label": "Reason for Withdrawal", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 22, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "validation": "Required() AND MinLength(10)" },
      { "name": "penaltyAmount", "label": "Early-Exit Penalty", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "validation": "Min(0)" },
      { "name": "netAmount", "label": "Net Amount Payable", "fieldType": "CURRENCY", "isReadonly": true, "inSummary": true, "displayOrder": 24, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "defaultValue": "SUBTRACT(@{amount}, @{penaltyAmount})" },

      { "name": "payoutMethod", "label": "Payout Method", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "options": [
          { "value": "CASH", "label": "Cash", "displayOrder": 0 },
          { "value": "MOBILE_MONEY", "label": "Mobile Money", "displayOrder": 1 },
          { "value": "BANK_TRANSFER", "label": "Bank Transfer", "displayOrder": 2 },
          { "value": "CHEQUE", "label": "Cheque", "displayOrder": 3 }
        ],
        "validation": "Required()" },
      { "name": "payoutAccount", "label": "Account / Mobile Number", "fieldType": "TEXT", "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "visibilityExpression": "@{payoutMethod} == 'MOBILE_MONEY' OR @{payoutMethod} == 'BANK_TRANSFER'",
        "validation": "ValidWhen(@{payoutMethod} == 'CASH' OR @{payoutMethod} == 'CHEQUE' OR IS_NOT_EMPTY(@{payoutAccount}), \"Account required\")" },

      { "name": "sufficientBalance", "label": "Sufficient Available Balance", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "ValidWhen(@{sufficientBalance} == true, \"Balance must be sufficient\")" },
      { "name": "noLoanSecurityHold", "label": "Not Held as Loan Security", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "ValidWhen(@{noLoanSecurityHold} == true, \"Funds must not be held as loan security\")" },
      { "name": "idVerified", "label": "Member ID Verified", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "ValidWhen(@{idVerified} == true, \"ID must be verified\")" },
      { "name": "signatureMatched", "label": "Signature / Biometric Matched", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 43, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "ValidWhen(@{signatureMatched} == true, \"Signature/biometric must match\")" },

      { "name": "withdrawalSlip", "label": "Signed Withdrawal Slip", "fieldType": "FILE", "isMandatory": true, "displayOrder": 50, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 10485760,
        "validation": "Required()" },
      { "name": "idCopy", "label": "Member ID Copy", "fieldType": "FILE", "isMandatory": true, "displayOrder": 51, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 10485760,
        "validation": "Required()" }
    ]
  }],

  "approvers": [
    { "level": 1, "name": "Teller", "approverType": "ROLE", "roleName": "TELLER", "amountLimit": 500, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Branch Accountant", "approverType": "ROLE", "roleName": "BRANCH_ACCOUNTANT", "amountLimit": 5000, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 3, "name": "Branch Manager", "approverType": "ROLE", "roleName": "BRANCH_MANAGER", "amountLimit": null, "canEscalate": false, "requireComment": false, "emailNotification": true }
  ]
}
