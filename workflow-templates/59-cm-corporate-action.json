{
  "_comment": "Corporate Action Event — process dividend / rights / bonus / split announcements on securities held.",
  "name": "Corporate Action Event",
  "code": "CAE",
  "description": "Process a corporate action (dividend, rights, bonus, split, merger) affecting client holdings.",
  "icon": "event_note",
  "displayOrder": 59,
  "requiresApproval": true,
  "commentsMandatoryOnReject": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "CAPITAL_MARKETS",
  "workflowTypeCode": "FINANCE",
  "titleTemplate": "@{caRef} - @{issuer} (@{caType})",
  "reminderEnabled": true,
  "reminderFrequencyHours": 12,
  "reminderMaxCount": 4,
  "reminderStartAfterHours": 12,
  "escalationEnabled": true,
  "escalationAfterHours": 48,
  "escalationAction": "NOTIFY_ADMIN",

  "forms": [{
    "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Event", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Terms", "displayOrder": 1, "icon": "list" },
      { "id": "temp_screen_3", "title": "Impact & Entitlements", "displayOrder": 2, "icon": "assessment" },
      { "id": "temp_screen_4", "title": "Documents", "displayOrder": 3, "icon": "attach_file" },
      { "id": "temp_screen_5", "title": "Review & Submit", "displayOrder": 4, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Issuer & Security", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Event Terms", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Holdings Impact", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_5", "title": "Documents", "displayOrder": 4, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_4" }
    ],
    "fields": [
      { "name": "caRef", "label": "Event Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"CAE-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "announcementDate", "label": "Announcement Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "validation": "Required()" },
      { "name": "caType", "label": "Event Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [
          { "value": "DIVIDEND_CASH", "label": "Cash Dividend", "displayOrder": 0 },
          { "value": "DIVIDEND_SCRIP", "label": "Scrip Dividend", "displayOrder": 1 },
          { "value": "RIGHTS", "label": "Rights Issue", "displayOrder": 2 },
          { "value": "BONUS", "label": "Bonus / Stock Dividend", "displayOrder": 3 },
          { "value": "SPLIT", "label": "Stock Split", "displayOrder": 4 },
          { "value": "CONSOLIDATION", "label": "Consolidation", "displayOrder": 5 },
          { "value": "MERGER", "label": "Merger / Acquisition", "displayOrder": 6 },
          { "value": "COUPON", "label": "Bond Coupon", "displayOrder": 7 },
          { "value": "REDEMPTION", "label": "Redemption", "displayOrder": 8 }
        ], "validation": "Required()" },
      { "name": "mandatory", "label": "Mandatory / Voluntary", "fieldType": "SELECT", "isMandatory": true, "defaultValue": "MANDATORY", "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [
          { "value": "MANDATORY", "label": "Mandatory", "displayOrder": 0 },
          { "value": "VOLUNTARY", "label": "Voluntary", "displayOrder": 1 },
          { "value": "CHOICE", "label": "Mandatory with Choice", "displayOrder": 2 }
        ], "validation": "Required()" },
      { "name": "issuer", "label": "Issuer", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "symbol", "label": "Symbol / ISIN", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "recordDate", "label": "Record Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Required()" },
      { "name": "exDate", "label": "Ex-Date", "fieldType": "DATE", "isMandatory": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Required()" },
      { "name": "paymentDate", "label": "Payment / Distribution Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Required()" },
      { "name": "ratePerShare", "label": "Rate / Dividend per Share", "fieldType": "NUMBER", "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Min(0)" },
      { "name": "ratio", "label": "Ratio (e.g. 1:10)", "fieldType": "TEXT", "displayOrder": 24, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "visibilityExpression": "@{caType} == 'BONUS' OR @{caType} == 'SPLIT' OR @{caType} == 'CONSOLIDATION' OR @{caType} == 'RIGHTS'" },
      { "name": "subscriptionPrice", "label": "Rights Subscription Price", "fieldType": "CURRENCY", "displayOrder": 25, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "visibilityExpression": "@{caType} == 'RIGHTS'" },
      { "name": "eligibleHoldings", "label": "Eligible Holdings (shares)", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "validation": "Required() AND Min(0)" },
      { "name": "numClientsAffected", "label": "Clients Affected", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "validation": "Required() AND Min(0)" },
      { "name": "totalEntitlementAmount", "label": "Total Entitlement", "fieldType": "CURRENCY", "isMandatory": true, "isLimited": true, "inSummary": true, "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "validation": "Required() AND Min(0)" },
      { "name": "withholdingTax", "label": "Withholding Tax Amount", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 33, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "validation": "Min(0)" },
      { "name": "netPayable", "label": "Net Amount Payable", "fieldType": "CURRENCY", "isReadonly": true, "inSummary": true, "displayOrder": 34, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "defaultValue": "SUBTRACT(@{totalEntitlementAmount}, @{withholdingTax})" },
      { "name": "issuerAnnouncement", "label": "Issuer Announcement / Circular", "fieldType": "FILE", "isMandatory": true, "displayOrder": 40, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "allowedFileTypes": "pdf", "maxFileSize": 10485760, "validation": "Required()" },
      { "name": "exchangeNotice", "label": "Exchange / Regulator Notice", "fieldType": "FILE", "displayOrder": 41, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "allowedFileTypes": "pdf", "maxFileSize": 10485760 },
      { "name": "clientNoticeTemplate", "label": "Client Notification Template", "fieldType": "FILE", "displayOrder": 42, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "allowedFileTypes": "pdf,doc,docx", "maxFileSize": 10485760 }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Operations Officer", "approverType": "ROLE", "roleName": "OPS_OFFICER", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Operations Manager", "approverType": "ROLE", "roleName": "OPS_MANAGER", "amountLimit": 500000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Head of Custody", "approverType": "ROLE", "roleName": "HEAD_OF_CUSTODY", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
