{
  "_comment": "Trade Settlement / Reconciliation — match and settle executed trades on value date, resolve breaks.",
  "name": "Trade Settlement & Reconciliation",
  "code": "TSR",
  "description": "Match, fund and settle executed trades on value date. Investigate and resolve settlement breaks.",
  "icon": "compare_arrows",
  "displayOrder": 60,
  "requiresApproval": true,
  "commentsMandatoryOnReject": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "CAPITAL_MARKETS",
  "workflowTypeCode": "FINANCE",
  "titleTemplate": "@{settleRef} - @{tradeRef} (@{settlementAmount})",
  "reminderEnabled": true,
  "reminderFrequencyHours": 2,
  "reminderMaxCount": 6,
  "reminderStartAfterHours": 1,
  "escalationEnabled": true,
  "escalationAfterHours": 8,
  "escalationAction": "NOTIFY_ADMIN",

  "forms": [{
    "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Trade", "displayOrder": 0, "icon": "receipt" },
      { "id": "temp_screen_2", "title": "Settlement", "displayOrder": 1, "icon": "payments" },
      { "id": "temp_screen_3", "title": "Breaks & Exceptions", "displayOrder": 2, "icon": "warning" },
      { "id": "temp_screen_4", "title": "Documents", "displayOrder": 3, "icon": "attach_file" },
      { "id": "temp_screen_5", "title": "Review & Submit", "displayOrder": 4, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Trade Details", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Matching & Settlement", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Exceptions", "displayOrder": 3, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_5", "title": "Documents", "displayOrder": 4, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_4" }
    ],
    "fields": [
      { "name": "settleRef", "label": "Settlement Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"TSR-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "processDate", "label": "Processing Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "operator", "label": "Operator", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "tradeRef", "label": "Trade Reference", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "side", "label": "Side", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "BUY", "label": "Buy", "displayOrder": 0 }, { "value": "SELL", "label": "Sell", "displayOrder": 1 } ], "validation": "Required()" },
      { "name": "symbol", "label": "Symbol", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "quantity", "label": "Quantity", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "validation": "Required() AND Min(1)" },
      { "name": "executionPrice", "label": "Execution Price", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "validation": "Required() AND Min(0)" },
      { "name": "counterparty", "label": "Counterparty / Broker", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 14, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "tradeDate", "label": "Trade Date", "fieldType": "DATE", "isMandatory": true, "displayOrder": 15, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "valueDate", "label": "Value / Settlement Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Required()" },
      { "name": "grossAmount", "label": "Gross Amount", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "defaultValue": "MULTIPLY(@{quantity}, @{executionPrice})", "validation": "Required() AND Min(0)" },
      { "name": "commission", "label": "Commission", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Min(0)" },
      { "name": "taxesAndLevies", "label": "Taxes & Exchange Levies", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Min(0)" },
      { "name": "settlementAmount", "label": "Net Settlement Amount", "fieldType": "CURRENCY", "isReadonly": true, "isLimited": true, "inSummary": true, "displayOrder": 24, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "defaultValue": "SUM(@{grossAmount}, @{commission}, @{taxesAndLevies})" },
      { "name": "cashMatched", "label": "Cash Leg Matched?", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 25, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "ValidWhen(@{cashMatched} == true, \"Cash must be matched before settlement\")" },
      { "name": "securitiesMatched", "label": "Securities Leg Matched?", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 26, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "ValidWhen(@{securitiesMatched} == true, \"Securities must be matched\")" },
      { "name": "hasBreak", "label": "Settlement Break?", "fieldType": "YES_NO", "defaultValue": "false", "inSummary": true, "displayOrder": 30, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4" },
      { "name": "breakType", "label": "Break Type", "fieldType": "SELECT", "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "visibilityExpression": "@{hasBreak} == true",
        "options": [
          { "value": "CASH", "label": "Cash Mismatch", "displayOrder": 0 },
          { "value": "QUANTITY", "label": "Quantity Mismatch", "displayOrder": 1 },
          { "value": "PRICE", "label": "Price Mismatch", "displayOrder": 2 },
          { "value": "UNMATCHED", "label": "Unmatched by Counterparty", "displayOrder": 3 },
          { "value": "FAILED", "label": "Failed at CSD", "displayOrder": 4 }
        ] },
      { "name": "breakDescription", "label": "Break Description", "fieldType": "TEXTAREA", "displayOrder": 32, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "visibilityExpression": "@{hasBreak} == true",
        "validation": "ValidWhen(@{hasBreak} == false OR HAS_MIN_LENGTH(@{breakDescription}, 20), \"Describe the break\")" },
      { "name": "resolution", "label": "Resolution / Action Taken", "fieldType": "TEXTAREA", "displayOrder": 33, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "visibilityExpression": "@{hasBreak} == true" },
      { "name": "contractNote", "label": "Contract Note", "fieldType": "FILE", "isMandatory": true, "displayOrder": 40, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "allowedFileTypes": "pdf", "maxFileSize": 10485760, "validation": "Required()" },
      { "name": "csdConfirmation", "label": "CSD Confirmation", "fieldType": "FILE", "displayOrder": 41, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "allowedFileTypes": "pdf,txt,xml", "maxFileSize": 10485760 },
      { "name": "swiftMessage", "label": "SWIFT Message (MT54x)", "fieldType": "FILE", "displayOrder": 42, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "allowedFileTypes": "txt,xml,pdf", "maxFileSize": 10485760 }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Settlements Officer (Maker)", "approverType": "ROLE", "roleName": "SETTLEMENTS_OFFICER", "amountLimit": 100000, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Settlements Manager (Checker)", "approverType": "ROLE", "roleName": "SETTLEMENTS_MANAGER", "amountLimit": 1000000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Head of Operations", "approverType": "ROLE", "roleName": "HEAD_OF_OPERATIONS", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
