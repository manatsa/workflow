{
  "_comment": "Variation / Change Order — approve a change to construction scope, time or cost.",
  "name": "Construction Variation Order",
  "code": "CVO",
  "description": "Approve a variation / change order to the construction contract scope, time or cost.",
  "icon": "edit_note",
  "displayOrder": 137,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "CONSTRUCTION",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{voRef} - @{projectName} (@{costImpact})",
  "reminderEnabled": true, "reminderFrequencyHours": 24, "reminderMaxCount": 3, "reminderStartAfterHours": 24,
  "escalationEnabled": true, "escalationAfterHours": 72, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Change Detail", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Impact", "displayOrder": 1, "icon": "assessment" },
      { "id": "temp_screen_3", "title": "Review", "displayOrder": 2, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Project & Contract", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Change Description", "displayOrder": 2, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_4", "title": "Cost Impact", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Time Impact", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" }
    ],
    "fields": [
      { "name": "voRef", "label": "Variation Order Ref", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"CVO-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "raisedDate", "label": "Raised Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "raisedBy", "label": "Raised By", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "voNumber", "label": "VO Number", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "projectName", "label": "Project", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "contractNumber", "label": "Contract Number", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "clientName", "label": "Client / Employer", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "originalContractValue", "label": "Original Contract Value", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND Min(0)" },
      { "name": "changeSource", "label": "Change Source", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "CLIENT", "label": "Client-Instructed", "displayOrder": 0 }, { "value": "DESIGN", "label": "Design Change", "displayOrder": 1 }, { "value": "SITE", "label": "Site / Ground Conditions", "displayOrder": 2 }, { "value": "REGULATORY", "label": "Regulatory Change", "displayOrder": 3 }, { "value": "CONTRACTOR", "label": "Contractor-Proposed", "displayOrder": 4 } ], "validation": "Required()" },
      { "name": "changeDescription", "label": "Description of Change", "fieldType": "TEXTAREA", "isMandatory": true, "inSummary": true, "displayOrder": 21, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required() AND MinLength(50)" },
      { "name": "justification", "label": "Justification", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 22, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required() AND MinLength(30)" },
      { "name": "costImpact", "label": "Cost Impact (+/-)", "fieldType": "CURRENCY", "isMandatory": true, "isLimited": true, "inSummary": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required()" },
      { "name": "percentOfContract", "label": "% of Contract Value", "fieldType": "NUMBER", "isReadonly": true, "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "defaultValue": "PERCENTAGE(@{costImpact}, @{originalContractValue})" },
      { "name": "newContractValue", "label": "New Contract Value", "fieldType": "CURRENCY", "isReadonly": true, "inSummary": true, "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "defaultValue": "SUM(@{originalContractValue}, @{costImpact})" },
      { "name": "costJustification", "label": "Cost Breakdown / Build-Up", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 33, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND MinLength(30)" },
      { "name": "timeImpactDays", "label": "Time Impact (days)", "fieldType": "NUMBER", "isMandatory": true, "defaultValue": "0", "inSummary": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "Required()" },
      { "name": "revisedCompletionDate", "label": "Revised Completion Date", "fieldType": "DATE", "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5" },
      { "name": "clientApproved", "label": "Client / Employer Approved", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 42, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{clientApproved} == true, \"Client approval required\")" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Quantity Surveyor", "approverType": "ROLE", "roleName": "QS", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Project Manager", "approverType": "ROLE", "roleName": "PROJECT_MANAGER", "amountLimit": 100000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Commercial Director", "approverType": "ROLE", "roleName": "COMMERCIAL_DIRECTOR", "amountLimit": 1000000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 4, "name": "MD / CEO", "approverType": "ROLE", "roleName": "MD", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
