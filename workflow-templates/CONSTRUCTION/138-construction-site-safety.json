{
  "_comment": "Site Safety Inspection — regular safety inspection of a construction site.",
  "name": "Construction Site Safety Inspection",
  "code": "CSI",
  "description": "Scheduled safety inspection of a construction site with checklist, findings and close-out actions.",
  "icon": "gpp_good",
  "displayOrder": 138,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "NON_FINANCIAL",
  "industryCode": "CONSTRUCTION",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{inspectionRef} - @{site} (@{result})",
  "reminderEnabled": true, "reminderFrequencyHours": 12, "reminderMaxCount": 3, "reminderStartAfterHours": 12,
  "escalationEnabled": true, "escalationAfterHours": 48, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Inspection", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Checklist & Findings", "displayOrder": 1, "icon": "checklist" },
      { "id": "temp_screen_3", "title": "Review", "displayOrder": 2, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Site Info", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Safety Checklist", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Findings", "displayOrder": 3, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Result & Close-Out", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" }
    ],
    "fields": [
      { "name": "inspectionRef", "label": "Inspection Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"CSI-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "inspectionDate", "label": "Inspection Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "inspector", "label": "Safety Officer", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "inspectionType", "label": "Inspection Type", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [ { "value": "DAILY", "label": "Daily", "displayOrder": 0 }, { "value": "WEEKLY", "label": "Weekly", "displayOrder": 1 }, { "value": "MONTHLY", "label": "Monthly", "displayOrder": 2 }, { "value": "SPOT", "label": "Spot-Check", "displayOrder": 3 }, { "value": "POST_INCIDENT", "label": "Post-Incident", "displayOrder": 4 } ], "validation": "Required()" },
      { "name": "site", "label": "Site / Project", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "projectManager", "label": "Project Manager", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "personnelOnSite", "label": "Personnel On Site", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND Min(0)" },
      { "name": "weatherConditions", "label": "Weather", "fieldType": "TEXT", "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2" },
      { "name": "ppeCompliance", "label": "PPE Compliance", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "PASS", "label": "Pass", "displayOrder": 0 }, { "value": "FAIL", "label": "Fail", "displayOrder": 1 }, { "value": "NA", "label": "N/A", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "workingAtHeight", "label": "Working at Height Controls", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "PASS", "label": "Pass", "displayOrder": 0 }, { "value": "FAIL", "label": "Fail", "displayOrder": 1 }, { "value": "NA", "label": "N/A", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "scaffolding", "label": "Scaffolding", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "PASS", "label": "Pass", "displayOrder": 0 }, { "value": "FAIL", "label": "Fail", "displayOrder": 1 }, { "value": "NA", "label": "N/A", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "excavations", "label": "Excavations", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "PASS", "label": "Pass", "displayOrder": 0 }, { "value": "FAIL", "label": "Fail", "displayOrder": 1 }, { "value": "NA", "label": "N/A", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "electricalSafety", "label": "Electrical Safety", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 24, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "PASS", "label": "Pass", "displayOrder": 0 }, { "value": "FAIL", "label": "Fail", "displayOrder": 1 }, { "value": "NA", "label": "N/A", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "fireSafety", "label": "Fire Safety", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 25, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "PASS", "label": "Pass", "displayOrder": 0 }, { "value": "FAIL", "label": "Fail", "displayOrder": 1 }, { "value": "NA", "label": "N/A", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "findings", "label": "Non-Conformance Findings", "fieldType": "TABLE", "displayOrder": 30, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "tableMinRows": 0, "tableMaxRows": 30, "tableStriped": true, "tableBordered": true,
        "tableColumns": "[{\"name\":\"finding\",\"label\":\"Finding\",\"type\":\"TEXT\",\"width\":300,\"required\":true},{\"name\":\"severity\",\"label\":\"Severity\",\"type\":\"SELECT\",\"width\":120,\"required\":true,\"options\":[\"LOW\",\"MEDIUM\",\"HIGH\",\"CRITICAL\"]},{\"name\":\"action\",\"label\":\"Corrective Action\",\"type\":\"TEXT\",\"width\":280,\"required\":true},{\"name\":\"responsible\",\"label\":\"Responsible\",\"type\":\"TEXT\",\"width\":140,\"required\":true},{\"name\":\"dueDate\",\"label\":\"Due Date\",\"type\":\"DATE\",\"width\":140,\"required\":true}]" },
      { "name": "result", "label": "Overall Result", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5",
        "options": [ { "value": "PASS", "label": "Pass", "displayOrder": 0 }, { "value": "CONDITIONAL", "label": "Conditional Pass", "displayOrder": 1 }, { "value": "FAIL_STOP", "label": "Fail - Stop Work", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "stopWorkIssued", "label": "Stop Work Order Issued", "fieldType": "YES_NO", "defaultValue": "false", "inSummary": true, "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5" },
      { "name": "summary", "label": "Summary / Notes", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 42, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "Required() AND MinLength(20)" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Site Safety Officer", "approverType": "ROLE", "roleName": "SAFETY_OFFICER", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 2, "name": "Project Manager", "approverType": "ROLE", "roleName": "PROJECT_MANAGER", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "HSE Manager", "approverType": "ROLE", "roleName": "HSE_MANAGER", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
