{
  "_comment": "Esports Roster Change — sign / release esports players on a competitive team.",
  "name": "Esports Roster Change",
  "code": "GER",
  "description": "Sign, release or bench esports players on a competitive team roster.",
  "icon": "groups",
  "displayOrder": 180,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "GAMING",
  "workflowTypeCode": "FINANCE",
  "titleTemplate": "@{rosterRef} - @{teamName} (@{changeType})",
  "reminderEnabled": true, "reminderFrequencyHours": 24, "reminderMaxCount": 3, "reminderStartAfterHours": 24,
  "escalationEnabled": true, "escalationAfterHours": 72, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Change", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Terms", "displayOrder": 1, "icon": "payments" },
      { "id": "temp_screen_3", "title": "Review", "displayOrder": 2, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Team & Player", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Change Detail", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_4", "title": "Contract & Compliance", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" }
    ],
    "fields": [
      { "name": "rosterRef", "label": "Roster Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"GER-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "submissionDate", "label": "Submission Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "gmName", "label": "General Manager", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "teamName", "label": "Team / Game Title", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "playerHandle", "label": "Player Handle", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "playerLegalName", "label": "Legal Name", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "playerAge", "label": "Player Age", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND Min(16) AND Max(80)" },
      { "name": "changeType", "label": "Change Type", "fieldType": "SELECT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "SIGN", "label": "Sign / New Signing", "displayOrder": 0 }, { "value": "RELEASE", "label": "Release / Drop", "displayOrder": 1 }, { "value": "BENCH", "label": "Bench", "displayOrder": 2 }, { "value": "TRADE", "label": "Trade", "displayOrder": 3 }, { "value": "LOAN", "label": "Loan", "displayOrder": 4 } ], "validation": "Required()" },
      { "name": "role", "label": "Role / Position", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "effectiveDate", "label": "Effective Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "rationale", "label": "Rationale", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 23, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required() AND MinLength(20)" },
      { "name": "salary", "label": "Monthly Salary", "fieldType": "CURRENCY", "defaultValue": "0", "isLimited": true, "inSummary": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Min(0)" },
      { "name": "contractMonths", "label": "Contract Term (months)", "fieldType": "NUMBER", "defaultValue": "12", "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Min(0) AND Max(60)" },
      { "name": "buyoutClause", "label": "Buyout Clause", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Min(0)" },
      { "name": "totalCommitment", "label": "Total Commitment", "fieldType": "CURRENCY", "isReadonly": true, "isLimited": true, "inSummary": true, "displayOrder": 33, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "defaultValue": "MULTIPLY(@{salary}, @{contractMonths})" },
      { "name": "visaRequired", "label": "Work Visa Required?", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 34, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "leagueRegistered", "label": "League / Publisher Registration Done", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 35, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "ValidWhen(@{leagueRegistered} == true, \"League registration required\")" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Team Coach", "approverType": "ROLE", "roleName": "TEAM_COACH", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 2, "name": "General Manager", "approverType": "ROLE", "roleName": "GM", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Head of Esports", "approverType": "ROLE", "roleName": "HEAD_ESPORTS", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
