{
  "_comment": "Event Sponsorship Application — process a sponsorship application for an association conference or event.",
  "name": "Event Sponsorship Application",
  "code": "ESA",
  "description": "Process a sponsorship proposal from a corporate partner for an association conference, awards ceremony or industry event.",
  "icon": "campaign",
  "displayOrder": 293,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "ASSOCIATIONS",
  "workflowTypeCode": "FINANCE",
  "titleTemplate": "@{sponsorRef} - @{sponsorName} (@{sponsorshipTier})",
  "reminderEnabled": true, "reminderFrequencyHours": 24, "reminderMaxCount": 3, "reminderStartAfterHours": 24,
  "escalationEnabled": true, "escalationAfterHours": 72, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Sponsor & Event", "displayOrder": 0, "icon": "campaign" },
      { "id": "temp_screen_2", "title": "Benefits & Payment", "displayOrder": 1, "icon": "star" },
      { "id": "temp_screen_3", "title": "Review", "displayOrder": 2, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Sponsor & Event", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Sponsorship Package", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Payment & Documents", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" }
    ],
    "fields": [
      { "name": "sponsorRef", "label": "Sponsorship Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"ESA-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "submitDate", "label": "Submit Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "sponsorName", "label": "Sponsor / Company Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "contactPerson", "label": "Contact Person", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "contactEmail", "label": "Contact Email", "fieldType": "EMAIL", "isMandatory": true, "displayOrder": 4, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "eventName", "label": "Event Name", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 5, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "eventDate", "label": "Event Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 6, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "eventVenue", "label": "Event Venue", "fieldType": "TEXT", "displayOrder": 7, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2" },
      { "name": "sponsorshipTier", "label": "Sponsorship Tier", "fieldType": "SELECT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "PLATINUM", "label": "Platinum / Title Sponsor", "displayOrder": 0 }, { "value": "GOLD", "label": "Gold Sponsor", "displayOrder": 1 }, { "value": "SILVER", "label": "Silver Sponsor", "displayOrder": 2 }, { "value": "BRONZE", "label": "Bronze Sponsor", "displayOrder": 3 }, { "value": "EXHIBITOR", "label": "Exhibitor", "displayOrder": 4 }, { "value": "IN_KIND", "label": "In-Kind Sponsor", "displayOrder": 5 } ], "validation": "Required()" },
      { "name": "sponsorshipAmount", "label": "Sponsorship Amount", "fieldType": "CURRENCY", "isMandatory": true, "isLimited": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required() AND Min(0)" },
      { "name": "benefitsIncluded", "label": "Benefits Included", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 12, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "exhibitionBooth", "label": "Exhibition Booth Included", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3" },
      { "name": "speakingSlot", "label": "Speaking Slot Included", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 14, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3" },
      { "name": "paymentReceived", "label": "Payment Received", "fieldType": "YES_NO", "defaultValue": "false", "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "invoiceIssued", "label": "Invoice Issued", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "remarks", "label": "Remarks", "fieldType": "TEXTAREA", "displayOrder": 22, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "sponsorshipAgreement", "label": "Sponsorship Agreement", "fieldType": "FILE", "displayOrder": 30, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "allowedFileTypes": "pdf,doc,docx", "maxFileSize": 10485760 },
      { "name": "sponsorLogo", "label": "Sponsor Logo (high-res)", "fieldType": "FILE", "displayOrder": 31, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "allowedFileTypes": "png,jpg,jpeg,svg,pdf", "maxFileSize": 10485760 }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Events Coordinator", "approverType": "ROLE", "roleName": "EVENTS_COORDINATOR", "amountLimit": 20000, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Executive Director", "approverType": "ROLE", "roleName": "EXECUTIVE_DIRECTOR", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
