{
  "_comment": "Patient Admission — register and admit a patient to a hospital ward / unit.",
  "name": "Patient Admission",
  "code": "HPA",
  "description": "Register and admit a patient to a hospital ward / unit with triage, bed allocation and billing setup.",
  "icon": "medical_services",
  "displayOrder": 74,
  "requiresApproval": true,
  "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "NON_FINANCIAL",
  "industryCode": "HEALTHCARE",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{admissionRef} - @{patientName} (@{ward})",
  "reminderEnabled": true, "reminderFrequencyHours": 1, "reminderMaxCount": 4, "reminderStartAfterHours": 1,
  "escalationEnabled": true, "escalationAfterHours": 4, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Patient", "displayOrder": 0, "icon": "person" },
      { "id": "temp_screen_2", "title": "Admission", "displayOrder": 1, "icon": "local_hospital" },
      { "id": "temp_screen_3", "title": "Payer / Insurance", "displayOrder": 2, "icon": "payments" },
      { "id": "temp_screen_4", "title": "Documents", "displayOrder": 3, "icon": "attach_file" },
      { "id": "temp_screen_5", "title": "Review", "displayOrder": 4, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Patient Identity", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Next of Kin", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Clinical", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Bed Allocation", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Payer", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_6", "title": "Documents", "displayOrder": 5, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_4" }
    ],
    "fields": [
      { "name": "admissionRef", "label": "Admission Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"HPA-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "admissionDate", "label": "Admission Date/Time", "fieldType": "DATE", "defaultValue": "TODAY()", "isMandatory": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()" },
      { "name": "patientMrn", "label": "Patient MRN", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "patientName", "label": "Patient Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required() AND MinLength(2)" },
      { "name": "dateOfBirth", "label": "Date of Birth", "fieldType": "DATE", "isMandatory": true, "displayOrder": 4, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()" },
      { "name": "gender", "label": "Gender", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 5, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [ { "value": "F", "label": "Female", "displayOrder": 0 }, { "value": "M", "label": "Male", "displayOrder": 1 }, { "value": "O", "label": "Other", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "phone", "label": "Phone", "fieldType": "PHONE", "isMandatory": true, "displayOrder": 6, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required() AND Phone()" },
      { "name": "nokName", "label": "Next of Kin Name", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "nokRelationship", "label": "Relationship", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "nokPhone", "label": "Next of Kin Phone", "fieldType": "PHONE", "isMandatory": true, "displayOrder": 12, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND Phone()" },
      { "name": "admissionType", "label": "Admission Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "EMERGENCY", "label": "Emergency", "displayOrder": 0 }, { "value": "ELECTIVE", "label": "Elective", "displayOrder": 1 }, { "value": "REFERRAL", "label": "Referral", "displayOrder": 2 }, { "value": "TRANSFER", "label": "Transfer-In", "displayOrder": 3 }, { "value": "MATERNITY", "label": "Maternity", "displayOrder": 4 } ], "validation": "Required()" },
      { "name": "triageLevel", "label": "Triage Level", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "1_IMMEDIATE", "label": "1 - Immediate (Red)", "displayOrder": 0 }, { "value": "2_URGENT", "label": "2 - Urgent (Orange)", "displayOrder": 1 }, { "value": "3_STANDARD", "label": "3 - Standard (Yellow)", "displayOrder": 2 }, { "value": "4_NON_URGENT", "label": "4 - Non-Urgent (Green)", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "admittingDiagnosis", "label": "Admitting Diagnosis", "fieldType": "TEXTAREA", "isMandatory": true, "inSummary": true, "displayOrder": 22, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required() AND MinLength(10)" },
      { "name": "admittingPhysician", "label": "Admitting Physician", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "referredFrom", "label": "Referred From", "fieldType": "TEXT", "displayOrder": 24, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3" },
      { "name": "ward", "label": "Ward / Unit", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "options": [ { "value": "GENERAL", "label": "General Ward", "displayOrder": 0 }, { "value": "ICU", "label": "ICU", "displayOrder": 1 }, { "value": "PAEDIATRIC", "label": "Paediatric", "displayOrder": 2 }, { "value": "MATERNITY", "label": "Maternity", "displayOrder": 3 }, { "value": "SURGICAL", "label": "Surgical", "displayOrder": 4 }, { "value": "ISOLATION", "label": "Isolation", "displayOrder": 5 }, { "value": "PRIVATE", "label": "Private", "displayOrder": 6 } ], "validation": "Required()" },
      { "name": "bedNumber", "label": "Bed Number", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required()" },
      { "name": "estimatedStayDays", "label": "Estimated Stay (days)", "fieldType": "NUMBER", "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Min(0)" },
      { "name": "payerType", "label": "Payer", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5",
        "options": [ { "value": "SELF_PAY", "label": "Self-Pay", "displayOrder": 0 }, { "value": "MEDICAL_AID", "label": "Medical Aid / Insurance", "displayOrder": 1 }, { "value": "EMPLOYER", "label": "Employer Scheme", "displayOrder": 2 }, { "value": "GOVERNMENT", "label": "Government Scheme", "displayOrder": 3 }, { "value": "NGO", "label": "NGO / Donor", "displayOrder": 4 } ], "validation": "Required()" },
      { "name": "insurerName", "label": "Insurer / Scheme Name", "fieldType": "TEXT", "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "visibilityExpression": "@{payerType} == 'MEDICAL_AID' OR @{payerType} == 'EMPLOYER' OR @{payerType} == 'GOVERNMENT'" },
      { "name": "memberNumber", "label": "Member / Policy Number", "fieldType": "TEXT", "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "visibilityExpression": "@{payerType} == 'MEDICAL_AID' OR @{payerType} == 'EMPLOYER' OR @{payerType} == 'GOVERNMENT'" },
      { "name": "deposit", "label": "Admission Deposit", "fieldType": "CURRENCY", "defaultValue": "0", "isLimited": true, "inSummary": true, "displayOrder": 43, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "Min(0)" },
      { "name": "preAuthorisation", "label": "Pre-Authorisation Obtained?", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 44, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5" },
      { "name": "patientId", "label": "Patient ID / Passport Copy", "fieldType": "FILE", "isMandatory": true, "displayOrder": 50, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_6", "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 10485760, "validation": "Required()" },
      { "name": "referralLetter", "label": "Referral Letter", "fieldType": "FILE", "displayOrder": 51, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_6", "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 10485760 },
      { "name": "consentForm", "label": "Signed Admission Consent", "fieldType": "FILE", "isMandatory": true, "displayOrder": 52, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_6", "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 10485760, "validation": "Required()" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Admissions Officer", "approverType": "ROLE", "roleName": "ADMISSIONS_OFFICER", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Charge Nurse", "approverType": "ROLE", "roleName": "CHARGE_NURSE", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 3, "name": "Attending Physician", "approverType": "ROLE", "roleName": "ATTENDING_PHYSICIAN", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
