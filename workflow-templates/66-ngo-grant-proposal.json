{
  "_comment": "Grant Proposal / Funding Application — NGO submits a concept / full proposal to a donor for funding.",
  "name": "Grant Proposal / Funding Application",
  "code": "GPA",
  "description": "NGO submits a concept note or full proposal to a donor for programme / project funding.",
  "icon": "volunteer_activism",
  "displayOrder": 66,
  "requiresApproval": true,
  "commentsMandatoryOnReject": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "NGO",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{grantRef} - @{projectTitle} (@{amountRequested})",
  "reminderEnabled": true,
  "reminderFrequencyHours": 24,
  "reminderMaxCount": 3,
  "reminderStartAfterHours": 24,
  "escalationEnabled": true,
  "escalationAfterHours": 72,
  "escalationAction": "NOTIFY_ADMIN",

  "forms": [{
    "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Opportunity", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Project", "displayOrder": 1, "icon": "lightbulb" },
      { "id": "temp_screen_3", "title": "Budget", "displayOrder": 2, "icon": "payments" },
      { "id": "temp_screen_4", "title": "Documents", "displayOrder": 3, "icon": "attach_file" },
      { "id": "temp_screen_5", "title": "Review & Submit", "displayOrder": 4, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Opportunity", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Donor", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Project Info", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Implementation", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Budget Lines", "displayOrder": 4, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_6", "title": "Co-Funding", "displayOrder": 5, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_7", "title": "Documents", "displayOrder": 6, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_4" }
    ],
    "fields": [
      { "name": "grantRef", "label": "Proposal Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"GPA-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "submissionDeadline", "label": "Donor Submission Deadline", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "validation": "Required() AND DateAfter(\"today\", \"Deadline must be future\")" },
      { "name": "callType", "label": "Call Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [
          { "value": "CONCEPT", "label": "Concept Note", "displayOrder": 0 },
          { "value": "FULL_PROPOSAL", "label": "Full Proposal", "displayOrder": 1 },
          { "value": "UNSOLICITED", "label": "Unsolicited Proposal", "displayOrder": 2 },
          { "value": "NO_COST_EXTENSION", "label": "No-Cost Extension", "displayOrder": 3 }
        ], "validation": "Required()" },
      { "name": "projectLead", "label": "Project Lead", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "donorName", "label": "Donor", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "donorCategory", "label": "Donor Category", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [
          { "value": "BILATERAL", "label": "Bilateral (Gov)", "displayOrder": 0 },
          { "value": "MULTILATERAL", "label": "Multilateral (UN, WB)", "displayOrder": 1 },
          { "value": "FOUNDATION", "label": "Foundation", "displayOrder": 2 },
          { "value": "CORPORATE", "label": "Corporate", "displayOrder": 3 },
          { "value": "INDIVIDUAL", "label": "Individual", "displayOrder": 4 }
        ], "validation": "Required()" },
      { "name": "projectTitle", "label": "Project Title", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 20, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Required() AND MinLength(10)" },
      { "name": "thematicArea", "label": "Thematic Area", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [
          { "value": "HEALTH", "label": "Health", "displayOrder": 0 },
          { "value": "EDUCATION", "label": "Education", "displayOrder": 1 },
          { "value": "WASH", "label": "Water / Sanitation", "displayOrder": 2 },
          { "value": "LIVELIHOODS", "label": "Livelihoods / Economic", "displayOrder": 3 },
          { "value": "GENDER", "label": "Gender & Inclusion", "displayOrder": 4 },
          { "value": "GOVERNANCE", "label": "Governance / Rights", "displayOrder": 5 },
          { "value": "ENVIRONMENT", "label": "Environment / Climate", "displayOrder": 6 },
          { "value": "HUMANITARIAN", "label": "Humanitarian / Relief", "displayOrder": 7 },
          { "value": "OTHER", "label": "Other", "displayOrder": 8 }
        ], "validation": "Required()" },
      { "name": "goal", "label": "Project Goal", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 22, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Required() AND MinLength(30)" },
      { "name": "objectives", "label": "Specific Objectives", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 23, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Required() AND MinLength(30)" },
      { "name": "startDate", "label": "Project Start", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "validation": "Required()" },
      { "name": "durationMonths", "label": "Duration (months)", "fieldType": "NUMBER", "isMandatory": true, "defaultValue": "12", "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "validation": "Required() AND Min(1) AND Max(120)" },
      { "name": "targetLocations", "label": "Target Locations / Countries", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "validation": "Required()" },
      { "name": "targetBeneficiaries", "label": "Direct Beneficiaries", "fieldType": "NUMBER", "isMandatory": true, "inSummary": true, "displayOrder": 33, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "validation": "Required() AND Min(0)" },
      { "name": "partners", "label": "Implementing Partners", "fieldType": "TEXTAREA", "displayOrder": 34, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "budgetLines", "label": "Budget Lines", "fieldType": "TABLE", "isMandatory": true, "displayOrder": 40, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5",
        "tableMinRows": 1, "tableMaxRows": 100, "tableStriped": true, "tableBordered": true,
        "tableColumns": "[{\"name\":\"category\",\"label\":\"Category\",\"type\":\"SELECT\",\"width\":160,\"required\":true,\"options\":[\"Personnel\",\"Travel\",\"Equipment\",\"Supplies\",\"Training\",\"Sub-grants\",\"Admin\",\"Overhead\"]},{\"name\":\"description\",\"label\":\"Description\",\"type\":\"TEXT\",\"width\":300,\"required\":true},{\"name\":\"amount\",\"label\":\"Amount\",\"type\":\"NUMBER\",\"width\":140,\"required\":true}]",
        "validation": "MinRows(1, \"Budget must have at least one line\")" },
      { "name": "amountRequested", "label": "Total Amount Requested", "fieldType": "CURRENCY", "isReadonly": true, "isLimited": true, "inSummary": true, "displayOrder": 41, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5",
        "defaultValue": "SUM_COLUMN(\"budgetLines\", \"amount\")" },
      { "name": "coFundingRequired", "label": "Co-Funding / Match Required?", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 50, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6" },
      { "name": "coFundingAmount", "label": "Co-Funding Amount", "fieldType": "CURRENCY", "defaultValue": "0", "inSummary": true, "displayOrder": 51, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6",
        "visibilityExpression": "@{coFundingRequired} == true",
        "validation": "Min(0)" },
      { "name": "coFundingSource", "label": "Co-Funding Source", "fieldType": "TEXT", "displayOrder": 52, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6",
        "visibilityExpression": "@{coFundingRequired} == true" },
      { "name": "proposalDoc", "label": "Proposal / Concept Note", "fieldType": "FILE", "isMandatory": true, "displayOrder": 60, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_7",
        "allowedFileTypes": "pdf,doc,docx", "maxFileSize": 20971520, "validation": "Required()" },
      { "name": "budgetFile", "label": "Detailed Budget", "fieldType": "FILE", "isMandatory": true, "displayOrder": 61, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_7",
        "allowedFileTypes": "xls,xlsx,pdf", "maxFileSize": 10485760, "validation": "Required()" },
      { "name": "logFrame", "label": "LogFrame / Results Matrix", "fieldType": "FILE", "displayOrder": 62, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_7",
        "allowedFileTypes": "xls,xlsx,pdf,doc,docx", "maxFileSize": 10485760 },
      { "name": "dueDiligenceDocs", "label": "NGO Due Diligence Package", "fieldType": "FILE", "multiple": true, "displayOrder": 63, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_7",
        "allowedFileTypes": "pdf,doc,docx,xlsx", "maxFileSize": 10485760, "maxFiles": 10 }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Programme Manager", "approverType": "ROLE", "roleName": "PROGRAMME_MANAGER", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Finance Director", "approverType": "ROLE", "roleName": "FINANCE_DIRECTOR", "amountLimit": 500000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Executive Director / CEO", "approverType": "ROLE", "roleName": "EXECUTIVE_DIRECTOR", "amountLimit": 5000000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 4, "name": "Board", "approverType": "ROLE", "roleName": "BOARD", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
