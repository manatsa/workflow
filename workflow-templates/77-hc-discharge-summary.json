{
  "_comment": "Discharge Summary — finalise patient discharge including clinical summary, medications and follow-up.",
  "name": "Discharge Summary",
  "code": "HDS",
  "description": "Finalise patient discharge with clinical summary, medications, billing clearance and follow-up plan.",
  "icon": "logout",
  "displayOrder": 77,
  "requiresApproval": true,
  "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "HEALTHCARE",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{dischargeRef} - @{patientName} (@{dischargeDate})",
  "reminderEnabled": true, "reminderFrequencyHours": 4, "reminderMaxCount": 4, "reminderStartAfterHours": 2,
  "escalationEnabled": true, "escalationAfterHours": 24, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Patient & Stay", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Clinical Summary", "displayOrder": 1, "icon": "description" },
      { "id": "temp_screen_3", "title": "Discharge Medications & Follow-Up", "displayOrder": 2, "icon": "medication" },
      { "id": "temp_screen_4", "title": "Billing & Clearance", "displayOrder": 3, "icon": "payments" },
      { "id": "temp_screen_5", "title": "Documents", "displayOrder": 4, "icon": "attach_file" },
      { "id": "temp_screen_6", "title": "Review", "displayOrder": 5, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference & Patient", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Stay Details", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Clinical", "displayOrder": 2, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Discharge Medications", "displayOrder": 3, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_5", "title": "Follow-Up", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_6", "title": "Bill", "displayOrder": 5, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_4" },
      { "id": "temp_grp_7", "title": "Documents", "displayOrder": 6, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_5" }
    ],
    "fields": [
      { "name": "dischargeRef", "label": "Discharge Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"HDS-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "admissionRef", "label": "Admission Reference", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "patientMrn", "label": "Patient MRN", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()" },
      { "name": "patientName", "label": "Patient Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()" },
      { "name": "admissionDate", "label": "Admission Date", "fieldType": "DATE", "isMandatory": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "dischargeDate", "label": "Discharge Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "lengthOfStayDays", "label": "Length of Stay (days)", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND Min(0)" },
      { "name": "dischargeType", "label": "Discharge Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "HOME", "label": "Home", "displayOrder": 0 }, { "value": "HOME_WITH_CARE", "label": "Home with Home Care", "displayOrder": 1 }, { "value": "TRANSFER", "label": "Transfer to Other Facility", "displayOrder": 2 }, { "value": "DAMA", "label": "Against Medical Advice", "displayOrder": 3 }, { "value": "DECEASED", "label": "Deceased", "displayOrder": 4 } ], "validation": "Required()" },
      { "name": "admittingDiagnosis", "label": "Admitting Diagnosis", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 20, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "finalDiagnosis", "label": "Final Diagnosis", "fieldType": "TEXTAREA", "isMandatory": true, "inSummary": true, "displayOrder": 21, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required() AND MinLength(15)" },
      { "name": "procedures", "label": "Procedures / Operations Performed", "fieldType": "TEXTAREA", "displayOrder": 22, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3" },
      { "name": "hospitalCourse", "label": "Hospital Course Summary", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 23, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required() AND MinLength(50)" },
      { "name": "conditionAtDischarge", "label": "Condition at Discharge", "fieldType": "SELECT", "isMandatory": true, "defaultValue": "STABLE", "inSummary": true, "displayOrder": 24, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "RECOVERED", "label": "Recovered", "displayOrder": 0 }, { "value": "IMPROVED", "label": "Improved", "displayOrder": 1 }, { "value": "STABLE", "label": "Stable", "displayOrder": 2 }, { "value": "UNCHANGED", "label": "Unchanged", "displayOrder": 3 }, { "value": "WORSE", "label": "Worse", "displayOrder": 4 } ], "validation": "Required()" },
      { "name": "dischargeMeds", "label": "Discharge Medications", "fieldType": "TABLE", "displayOrder": 30, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "tableMinRows": 0, "tableMaxRows": 30, "tableStriped": true, "tableBordered": true,
        "tableColumns": "[{\"name\":\"drug\",\"label\":\"Drug\",\"type\":\"TEXT\",\"width\":220,\"required\":true},{\"name\":\"dose\",\"label\":\"Dose\",\"type\":\"TEXT\",\"width\":140,\"required\":true},{\"name\":\"frequency\",\"label\":\"Frequency\",\"type\":\"TEXT\",\"width\":160,\"required\":true},{\"name\":\"durationDays\",\"label\":\"Duration (days)\",\"type\":\"NUMBER\",\"width\":140,\"required\":true}]" },
      { "name": "followUpDate", "label": "Follow-Up Appointment", "fieldType": "DATE", "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5" },
      { "name": "followUpClinic", "label": "Follow-Up Clinic / Physician", "fieldType": "TEXT", "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5" },
      { "name": "patientEducation", "label": "Patient Education / Warning Signs", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 42, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "Required() AND MinLength(20)" },
      { "name": "totalCharges", "label": "Total Charges", "fieldType": "CURRENCY", "isMandatory": true, "isLimited": true, "inSummary": true, "displayOrder": 50, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_6", "validation": "Required() AND Min(0)" },
      { "name": "amountPaid", "label": "Amount Paid / Claimed", "fieldType": "CURRENCY", "isMandatory": true, "defaultValue": "0", "displayOrder": 51, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_6", "validation": "Required() AND Min(0)" },
      { "name": "balanceOutstanding", "label": "Balance Outstanding", "fieldType": "CURRENCY", "isReadonly": true, "inSummary": true, "displayOrder": 52, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_6",
        "defaultValue": "SUBTRACT(@{totalCharges}, @{amountPaid})" },
      { "name": "billingCleared", "label": "Billing Cleared", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 53, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_6",
        "validation": "ValidWhen(@{billingCleared} == true, \"Billing must be cleared before discharge\")" },
      { "name": "dischargeSummary", "label": "Discharge Summary Document", "fieldType": "FILE", "isMandatory": true, "displayOrder": 60, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_7", "allowedFileTypes": "pdf,doc,docx", "maxFileSize": 10485760, "validation": "Required()" },
      { "name": "dischargePrescription", "label": "Discharge Prescription", "fieldType": "FILE", "displayOrder": 61, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_7", "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 10485760 },
      { "name": "sickCertificate", "label": "Sick Leave Certificate (if applicable)", "fieldType": "FILE", "displayOrder": 62, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_7", "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 10485760 }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Attending Physician", "approverType": "ROLE", "roleName": "ATTENDING_PHYSICIAN", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Nurse Manager / Ward Sister", "approverType": "ROLE", "roleName": "NURSE_MANAGER", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 3, "name": "Billing / Finance Officer", "approverType": "ROLE", "roleName": "BILLING_OFFICER", "amountLimit": null, "canEscalate": false, "requireComment": false, "emailNotification": true }
  ]
}
