{
  "_comment": "Donor Report — periodic narrative + financial report to a donor on an active grant.",
  "name": "Donor Report",
  "code": "NDR",
  "description": "Periodic narrative and financial report to a donor on an active grant / programme.",
  "icon": "summarize",
  "displayOrder": 68,
  "requiresApproval": true,
  "commentsMandatoryOnReject": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "NGO",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{reportRef} - @{projectTitle} (@{reportPeriod})",
  "reminderEnabled": true,
  "reminderFrequencyHours": 24,
  "reminderMaxCount": 3,
  "reminderStartAfterHours": 24,
  "escalationEnabled": true,
  "escalationAfterHours": 72,
  "escalationAction": "NOTIFY_ADMIN",

  "forms": [{
    "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Reference", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Narrative", "displayOrder": 1, "icon": "article" },
      { "id": "temp_screen_3", "title": "Financial", "displayOrder": 2, "icon": "payments" },
      { "id": "temp_screen_4", "title": "Risks & Next Steps", "displayOrder": 3, "icon": "warning" },
      { "id": "temp_screen_5", "title": "Documents", "displayOrder": 4, "icon": "attach_file" },
      { "id": "temp_screen_6", "title": "Review & Submit", "displayOrder": 5, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Grant & Period", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Achievements", "displayOrder": 2, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Indicators", "displayOrder": 3, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Financial Summary", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_6", "title": "Variance Explanation", "displayOrder": 5, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_7", "title": "Risks & Next Steps", "displayOrder": 6, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_4" },
      { "id": "temp_grp_8", "title": "Documents", "displayOrder": 7, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_5" }
    ],
    "fields": [
      { "name": "reportRef", "label": "Report Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"NDR-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "preparedDate", "label": "Prepared Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "preparedBy", "label": "Prepared By", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "reportType", "label": "Report Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [
          { "value": "MONTHLY", "label": "Monthly", "displayOrder": 0 },
          { "value": "QUARTERLY", "label": "Quarterly", "displayOrder": 1 },
          { "value": "SEMI_ANNUAL", "label": "Semi-Annual", "displayOrder": 2 },
          { "value": "ANNUAL", "label": "Annual", "displayOrder": 3 },
          { "value": "FINAL", "label": "Final / End-of-Grant", "displayOrder": 4 }
        ], "validation": "Required()" },
      { "name": "grantRef", "label": "Grant / Contract Reference", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "donorName", "label": "Donor", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "projectTitle", "label": "Project Title", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "reportPeriod", "label": "Report Period (e.g. Q3 2026)", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "dueDate", "label": "Donor Due Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 14, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "summary", "label": "Executive Summary", "fieldType": "TEXTAREA", "isMandatory": true, "inSummary": true, "displayOrder": 20, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Required() AND MinLength(50)" },
      { "name": "achievements", "label": "Key Achievements", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 21, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Required() AND MinLength(50)" },
      { "name": "challenges", "label": "Challenges & Mitigation", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 22, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Required() AND MinLength(30)" },
      { "name": "indicators", "label": "Indicator Performance", "fieldType": "TABLE", "isMandatory": true, "displayOrder": 30, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "tableMinRows": 1, "tableMaxRows": 50, "tableStriped": true, "tableBordered": true,
        "tableColumns": "[{\"name\":\"indicator\",\"label\":\"Indicator\",\"type\":\"TEXT\",\"width\":280,\"required\":true},{\"name\":\"target\",\"label\":\"Target\",\"type\":\"NUMBER\",\"width\":110,\"required\":true},{\"name\":\"actual\",\"label\":\"Actual\",\"type\":\"NUMBER\",\"width\":110,\"required\":true},{\"name\":\"percent\",\"label\":\"%\",\"type\":\"NUMBER\",\"width\":80},{\"name\":\"note\",\"label\":\"Note\",\"type\":\"TEXT\",\"width\":220}]" },
      { "name": "grantAmount", "label": "Total Grant Budget", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5",
        "validation": "Required() AND Min(0)" },
      { "name": "disbursedToDate", "label": "Disbursed to Date", "fieldType": "CURRENCY", "isMandatory": true, "defaultValue": "0", "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5",
        "validation": "Required() AND Min(0)" },
      { "name": "periodBudget", "label": "Period Budget", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5",
        "validation": "Required() AND Min(0)" },
      { "name": "periodSpent", "label": "Period Actual Spend", "fieldType": "CURRENCY", "isMandatory": true, "isLimited": true, "inSummary": true, "displayOrder": 43, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5",
        "validation": "Required() AND Min(0)" },
      { "name": "burnRatePercent", "label": "Burn Rate %", "fieldType": "NUMBER", "isReadonly": true, "inSummary": true, "displayOrder": 44, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5",
        "defaultValue": "PERCENTAGE(@{periodSpent}, @{periodBudget})" },
      { "name": "variancePercent", "label": "Variance %", "fieldType": "NUMBER", "isReadonly": true, "displayOrder": 45, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5",
        "defaultValue": "PERCENTAGE(SUBTRACT(@{periodSpent}, @{periodBudget}), @{periodBudget})" },
      { "name": "varianceExplanation", "label": "Variance Explanation", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 50, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6",
        "validation": "Required() AND MinLength(20)" },
      { "name": "risksIdentified", "label": "Risks / Issues Identified", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 60, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_7",
        "validation": "Required() AND MinLength(20)" },
      { "name": "nextSteps", "label": "Next Period Priorities", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 61, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_7",
        "validation": "Required() AND MinLength(20)" },
      { "name": "narrativeReport", "label": "Narrative Report", "fieldType": "FILE", "isMandatory": true, "displayOrder": 70, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_8",
        "allowedFileTypes": "pdf,doc,docx", "maxFileSize": 20971520, "validation": "Required()" },
      { "name": "financialReport", "label": "Financial Report", "fieldType": "FILE", "isMandatory": true, "displayOrder": 71, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_8",
        "allowedFileTypes": "xls,xlsx,pdf", "maxFileSize": 10485760, "validation": "Required()" },
      { "name": "evidencePack", "label": "Evidence / MEAL Pack", "fieldType": "FILE", "multiple": true, "displayOrder": 72, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_8",
        "allowedFileTypes": "pdf,doc,docx,xlsx,jpg,jpeg,png", "maxFileSize": 20971520, "maxFiles": 20 }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Programme Manager", "approverType": "ROLE", "roleName": "PROGRAMME_MANAGER", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Finance Director", "approverType": "ROLE", "roleName": "FINANCE_DIRECTOR", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Executive Director", "approverType": "ROLE", "roleName": "EXECUTIVE_DIRECTOR", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
