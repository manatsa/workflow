{
  "_comment": "Garment QC / Final Inspection — AQL-based final inspection before shipment.",
  "name": "Garment QC Final Inspection",
  "code": "CQI",
  "description": "AQL-based final inspection of a garment production lot before shipment.",
  "icon": "checklist",
  "displayOrder": 105,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "NON_FINANCIAL",
  "industryCode": "CLOTHING",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{qcRef} - @{poRef} (@{result})",
  "reminderEnabled": true, "reminderFrequencyHours": 4, "reminderMaxCount": 4, "reminderStartAfterHours": 2,
  "escalationEnabled": true, "escalationAfterHours": 24, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Inspection", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Defects & Result", "displayOrder": 1, "icon": "warning" },
      { "id": "temp_screen_3", "title": "Review", "displayOrder": 2, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Order & Lot", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "AQL Sampling", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_4", "title": "Defects Found", "displayOrder": 3, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Result", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" }
    ],
    "fields": [
      { "name": "qcRef", "label": "QC Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"CQI-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "inspectionDate", "label": "Inspection Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "inspector", "label": "Inspector", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "factory", "label": "Factory", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()" },
      { "name": "poRef", "label": "Production Order Ref", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "styleCode", "label": "Style Code", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "totalQty", "label": "Total Lot Qty", "fieldType": "NUMBER", "isMandatory": true, "inSummary": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND Min(1)" },
      { "name": "packedQty", "label": "Packed Qty", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND Min(0)" },
      { "name": "aqlLevel", "label": "AQL Level", "fieldType": "SELECT", "isMandatory": true, "defaultValue": "2_5", "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "1_5", "label": "1.5 (Tight)", "displayOrder": 0 }, { "value": "2_5", "label": "2.5 (Standard)", "displayOrder": 1 }, { "value": "4_0", "label": "4.0 (Loose)", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "sampleSize", "label": "Sample Size Inspected", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required() AND Min(1)" },
      { "name": "majorAllowed", "label": "Major Defects - Allowed", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required() AND Min(0)" },
      { "name": "minorAllowed", "label": "Minor Defects - Allowed", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required() AND Min(0)" },
      { "name": "defects", "label": "Defects Found", "fieldType": "TABLE", "displayOrder": 30, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "tableMinRows": 0, "tableMaxRows": 200, "tableStriped": true, "tableBordered": true,
        "tableColumns": "[{\"name\":\"defectCode\",\"label\":\"Defect\",\"type\":\"TEXT\",\"width\":260,\"required\":true},{\"name\":\"severity\",\"label\":\"Severity\",\"type\":\"SELECT\",\"width\":120,\"required\":true,\"options\":[\"CRITICAL\",\"MAJOR\",\"MINOR\"]},{\"name\":\"count\",\"label\":\"Count\",\"type\":\"NUMBER\",\"width\":100,\"required\":true}]" },
      { "name": "criticalCount", "label": "Critical Defects", "fieldType": "NUMBER", "isMandatory": true, "defaultValue": "0", "inSummary": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "Required() AND Min(0)" },
      { "name": "majorCount", "label": "Major Defects", "fieldType": "NUMBER", "isMandatory": true, "defaultValue": "0", "inSummary": true, "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "Required() AND Min(0)" },
      { "name": "minorCount", "label": "Minor Defects", "fieldType": "NUMBER", "isMandatory": true, "defaultValue": "0", "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "Required() AND Min(0)" },
      { "name": "result", "label": "Result", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 43, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5",
        "options": [ { "value": "PASS", "label": "Pass", "displayOrder": 0 }, { "value": "FAIL", "label": "Fail", "displayOrder": 1 }, { "value": "RE_INSPECT", "label": "Re-Inspect", "displayOrder": 2 }, { "value": "ACCEPT_WITH_DEV", "label": "Accept with Deviation", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "inspectorNotes", "label": "Inspector Notes", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 44, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "Required() AND MinLength(20)" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "QC Inspector", "approverType": "ROLE", "roleName": "QC_INSPECTOR", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "QC Manager", "approverType": "ROLE", "roleName": "QC_MANAGER", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
