{
  "_comment": "Benevolence / Welfare Request — apply for financial assistance from the church benevolence fund.",
  "name": "Benevolence Request",
  "code": "BEN",
  "description": "Submit a request for financial assistance from the church benevolence or welfare fund for members or community in need.",
  "icon": "volunteer_activism",
  "displayOrder": 291,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "RELIGIOUS",
  "workflowTypeCode": "FINANCE",
  "titleTemplate": "@{benRef} - @{applicantName} (@{assistanceType})",
  "reminderEnabled": true, "reminderFrequencyHours": 12, "reminderMaxCount": 4, "reminderStartAfterHours": 12,
  "escalationEnabled": true, "escalationAfterHours": 48, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Applicant & Need", "displayOrder": 0, "icon": "person" },
      { "id": "temp_screen_2", "title": "Assessment & Approval", "displayOrder": 1, "icon": "assessment" },
      { "id": "temp_screen_3", "title": "Review", "displayOrder": 2, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Applicant Details", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Need Description", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_4", "title": "Assessment & Payment", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Attachments", "displayOrder": 4, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_2" }
    ],
    "fields": [
      { "name": "benRef", "label": "Request Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"BEN-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "requestDate", "label": "Request Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "applicantName", "label": "Applicant Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "applicantPhone", "label": "Phone", "fieldType": "PHONE", "isMandatory": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "memberStatus", "label": "Member Status", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 4, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "ACTIVE_MEMBER", "label": "Active Member", "displayOrder": 0 }, { "value": "INACTIVE_MEMBER", "label": "Inactive Member", "displayOrder": 1 }, { "value": "VISITOR", "label": "Visitor / Attendee", "displayOrder": 2 }, { "value": "COMMUNITY", "label": "Community (Non-Member)", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "householdSize", "label": "Household Size", "fieldType": "NUMBER", "displayOrder": 5, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2" },
      { "name": "assistanceType", "label": "Assistance Type", "fieldType": "SELECT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "RENT", "label": "Rent / Housing", "displayOrder": 0 }, { "value": "UTILITIES", "label": "Utilities (Electric, Water)", "displayOrder": 1 }, { "value": "FOOD", "label": "Food / Groceries", "displayOrder": 2 }, { "value": "MEDICAL", "label": "Medical Bills", "displayOrder": 3 }, { "value": "FUNERAL", "label": "Funeral Costs", "displayOrder": 4 }, { "value": "EDUCATION", "label": "School Fees / Education", "displayOrder": 5 }, { "value": "TRANSPORT", "label": "Transport", "displayOrder": 6 }, { "value": "OTHER", "label": "Other", "displayOrder": 7 } ], "validation": "Required()" },
      { "name": "amountRequested", "label": "Amount Requested", "fieldType": "CURRENCY", "isMandatory": true, "isLimited": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required() AND Min(1)" },
      { "name": "needDescription", "label": "Description of Need", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 12, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "previousAssistance", "label": "Previous Assistance Received", "fieldType": "YES_NO", "defaultValue": "false", "inSummary": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3" },
      { "name": "previousDetails", "label": "Previous Assistance Details", "fieldType": "TEXTAREA", "displayOrder": 14, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "visibilityExpression": "@{previousAssistance} == true" },
      { "name": "amountApproved", "label": "Amount Approved", "fieldType": "CURRENCY", "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "paymentMethod", "label": "Payment Method", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "options": [ { "value": "CASH", "label": "Cash", "displayOrder": 0 }, { "value": "BANK_TRANSFER", "label": "Bank Transfer", "displayOrder": 1 }, { "value": "DIRECT_PAYMENT", "label": "Direct Payment to Provider", "displayOrder": 2 }, { "value": "VOUCHER", "label": "Voucher / Gift Card", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "payeeName", "label": "Payee Name (if direct)", "fieldType": "TEXT", "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "followUpRequired", "label": "Follow-Up Required", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "assessmentNotes", "label": "Assessment Notes", "fieldType": "TEXTAREA", "displayOrder": 24, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "supportingDocs", "label": "Supporting Documents (bills, quotes, etc.)", "fieldType": "FILE", "displayOrder": 30, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "allowedFileTypes": "pdf,jpg,jpeg,png,doc,docx", "maxFileSize": 10485760 }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Welfare / Deacons Committee", "approverType": "ROLE", "roleName": "WELFARE_COMMITTEE", "amountLimit": 2000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 2, "name": "Church Administrator", "approverType": "ROLE", "roleName": "ADMINISTRATOR", "amountLimit": 10000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Senior Pastor / Board", "approverType": "ROLE", "roleName": "SENIOR_PASTOR", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
