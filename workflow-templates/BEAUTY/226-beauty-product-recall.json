{
  "_comment": "Product Safety Recall — initiate and manage a cosmetic product recall due to safety concerns.",
  "name": "Product Safety Recall",
  "code": "PSR",
  "description": "Initiate, investigate, and execute a cosmetic product recall including risk classification, affected batch identification, customer notification, and corrective actions.",
  "icon": "warning",
  "displayOrder": 226,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "NON_FINANCIAL",
  "industryCode": "BEAUTY",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{recallRef} - @{productName} - @{riskClassification}",
  "reminderEnabled": true, "reminderFrequencyHours": 8, "reminderMaxCount": 3, "reminderStartAfterHours": 8,
  "escalationEnabled": true, "escalationAfterHours": 24, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Product & Incident", "displayOrder": 0, "icon": "warning" },
      { "id": "temp_screen_2", "title": "Risk Assessment", "displayOrder": 1, "icon": "health_and_safety" },
      { "id": "temp_screen_3", "title": "Recall Actions", "displayOrder": 2, "icon": "assignment" },
      { "id": "temp_screen_4", "title": "Review", "displayOrder": 3, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Product Identification", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Incident Details", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_4", "title": "Risk Classification", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Affected Scope", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_6", "title": "Recall Plan", "displayOrder": 5, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_7", "title": "Documents", "displayOrder": 6, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_3" }
    ],
    "fields": [
      { "name": "recallRef", "label": "Recall Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"PSR-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "reportDate", "label": "Report Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "productName", "label": "Product Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND MinLength(2)" },
      { "name": "productSku", "label": "Product SKU / Code", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "batchNumbers", "label": "Affected Batch Numbers", "fieldType": "TEXTAREA", "isMandatory": true, "inSummary": true, "displayOrder": 4, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "manufacturingDate", "label": "Manufacturing Date Range", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 5, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "incidentType", "label": "Incident Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 6, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "ALLERGIC_REACTION", "label": "Allergic Reaction", "displayOrder": 0 }, { "value": "CONTAMINATION", "label": "Microbial Contamination", "displayOrder": 1 }, { "value": "WRONG_LABEL", "label": "Incorrect Labelling", "displayOrder": 2 }, { "value": "BANNED_INGREDIENT", "label": "Banned Ingredient Detected", "displayOrder": 3 }, { "value": "PACKAGING_DEFECT", "label": "Packaging Defect", "displayOrder": 4 }, { "value": "STABILITY_FAILURE", "label": "Stability Failure", "displayOrder": 5 }, { "value": "OTHER", "label": "Other", "displayOrder": 6 } ], "validation": "Required()" },
      { "name": "incidentDescription", "label": "Incident Description", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 7, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required() AND MinLength(20)" },
      { "name": "complaintsReceived", "label": "Number of Complaints Received", "fieldType": "NUMBER", "isMandatory": true, "inSummary": true, "displayOrder": 8, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required() AND Min(0)" },
      { "name": "riskClassification", "label": "Risk Classification", "fieldType": "SELECT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "options": [ { "value": "CLASS_I", "label": "Class I - Serious Health Hazard", "displayOrder": 0 }, { "value": "CLASS_II", "label": "Class II - Temporary / Reversible", "displayOrder": 1 }, { "value": "CLASS_III", "label": "Class III - Low Risk / Non-Conformance", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "healthImpact", "label": "Potential Health Impact", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 11, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND MinLength(10)" },
      { "name": "unitsDistributed", "label": "Units Distributed", "fieldType": "NUMBER", "isMandatory": true, "inSummary": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "Required() AND Min(1)" },
      { "name": "distributionChannels", "label": "Distribution Channels Affected", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 13, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "Required()" },
      { "name": "regionsAffected", "label": "Regions Affected", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 14, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "Required()" },
      { "name": "recallStrategy", "label": "Recall Strategy", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6",
        "options": [ { "value": "VOLUNTARY", "label": "Voluntary Recall", "displayOrder": 0 }, { "value": "MANDATORY", "label": "Mandatory (Regulator Ordered)", "displayOrder": 1 }, { "value": "MARKET_WITHDRAWAL", "label": "Market Withdrawal", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "correctiveAction", "label": "Corrective Action Plan", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 21, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "validation": "Required() AND MinLength(20)" },
      { "name": "customerNotificationPlan", "label": "Customer Notification Plan", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 22, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "validation": "Required() AND MinLength(10)" },
      { "name": "regulatoryNotified", "label": "Regulatory Authority Notified", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "validation": "ValidWhen(@{regulatoryNotified} == true, \"Regulatory authority must be notified for all recalls\")" },
      { "name": "supportingEvidence", "label": "Supporting Evidence / Lab Reports", "fieldType": "FILE", "isMandatory": true, "displayOrder": 30, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_7", "allowedFileTypes": "pdf,doc,docx,xls,xlsx,jpg,jpeg,png", "maxFileSize": 10485760, "validation": "Required()" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Quality Assurance Manager", "approverType": "ROLE", "roleName": "QA_MANAGER", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 2, "name": "Regulatory Affairs Director", "approverType": "ROLE", "roleName": "REGULATORY_DIRECTOR", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Chief Executive Officer", "approverType": "ROLE", "roleName": "CEO", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}