{
  "_comment": "Cosmetic Product Formulation Approval — approve new or reformulated cosmetic products before manufacturing.",
  "name": "Cosmetic Product Formulation Approval",
  "code": "CPF",
  "description": "Review and approve cosmetic product formulations including ingredient safety, stability testing, regulatory compliance, and packaging specifications.",
  "icon": "science",
  "displayOrder": 224,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "NON_FINANCIAL",
  "industryCode": "BEAUTY",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{formulationRef} - @{productName}",
  "reminderEnabled": true, "reminderFrequencyHours": 48, "reminderMaxCount": 3, "reminderStartAfterHours": 48,
  "escalationEnabled": true, "escalationAfterHours": 120, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Product Details", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Formulation & Ingredients", "displayOrder": 1, "icon": "science" },
      { "id": "temp_screen_3", "title": "Testing & Compliance", "displayOrder": 2, "icon": "verified_user" },
      { "id": "temp_screen_4", "title": "Review", "displayOrder": 3, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Product Information", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Formulation", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Ingredient List", "displayOrder": 3, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Safety & Testing", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_6", "title": "Regulatory & Documents", "displayOrder": 5, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" }
    ],
    "fields": [
      { "name": "formulationRef", "label": "Formulation Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"CPF-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "submissionDate", "label": "Submission Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "productName", "label": "Product Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND MinLength(3)" },
      { "name": "productCategory", "label": "Product Category", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "SKINCARE", "label": "Skincare", "displayOrder": 0 }, { "value": "MAKEUP", "label": "Makeup / Colour Cosmetics", "displayOrder": 1 }, { "value": "HAIRCARE", "label": "Haircare", "displayOrder": 2 }, { "value": "FRAGRANCE", "label": "Fragrance", "displayOrder": 3 }, { "value": "BODY_CARE", "label": "Body Care", "displayOrder": 4 }, { "value": "SUN_CARE", "label": "Sun Care", "displayOrder": 5 }, { "value": "ORAL_CARE", "label": "Oral Care", "displayOrder": 6 } ], "validation": "Required()" },
      { "name": "formulationType", "label": "Formulation Type", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 4, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "NEW", "label": "New Formulation", "displayOrder": 0 }, { "value": "REFORMULATION", "label": "Reformulation", "displayOrder": 1 }, { "value": "LINE_EXTENSION", "label": "Line Extension", "displayOrder": 2 }, { "value": "REGULATORY_UPDATE", "label": "Regulatory Update", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "targetMarket", "label": "Target Market", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 5, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "MASS", "label": "Mass Market", "displayOrder": 0 }, { "value": "PRESTIGE", "label": "Prestige / Premium", "displayOrder": 1 }, { "value": "PROFESSIONAL", "label": "Professional", "displayOrder": 2 }, { "value": "ORGANIC", "label": "Organic / Natural", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "productDescription", "label": "Product Description & Claims", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 6, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND MinLength(20)" },
      { "name": "formulaVersion", "label": "Formula Version", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "phLevel", "label": "pH Level", "fieldType": "NUMBER", "isMandatory": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required() AND Min(0)" },
      { "name": "viscosity", "label": "Viscosity (cP)", "fieldType": "NUMBER", "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3" },
      { "name": "shelfLifeMonths", "label": "Shelf Life (months)", "fieldType": "NUMBER", "isMandatory": true, "inSummary": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required() AND Min(1)" },
      { "name": "ingredients", "label": "INCI Ingredient List", "fieldType": "TABLE", "isMandatory": true, "displayOrder": 14, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "tableMinRows": 1, "tableMaxRows": 50, "tableStriped": true, "tableBordered": true,
        "tableColumns": "[{\"name\":\"inciName\",\"label\":\"INCI Name\",\"type\":\"TEXT\",\"width\":220,\"required\":true},{\"name\":\"tradeName\",\"label\":\"Trade Name\",\"type\":\"TEXT\",\"width\":160},{\"name\":\"supplier\",\"label\":\"Supplier\",\"type\":\"TEXT\",\"width\":140},{\"name\":\"percentage\",\"label\":\"%\",\"type\":\"NUMBER\",\"width\":80,\"required\":true},{\"name\":\"function\",\"label\":\"Function\",\"type\":\"TEXT\",\"width\":140}]", "validation": "MinRows(1, \"At least one ingredient required\")" },
      { "name": "containsAllergens", "label": "Contains Known Allergens", "fieldType": "YES_NO", "defaultValue": "false", "inSummary": true, "displayOrder": 15, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3" },
      { "name": "allergenDetails", "label": "Allergen Details", "fieldType": "TEXTAREA", "displayOrder": 16, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3" },
      { "name": "stabilityTestPassed", "label": "Stability Test Passed", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{stabilityTestPassed} == true, \"Stability test must be passed before approval\")" },
      { "name": "microTestPassed", "label": "Microbiological Test Passed", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{microTestPassed} == true, \"Microbiological test must be passed\")" },
      { "name": "dermatologistTested", "label": "Dermatologically Tested", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{dermatologistTested} == true, \"Dermatological testing is required\")" },
      { "name": "paoMonths", "label": "Period After Opening (months)", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "Required() AND Min(1)" },
      { "name": "regulatoryCompliance", "label": "Regulatory Region", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 24, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6",
        "options": [ { "value": "EU", "label": "EU (EC 1223/2009)", "displayOrder": 0 }, { "value": "US_FDA", "label": "US (FDA)", "displayOrder": 1 }, { "value": "BOTH", "label": "EU & US", "displayOrder": 2 }, { "value": "OTHER", "label": "Other Region", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "safetyDataSheet", "label": "Safety Data Sheet (SDS)", "fieldType": "FILE", "isMandatory": true, "displayOrder": 25, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "allowedFileTypes": "pdf", "maxFileSize": 10485760, "validation": "Required()" },
      { "name": "stabilityReport", "label": "Stability Test Report", "fieldType": "FILE", "displayOrder": 26, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "allowedFileTypes": "pdf,doc,docx", "maxFileSize": 10485760 }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "R&D Chemist", "approverType": "ROLE", "roleName": "RD_CHEMIST", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Regulatory Affairs Manager", "approverType": "ROLE", "roleName": "REGULATORY_MANAGER", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Head of Product Development", "approverType": "ROLE", "roleName": "HEAD_PRODUCT_DEV", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}