{
  "_comment": "Land / Title Registration — register a new title or transfer of immovable property.",
  "name": "Land Title Registration",
  "code": "LTR",
  "description": "Register a new title, subdivision or transfer of immovable property.",
  "icon": "home",
  "displayOrder": 64,
  "requiresApproval": true,
  "commentsMandatoryOnReject": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "GOVERNMENT",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{titleRef} - @{applicantName} (@{transactionType})",
  "reminderEnabled": true,
  "reminderFrequencyHours": 48,
  "reminderMaxCount": 3,
  "reminderStartAfterHours": 48,
  "escalationEnabled": true,
  "escalationAfterHours": 168,
  "escalationAction": "NOTIFY_ADMIN",

  "forms": [{
    "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Applicant", "displayOrder": 0, "icon": "person" },
      { "id": "temp_screen_2", "title": "Property", "displayOrder": 1, "icon": "home" },
      { "id": "temp_screen_3", "title": "Transaction", "displayOrder": 2, "icon": "swap_horiz" },
      { "id": "temp_screen_4", "title": "Fees & Duty", "displayOrder": 3, "icon": "payments" },
      { "id": "temp_screen_5", "title": "Documents", "displayOrder": 4, "icon": "attach_file" },
      { "id": "temp_screen_6", "title": "Review & Submit", "displayOrder": 5, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Applicant", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Property", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_3", "title": "Transaction", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_4", "title": "Transferor (if Transfer)", "displayOrder": 3, "columns": 2, "isCollapsible": true, "isCollapsedByDefault": true, "screenId": "temp_screen_3" },
      { "id": "temp_grp_5", "title": "Fees", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_4" },
      { "id": "temp_grp_6", "title": "Documents", "displayOrder": 5, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_5" }
    ],
    "fields": [
      { "name": "titleRef", "label": "Application Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"LTR-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "submissionDate", "label": "Submission Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "applicantName", "label": "Applicant / Transferee", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "validation": "Required()" },
      { "name": "applicantId", "label": "ID / Reg Number", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "phone", "label": "Phone", "fieldType": "PHONE", "isMandatory": true, "displayOrder": 4, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "validation": "Required() AND Phone()" },
      { "name": "email", "label": "Email", "fieldType": "EMAIL", "displayOrder": 5, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "validation": "ValidWhen(IS_EMPTY(@{email}) OR IS_EMAIL(@{email}), \"Enter valid email\")" },
      { "name": "address", "label": "Address", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 6, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "validation": "Required()" },
      { "name": "titleNumber", "label": "Title / Deed Number", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "landUse", "label": "Land Use", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "options": [
          { "value": "RESIDENTIAL", "label": "Residential", "displayOrder": 0 },
          { "value": "COMMERCIAL", "label": "Commercial", "displayOrder": 1 },
          { "value": "INDUSTRIAL", "label": "Industrial", "displayOrder": 2 },
          { "value": "AGRICULTURAL", "label": "Agricultural", "displayOrder": 3 },
          { "value": "INSTITUTIONAL", "label": "Institutional", "displayOrder": 4 }
        ], "validation": "Required()" },
      { "name": "tenureType", "label": "Tenure", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "options": [
          { "value": "FREEHOLD", "label": "Freehold", "displayOrder": 0 },
          { "value": "LEASEHOLD", "label": "Leasehold", "displayOrder": 1 },
          { "value": "CUSTOMARY", "label": "Customary", "displayOrder": 2 }
        ], "validation": "Required()" },
      { "name": "areaSqm", "label": "Area (m²)", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required() AND Min(0.01)" },
      { "name": "locationDescription", "label": "Location (Plot / Ward / District)", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 14, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required() AND MinLength(15)" },
      { "name": "gpsCoordinates", "label": "GPS Coordinates", "fieldType": "TEXT", "displayOrder": 15, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2" },
      { "name": "transactionType", "label": "Transaction Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "options": [
          { "value": "FIRST_REGISTRATION", "label": "First Registration", "displayOrder": 0 },
          { "value": "TRANSFER", "label": "Transfer / Sale", "displayOrder": 1 },
          { "value": "SUBDIVISION", "label": "Subdivision", "displayOrder": 2 },
          { "value": "CONSOLIDATION", "label": "Consolidation", "displayOrder": 3 },
          { "value": "MORTGAGE", "label": "Mortgage / Charge", "displayOrder": 4 },
          { "value": "RELEASE", "label": "Release of Charge", "displayOrder": 5 },
          { "value": "CAVEAT", "label": "Caveat", "displayOrder": 6 }
        ], "validation": "Required()" },
      { "name": "considerationValue", "label": "Consideration / Purchase Price", "fieldType": "CURRENCY", "isLimited": true, "inSummary": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "visibilityExpression": "@{transactionType} == 'TRANSFER' OR @{transactionType} == 'MORTGAGE'",
        "validation": "ValidWhen(@{transactionType} != 'TRANSFER' OR @{considerationValue} > 0, \"Consideration required\")" },
      { "name": "transferorName", "label": "Transferor Name", "fieldType": "TEXT", "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "visibilityExpression": "@{transactionType} == 'TRANSFER'",
        "validation": "ValidWhen(@{transactionType} != 'TRANSFER' OR IS_NOT_EMPTY(@{transferorName}), \"Transferor required\")" },
      { "name": "transferorId", "label": "Transferor ID", "fieldType": "TEXT", "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "visibilityExpression": "@{transactionType} == 'TRANSFER'" },
      { "name": "searchFee", "label": "Search Fee", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "Min(0)" },
      { "name": "registrationFee", "label": "Registration Fee", "fieldType": "CURRENCY", "isMandatory": true, "defaultValue": "0", "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "Required() AND Min(0)" },
      { "name": "stampDuty", "label": "Stamp Duty", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "Min(0)" },
      { "name": "transferTax", "label": "Transfer Tax / CGT", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 43, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "Min(0)" },
      { "name": "totalFees", "label": "Total Fees", "fieldType": "CURRENCY", "isReadonly": true, "inSummary": true, "displayOrder": 44, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "defaultValue": "SUM(@{searchFee}, @{registrationFee}, @{stampDuty}, @{transferTax})" },
      { "name": "titleDeed", "label": "Existing Title / Deed", "fieldType": "FILE", "displayOrder": 50, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 10485760 },
      { "name": "saleAgreement", "label": "Sale / Transfer Agreement", "fieldType": "FILE", "displayOrder": 51, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "visibilityExpression": "@{transactionType} == 'TRANSFER'",
        "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 10485760,
        "validation": "ValidWhen(@{transactionType} != 'TRANSFER' OR IS_NOT_EMPTY(@{saleAgreement}), \"Sale agreement required\")" },
      { "name": "survey", "label": "Survey Plan / Site Map", "fieldType": "FILE", "isMandatory": true, "displayOrder": 52, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 20971520, "validation": "Required()" },
      { "name": "idCopies", "label": "Parties ID Copies", "fieldType": "FILE", "isMandatory": true, "multiple": true, "displayOrder": 53, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 10485760, "maxFiles": 10, "validation": "Required()" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Land Registry Officer", "approverType": "ROLE", "roleName": "LAND_OFFICER", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Registrar of Deeds", "approverType": "ROLE", "roleName": "REGISTRAR_OF_DEEDS", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Commissioner of Lands", "approverType": "ROLE", "roleName": "COMMISSIONER_OF_LANDS", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
