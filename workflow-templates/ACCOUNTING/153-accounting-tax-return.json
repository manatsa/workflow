{
  "_comment": "Tax Return Filing — prepare and file a corporate / individual tax return.",
  "name": "Tax Return Filing",
  "code": "ATR",
  "description": "Prepare, review and file a corporate or individual income tax return.",
  "icon": "request_quote",
  "displayOrder": 153,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "ACCOUNTING",
  "workflowTypeCode": "FINANCE",
  "titleTemplate": "@{returnRef} - @{taxpayerName} (@{taxYear})",
  "reminderEnabled": true, "reminderFrequencyHours": 24, "reminderMaxCount": 3, "reminderStartAfterHours": 24,
  "escalationEnabled": true, "escalationAfterHours": 72, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Taxpayer", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Tax Computation", "displayOrder": 1, "icon": "payments" },
      { "id": "temp_screen_3", "title": "Review", "displayOrder": 2, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Taxpayer", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Return Type", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_4", "title": "Income & Deductions", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Tax Liability", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" }
    ],
    "fields": [
      { "name": "returnRef", "label": "Return Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"ATR-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "preparedDate", "label": "Prepared Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "preparer", "label": "Preparer", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "dueDate", "label": "Filing Deadline", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()" },
      { "name": "taxpayerName", "label": "Taxpayer Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "taxId", "label": "Tax / TIN Number", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "taxpayerType", "label": "Taxpayer Type", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "INDIVIDUAL", "label": "Individual", "displayOrder": 0 }, { "value": "CORPORATE", "label": "Corporate", "displayOrder": 1 }, { "value": "PARTNERSHIP", "label": "Partnership", "displayOrder": 2 }, { "value": "TRUST", "label": "Trust", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "residency", "label": "Tax Residency", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "returnType", "label": "Return Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "INCOME", "label": "Income Tax", "displayOrder": 0 }, { "value": "VAT", "label": "VAT", "displayOrder": 1 }, { "value": "PAYE", "label": "PAYE", "displayOrder": 2 }, { "value": "CGT", "label": "Capital Gains Tax", "displayOrder": 3 }, { "value": "WHT", "label": "Withholding Tax", "displayOrder": 4 }, { "value": "CUSTOMS", "label": "Customs / Excise", "displayOrder": 5 } ], "validation": "Required()" },
      { "name": "taxYear", "label": "Tax Year / Period", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "originalOrAmended", "label": "Original / Amended", "fieldType": "SELECT", "isMandatory": true, "defaultValue": "ORIGINAL", "displayOrder": 22, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "ORIGINAL", "label": "Original", "displayOrder": 0 }, { "value": "AMENDED", "label": "Amended", "displayOrder": 1 } ], "validation": "Required()" },
      { "name": "grossIncome", "label": "Gross Income", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Min(0)" },
      { "name": "allowableDeductions", "label": "Allowable Deductions", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Min(0)" },
      { "name": "taxableIncome", "label": "Taxable Income", "fieldType": "CURRENCY", "isReadonly": true, "inSummary": true, "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "defaultValue": "SUBTRACT(@{grossIncome}, @{allowableDeductions})" },
      { "name": "effectiveTaxRate", "label": "Effective Tax Rate %", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 33, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Min(0) AND Max(100)" },
      { "name": "taxLiability", "label": "Tax Liability", "fieldType": "CURRENCY", "isMandatory": true, "isLimited": true, "inSummary": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "Required() AND Min(0)" },
      { "name": "taxPaid", "label": "Tax Already Paid / Withheld", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "Min(0)" },
      { "name": "taxDueOrRefund", "label": "Tax Due / (Refund)", "fieldType": "CURRENCY", "isReadonly": true, "inSummary": true, "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5",
        "defaultValue": "SUBTRACT(@{taxLiability}, @{taxPaid})" },
      { "name": "clientApproved", "label": "Client Approval Received", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 43, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{clientApproved} == true, \"Client approval required\")" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Tax Preparer", "approverType": "ROLE", "roleName": "TAX_PREPARER", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Tax Manager / Reviewer", "approverType": "ROLE", "roleName": "TAX_MANAGER", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Tax Partner", "approverType": "ROLE", "roleName": "TAX_PARTNER", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
