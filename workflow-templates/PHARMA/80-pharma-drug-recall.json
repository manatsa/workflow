{
  "_comment": "Drug / Product Recall — market-action recall of a pharmaceutical product batch.",
  "name": "Drug Recall",
  "code": "PDR",
  "description": "Initiate and execute a market recall of a pharmaceutical product due to quality, safety or labelling issues.",
  "icon": "warning",
  "displayOrder": 80,
  "requiresApproval": true,
  "commentsMandatoryOnReject": true, "commentsMandatoryOnEscalate": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "PHARMA",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{recallRef} - @{productName} (@{classification})",
  "reminderEnabled": true, "reminderFrequencyHours": 2, "reminderMaxCount": 5, "reminderStartAfterHours": 1,
  "escalationEnabled": true, "escalationAfterHours": 12, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Recall Header", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Product & Distribution", "displayOrder": 1, "icon": "inventory" },
      { "id": "temp_screen_3", "title": "Reason & Action", "displayOrder": 2, "icon": "gavel" },
      { "id": "temp_screen_4", "title": "Financial Impact", "displayOrder": 3, "icon": "payments" },
      { "id": "temp_screen_5", "title": "Documents", "displayOrder": 4, "icon": "attach_file" },
      { "id": "temp_screen_6", "title": "Review", "displayOrder": 5, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Header", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Classification", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Product Details", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Distribution", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Reason", "displayOrder": 4, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_6", "title": "Recall Action Plan", "displayOrder": 5, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_7", "title": "Financials", "displayOrder": 6, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_4" },
      { "id": "temp_grp_8", "title": "Documents", "displayOrder": 7, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_5" }
    ],
    "fields": [
      { "name": "recallRef", "label": "Recall Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"PDR-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "initiatedDate", "label": "Initiation Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "initiator", "label": "Initiator", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "source", "label": "Recall Source", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [ { "value": "VOLUNTARY", "label": "Voluntary", "displayOrder": 0 }, { "value": "REGULATOR", "label": "Regulator-Mandated", "displayOrder": 1 }, { "value": "COMPLAINT", "label": "Customer Complaint", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "classification", "label": "Recall Class", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "CLASS_1", "label": "Class I - Serious Health Risk", "displayOrder": 0 }, { "value": "CLASS_2", "label": "Class II - Temporary / Reversible Risk", "displayOrder": 1 }, { "value": "CLASS_3", "label": "Class III - No Health Risk", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "recallDepth", "label": "Recall Depth", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "WHOLESALE", "label": "Wholesale", "displayOrder": 0 }, { "value": "RETAIL", "label": "Retail / Pharmacy", "displayOrder": 1 }, { "value": "PATIENT", "label": "Patient Level", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "productName", "label": "Product Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "productCode", "label": "Product Code / SKU", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "batchNumbers", "label": "Affected Batch Numbers", "fieldType": "TEXTAREA", "isMandatory": true, "inSummary": true, "displayOrder": 22, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "unitsDistributed", "label": "Units Distributed", "fieldType": "NUMBER", "isMandatory": true, "inSummary": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Min(0)" },
      { "name": "countries", "label": "Affected Countries / Markets", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 31, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required()" },
      { "name": "customersAffected", "label": "Distinct Customers / Distributors Affected", "fieldType": "NUMBER", "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Min(0)" },
      { "name": "reason", "label": "Reason for Recall", "fieldType": "TEXTAREA", "isMandatory": true, "inSummary": true, "displayOrder": 40, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "Required() AND MinLength(30)" },
      { "name": "healthHazard", "label": "Health Hazard Assessment", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 41, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "Required() AND MinLength(30)" },
      { "name": "publicNotification", "label": "Public Notification Required?", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 50, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6" },
      { "name": "targetCompletionDate", "label": "Target Completion Date", "fieldType": "DATE", "isMandatory": true, "displayOrder": 51, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "validation": "Required() AND DateAfter(\"today\", \"Target must be future\")" },
      { "name": "recallStrategy", "label": "Recall Strategy / Action Plan", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 52, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "validation": "Required() AND MinLength(50)" },
      { "name": "unitsReturned", "label": "Units Expected Returned", "fieldType": "NUMBER", "defaultValue": "0", "displayOrder": 53, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "validation": "Min(0)" },
      { "name": "estimatedRecoveryPercent", "label": "Estimated Recovery %", "fieldType": "NUMBER", "displayOrder": 54, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "validation": "Min(0) AND Max(100)" },
      { "name": "costOfGoods", "label": "Cost of Goods Impact", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 60, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_7", "validation": "Min(0)" },
      { "name": "logisticsCost", "label": "Logistics / Destruction Cost", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 61, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_7", "validation": "Min(0)" },
      { "name": "customerRefunds", "label": "Customer Refunds", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 62, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_7", "validation": "Min(0)" },
      { "name": "totalFinancialImpact", "label": "Total Financial Impact", "fieldType": "CURRENCY", "isReadonly": true, "isLimited": true, "inSummary": true, "displayOrder": 63, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_7",
        "defaultValue": "SUM(@{costOfGoods}, @{logisticsCost}, @{customerRefunds})" },
      { "name": "regulatoryNotice", "label": "Regulatory Notification", "fieldType": "FILE", "isMandatory": true, "displayOrder": 70, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_8", "allowedFileTypes": "pdf,doc,docx", "maxFileSize": 10485760, "validation": "Required()" },
      { "name": "customerNotice", "label": "Customer / Distributor Notice", "fieldType": "FILE", "isMandatory": true, "displayOrder": 71, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_8", "allowedFileTypes": "pdf,doc,docx", "maxFileSize": 10485760, "validation": "Required()" },
      { "name": "healthHazardReport", "label": "Health Hazard Evaluation Report", "fieldType": "FILE", "displayOrder": 72, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_8", "allowedFileTypes": "pdf,doc,docx", "maxFileSize": 10485760 }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "QA Manager", "approverType": "ROLE", "roleName": "QA_MANAGER", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 2, "name": "Qualified Person (QP)", "approverType": "ROLE", "roleName": "QUALIFIED_PERSON", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Head of Regulatory Affairs", "approverType": "ROLE", "roleName": "HEAD_REGULATORY", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 4, "name": "CEO / Managing Director", "approverType": "ROLE", "roleName": "CEO", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
