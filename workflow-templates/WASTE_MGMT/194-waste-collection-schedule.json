{
  "_comment": "Waste Collection Schedule — schedule and approve waste collection routes.",
  "name": "Waste Collection Schedule",
  "code": "WCS",
  "description": "Schedule and approve waste collection routes for residential or commercial zones.",
  "icon": "delete",
  "displayOrder": 194,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "NON_FINANCIAL",
  "industryCode": "WASTE_MGMT",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{scheduleRef} - @{zone} (@{collectionDate})",
  "reminderEnabled": true, "reminderFrequencyHours": 12, "reminderMaxCount": 3, "reminderStartAfterHours": 12,
  "escalationEnabled": true, "escalationAfterHours": 48, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Route", "displayOrder": 0, "icon": "route" },
      { "id": "temp_screen_2", "title": "Resources", "displayOrder": 1, "icon": "local_shipping" },
      { "id": "temp_screen_3", "title": "Review", "displayOrder": 2, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Route Details", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Vehicle & Crew", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Disposal", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" }
    ],
    "fields": [
      { "name": "scheduleRef", "label": "Schedule Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"WCS-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "createdDate", "label": "Created Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "zone", "label": "Collection Zone", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "wasteType", "label": "Waste Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "GENERAL", "label": "General / Household", "displayOrder": 0 }, { "value": "RECYCLABLE", "label": "Recyclable", "displayOrder": 1 }, { "value": "ORGANIC", "label": "Organic / Green", "displayOrder": 2 }, { "value": "HAZARDOUS", "label": "Hazardous", "displayOrder": 3 }, { "value": "MEDICAL", "label": "Medical", "displayOrder": 4 }, { "value": "CONSTRUCTION", "label": "Construction & Demolition", "displayOrder": 5 } ], "validation": "Required()" },
      { "name": "collectionDate", "label": "Collection Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND DateAfter(\"today\", \"Must be future date\")" },
      { "name": "frequency", "label": "Frequency", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "DAILY", "label": "Daily", "displayOrder": 0 }, { "value": "TWICE_WEEKLY", "label": "Twice Weekly", "displayOrder": 1 }, { "value": "WEEKLY", "label": "Weekly", "displayOrder": 2 }, { "value": "BIWEEKLY", "label": "Bi-Weekly", "displayOrder": 3 }, { "value": "MONTHLY", "label": "Monthly", "displayOrder": 4 } ], "validation": "Required()" },
      { "name": "estimatedStops", "label": "Estimated Stops", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 14, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND Min(1)" },
      { "name": "estimatedTonnage", "label": "Estimated Tonnage", "fieldType": "NUMBER", "isMandatory": true, "inSummary": true, "displayOrder": 15, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND Min(0.1)" },
      { "name": "vehicleReg", "label": "Vehicle Registration", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "vehicleType", "label": "Vehicle Type", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "COMPACTOR", "label": "Compactor Truck", "displayOrder": 0 }, { "value": "SKIP", "label": "Skip Loader", "displayOrder": 1 }, { "value": "HOOKLOADER", "label": "Hook Loader", "displayOrder": 2 }, { "value": "TIPPER", "label": "Tipper Truck", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "driver", "label": "Driver", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "crewSize", "label": "Crew Size", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required() AND Min(1)" },
      { "name": "disposalSite", "label": "Disposal Site / Landfill", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required()" },
      { "name": "disposalPermitValid", "label": "Disposal Permit Valid", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "ValidWhen(@{disposalPermitValid} == true, \"Valid disposal permit required\")" },
      { "name": "specialInstructions", "label": "Special Instructions", "fieldType": "TEXTAREA", "displayOrder": 32, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Route Supervisor", "approverType": "ROLE", "roleName": "ROUTE_SUPERVISOR", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Operations Manager", "approverType": "ROLE", "roleName": "OPS_MANAGER", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
