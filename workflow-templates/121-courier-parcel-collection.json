{
  "_comment": "Parcel Collection Booking — schedule a parcel pickup from a sender.",
  "name": "Parcel Collection Booking",
  "code": "CPB",
  "description": "Schedule a parcel pickup from a sender for courier / express delivery.",
  "icon": "inbox",
  "displayOrder": 121,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "COURIER",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{awbRef} - @{sender} → @{recipient}",
  "reminderEnabled": true, "reminderFrequencyHours": 2, "reminderMaxCount": 4, "reminderStartAfterHours": 1,
  "escalationEnabled": true, "escalationAfterHours": 12, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Sender & Recipient", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Parcel & Service", "displayOrder": 1, "icon": "inventory" },
      { "id": "temp_screen_3", "title": "Review", "displayOrder": 2, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Sender", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Recipient", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_4", "title": "Parcel", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Service & Charges", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" }
    ],
    "fields": [
      { "name": "awbRef", "label": "AWB / Waybill", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"CPB-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "bookingDate", "label": "Booking Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "sender", "label": "Sender", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "senderPhone", "label": "Sender Phone", "fieldType": "PHONE", "isMandatory": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND Phone()" },
      { "name": "pickupAddress", "label": "Pickup Address", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 4, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND MinLength(10)" },
      { "name": "pickupWindow", "label": "Pickup Window", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 5, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "recipient", "label": "Recipient", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "recipientPhone", "label": "Recipient Phone", "fieldType": "PHONE", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required() AND Phone()" },
      { "name": "deliveryAddress", "label": "Delivery Address", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 12, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required() AND MinLength(10)" },
      { "name": "country", "label": "Delivery Country", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 13, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "parcelDescription", "label": "Contents Description", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 20, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required()" },
      { "name": "numberOfPieces", "label": "Pieces", "fieldType": "NUMBER", "isMandatory": true, "defaultValue": "1", "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Min(1)" },
      { "name": "weightKg", "label": "Weight (kg)", "fieldType": "NUMBER", "isMandatory": true, "inSummary": true, "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Min(0.01)" },
      { "name": "dimensions", "label": "Dimensions (LxWxH cm)", "fieldType": "TEXT", "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "declaredValue", "label": "Declared Value", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 24, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Min(0)" },
      { "name": "fragile", "label": "Fragile?", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 25, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "dangerousGoods", "label": "Dangerous Goods?", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 26, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "serviceLevel", "label": "Service", "fieldType": "SELECT", "isMandatory": true, "defaultValue": "STANDARD", "inSummary": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5",
        "options": [ { "value": "EXPRESS", "label": "Express (Same/Next Day)", "displayOrder": 0 }, { "value": "STANDARD", "label": "Standard", "displayOrder": 1 }, { "value": "ECONOMY", "label": "Economy", "displayOrder": 2 }, { "value": "INTERNATIONAL", "label": "International", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "paymentMethod", "label": "Payment Method", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5",
        "options": [ { "value": "PREPAID", "label": "Prepaid", "displayOrder": 0 }, { "value": "COD", "label": "Cash on Delivery", "displayOrder": 1 }, { "value": "ACCOUNT", "label": "On Account", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "charge", "label": "Shipping Charge", "fieldType": "CURRENCY", "isMandatory": true, "isLimited": true, "inSummary": true, "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "Required() AND Min(0)" },
      { "name": "codAmount", "label": "COD Amount", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 33, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "visibilityExpression": "@{paymentMethod} == 'COD'", "validation": "Min(0)" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Customer Service Agent", "approverType": "ROLE", "roleName": "CS_AGENT", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Dispatch Supervisor", "approverType": "ROLE", "roleName": "DISPATCH_SUPERVISOR", "amountLimit": null, "canEscalate": false, "requireComment": false, "emailNotification": true }
  ]
}
