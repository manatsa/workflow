{
  "_comment": "Container Release — release of an import container after customs clearance and charges paid.",
  "name": "Container Release",
  "code": "SCR",
  "description": "Release an import container after customs clearance, demurrage and port charges settled.",
  "icon": "check_circle",
  "displayOrder": 114,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "SHIPPING",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{releaseRef} - @{containerNumber} (@{consignee})",
  "reminderEnabled": true, "reminderFrequencyHours": 4, "reminderMaxCount": 4, "reminderStartAfterHours": 2,
  "escalationEnabled": true, "escalationAfterHours": 24, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Container", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Charges & Checks", "displayOrder": 1, "icon": "checklist" },
      { "id": "temp_screen_3", "title": "Review", "displayOrder": 2, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Container & Consignee", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Import & B/L", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_4", "title": "Charges", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Release Checks", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" }
    ],
    "fields": [
      { "name": "releaseRef", "label": "Release Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"SCR-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "requestDate", "label": "Request Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "containerNumber", "label": "Container Number", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND Pattern(/^[A-Z]{4}[0-9]{7}$/, \"Enter valid ISO container number (4 letters + 7 digits)\")", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "containerSize", "label": "Size / Type", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "20GP", "label": "20' General", "displayOrder": 0 }, { "value": "40GP", "label": "40' General", "displayOrder": 1 }, { "value": "40HC", "label": "40' High Cube", "displayOrder": 2 }, { "value": "20RF", "label": "20' Reefer", "displayOrder": 3 }, { "value": "40RF", "label": "40' Reefer", "displayOrder": 4 }, { "value": "OT", "label": "Open Top", "displayOrder": 5 }, { "value": "FR", "label": "Flat Rack", "displayOrder": 6 } ], "validation": "Required()" },
      { "name": "consignee", "label": "Consignee", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "haulier", "label": "Collecting Haulier", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "truckReg", "label": "Truck Reg.", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 14, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "driverName", "label": "Driver Name", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 15, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "blNumber", "label": "B/L Number", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "declarationNo", "label": "Customs Declaration No.", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "portArrivalDate", "label": "Date Landed at Port", "fieldType": "DATE", "isMandatory": true, "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "freeDaysRemaining", "label": "Free Days Remaining", "fieldType": "NUMBER", "isMandatory": true, "defaultValue": "0", "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "demurrageAmount", "label": "Demurrage", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Min(0)" },
      { "name": "storageCharges", "label": "Storage Charges", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Min(0)" },
      { "name": "thc", "label": "THC", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Min(0)" },
      { "name": "containerDeposit", "label": "Container Deposit", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 33, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Min(0)" },
      { "name": "totalPayable", "label": "Total Payable", "fieldType": "CURRENCY", "isReadonly": true, "isLimited": true, "inSummary": true, "displayOrder": 34, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "defaultValue": "SUM(@{demurrageAmount}, @{storageCharges}, @{thc}, @{containerDeposit})" },
      { "name": "customsCleared", "label": "Customs Cleared", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{customsCleared} == true, \"Customs must be cleared\")" },
      { "name": "allChargesPaid", "label": "All Charges Paid", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{allChargesPaid} == true, \"Charges must be paid\")" },
      { "name": "doIssued", "label": "Delivery Order Issued", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{doIssued} == true, \"Delivery order required\")" },
      { "name": "haulierAuthorised", "label": "Haulier Authorised & Insured", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 43, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{haulierAuthorised} == true, \"Haulier must be authorised\")" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Container Release Officer", "approverType": "ROLE", "roleName": "RELEASE_OFFICER", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Terminal Operations Manager", "approverType": "ROLE", "roleName": "TERMINAL_OPS", "amountLimit": null, "canEscalate": false, "requireComment": false, "emailNotification": true }
  ]
}
