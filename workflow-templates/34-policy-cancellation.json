{
  "_comment": "Policy Cancellation / Surrender — cancel a funeral policy, calculate surrender value or refund.",
  "name": "Policy Cancellation / Surrender",
  "code": "PCS",
  "description": "Cancel or surrender a funeral assurance policy, process any surrender or refund value.",
  "icon": "cancel",
  "displayOrder": 34,
  "requiresApproval": true,
  "commentsMandatory": false,
  "commentsMandatoryOnReject": true,
  "commentsMandatoryOnEscalate": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "titleTemplate": "@{cancelRef} - @{policyholderName} (@{policyNumber})",
  "reminderEnabled": true,
  "reminderFrequencyHours": 24,
  "reminderMaxCount": 3,
  "reminderStartAfterHours": 24,
  "escalationEnabled": true,
  "escalationAfterHours": 72,
  "escalationAction": "NOTIFY_ADMIN",
  "reminderEmailSubject": "Reminder: Policy Cancellation @{referenceNumber} pending",
  "reminderEmailBody": "<p>Policy cancellation <strong>@{referenceNumber}</strong> awaiting your action.</p>",
  "forms": [
    {
      "name": "Main Form",
      "displayOrder": 0,
      "screens": [
        {
          "id": "temp_screen_1",
          "title": "Reference",
          "displayOrder": 0,
          "icon": "info"
        },
        {
          "id": "temp_screen_2",
          "title": "Policy",
          "displayOrder": 1,
          "icon": "policy"
        },
        {
          "id": "temp_screen_3",
          "title": "Cancellation Reason",
          "displayOrder": 2,
          "icon": "edit_note"
        },
        {
          "id": "temp_screen_4",
          "title": "Refund / Surrender",
          "displayOrder": 3,
          "icon": "payments"
        },
        {
          "id": "temp_screen_5",
          "title": "Documents",
          "displayOrder": 4,
          "icon": "attach_file"
        },
        {
          "id": "temp_screen_6",
          "title": "Review & Submit",
          "displayOrder": 5,
          "icon": "fact_check",
          "isSummaryScreen": true
        }
      ],
      "fieldGroups": [
        {
          "id": "temp_grp_1",
          "title": "Reference",
          "displayOrder": 0,
          "columns": 2,
          "isCollapsible": false,
          "screenId": "temp_screen_1"
        },
        {
          "id": "temp_grp_2",
          "title": "Policy Details",
          "displayOrder": 1,
          "columns": 2,
          "isCollapsible": false,
          "screenId": "temp_screen_2"
        },
        {
          "id": "temp_grp_3",
          "title": "Reason",
          "displayOrder": 2,
          "columns": 1,
          "isCollapsible": false,
          "screenId": "temp_screen_3"
        },
        {
          "id": "temp_grp_4",
          "title": "Refund Calculation",
          "displayOrder": 3,
          "columns": 2,
          "isCollapsible": false,
          "screenId": "temp_screen_4"
        },
        {
          "id": "temp_grp_5",
          "title": "Payout Destination",
          "displayOrder": 4,
          "columns": 2,
          "isCollapsible": false,
          "screenId": "temp_screen_4"
        },
        {
          "id": "temp_grp_6",
          "title": "Documents",
          "displayOrder": 5,
          "columns": 1,
          "isCollapsible": false,
          "screenId": "temp_screen_5"
        }
      ],
      "fields": [
        {
          "name": "cancelRef",
          "label": "Cancellation Reference",
          "fieldType": "TEXT",
          "defaultValue": "SEQUENCE(\"PCS-\")",
          "isReadonly": true,
          "isTitle": true,
          "inSummary": true,
          "displayOrder": 0,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_1"
        },
        {
          "name": "requestDate",
          "label": "Request Date",
          "fieldType": "DATE",
          "defaultValue": "TODAY()",
          "isReadonly": true,
          "inSummary": true,
          "displayOrder": 1,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_1"
        },
        {
          "name": "officer",
          "label": "Officer",
          "fieldType": "TEXT",
          "defaultValue": "CURRENT_USER()",
          "isReadonly": true,
          "displayOrder": 2,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_1"
        },
        {
          "name": "branch",
          "label": "Branch",
          "fieldType": "TEXT",
          "isMandatory": true,
          "displayOrder": 3,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_1",
          "validation": "Required()"
        },
        {
          "name": "policyNumber",
          "label": "Policy Number",
          "fieldType": "TEXT",
          "isMandatory": true,
          "inSummary": true,
          "displayOrder": 10,
          "columnSpan": 1,
          "screenId": "temp_screen_2",
          "fieldGroupId": "temp_grp_2",
          "validation": "Required()",
          "customValidationRule": "TRIM() AND UPPER()"
        },
        {
          "name": "policyholderName",
          "label": "Policyholder Name",
          "fieldType": "TEXT",
          "isMandatory": true,
          "isTitle": true,
          "inSummary": true,
          "displayOrder": 11,
          "columnSpan": 1,
          "screenId": "temp_screen_2",
          "fieldGroupId": "temp_grp_2",
          "validation": "Required()"
        },
        {
          "name": "policyholderId",
          "label": "Policyholder ID",
          "fieldType": "TEXT",
          "isMandatory": true,
          "displayOrder": 12,
          "columnSpan": 1,
          "screenId": "temp_screen_2",
          "fieldGroupId": "temp_grp_2",
          "validation": "Required()"
        },
        {
          "name": "inceptionDate",
          "label": "Policy Inception Date",
          "fieldType": "DATE",
          "isMandatory": true,
          "displayOrder": 13,
          "columnSpan": 1,
          "screenId": "temp_screen_2",
          "fieldGroupId": "temp_grp_2",
          "validation": "Required()"
        },
        {
          "name": "plan",
          "label": "Plan",
          "fieldType": "TEXT",
          "isMandatory": true,
          "displayOrder": 14,
          "columnSpan": 1,
          "screenId": "temp_screen_2",
          "fieldGroupId": "temp_grp_2",
          "validation": "Required()"
        },
        {
          "name": "monthlyPremium",
          "label": "Monthly Premium",
          "fieldType": "CURRENCY",
          "isMandatory": true,
          "displayOrder": 15,
          "columnSpan": 1,
          "screenId": "temp_screen_2",
          "fieldGroupId": "temp_grp_2",
          "validation": "Required() AND Min(0)"
        },
        {
          "name": "monthsPaid",
          "label": "Months Paid",
          "fieldType": "NUMBER",
          "isMandatory": true,
          "inSummary": true,
          "displayOrder": 16,
          "columnSpan": 1,
          "screenId": "temp_screen_2",
          "fieldGroupId": "temp_grp_2",
          "validation": "Required() AND Min(0)"
        },
        {
          "name": "cancellationType",
          "label": "Cancellation Type",
          "fieldType": "SELECT",
          "isMandatory": true,
          "inSummary": true,
          "displayOrder": 20,
          "columnSpan": 1,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_3",
          "options": [
            {
              "value": "COOLING_OFF",
              "label": "Cooling-Off (within 30 days)",
              "displayOrder": 0
            },
            {
              "value": "VOLUNTARY",
              "label": "Voluntary Cancellation",
              "displayOrder": 1
            },
            {
              "value": "SURRENDER",
              "label": "Surrender",
              "displayOrder": 2
            },
            {
              "value": "NON_PAYMENT_LAPSE",
              "label": "Non-Payment Lapse",
              "displayOrder": 3
            },
            {
              "value": "FRAUD",
              "label": "Fraud / Misrepresentation",
              "displayOrder": 4
            },
            {
              "value": "DEATH",
              "label": "Death of Main Member (no dependants)",
              "displayOrder": 5
            }
          ],
          "validation": "Required()"
        },
        {
          "name": "reason",
          "label": "Reason Detail",
          "fieldType": "TEXTAREA",
          "isMandatory": true,
          "inSummary": true,
          "displayOrder": 21,
          "columnSpan": 2,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_3",
          "validation": "Required() AND MinLength(20)"
        },
        {
          "name": "retentionOffered",
          "label": "Retention Offer Made?",
          "fieldType": "YES_NO",
          "defaultValue": "false",
          "displayOrder": 22,
          "columnSpan": 1,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_3"
        },
        {
          "name": "retentionOutcome",
          "label": "Retention Outcome",
          "fieldType": "TEXTAREA",
          "displayOrder": 23,
          "columnSpan": 2,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_3",
          "visibilityExpression": "@{retentionOffered} == true"
        },
        {
          "name": "totalPremiumsPaid",
          "label": "Total Premiums Paid",
          "fieldType": "CURRENCY",
          "isMandatory": true,
          "displayOrder": 30,
          "columnSpan": 1,
          "screenId": "temp_screen_4",
          "fieldGroupId": "temp_grp_4",
          "validation": "Required() AND Min(0)"
        },
        {
          "name": "surrenderValue",
          "label": "Surrender / Refund Value",
          "fieldType": "CURRENCY",
          "isMandatory": true,
          "defaultValue": "0",
          "displayOrder": 31,
          "columnSpan": 1,
          "screenId": "temp_screen_4",
          "fieldGroupId": "temp_grp_4",
          "validation": "Required() AND Min(0)"
        },
        {
          "name": "cancellationFee",
          "label": "Cancellation Fee / Charges",
          "fieldType": "CURRENCY",
          "defaultValue": "0",
          "displayOrder": 32,
          "columnSpan": 1,
          "screenId": "temp_screen_4",
          "fieldGroupId": "temp_grp_4",
          "validation": "Min(0)"
        },
        {
          "name": "netPayable",
          "label": "Net Amount Payable",
          "fieldType": "CURRENCY",
          "isReadonly": true,
          "isLimited": true,
          "inSummary": true,
          "displayOrder": 33,
          "columnSpan": 1,
          "screenId": "temp_screen_4",
          "fieldGroupId": "temp_grp_4",
          "defaultValue": "SUBTRACT(@{surrenderValue}, @{cancellationFee})"
        },
        {
          "name": "effectiveCancelDate",
          "label": "Effective Cancellation Date",
          "fieldType": "DATE",
          "isMandatory": true,
          "defaultValue": "TODAY()",
          "inSummary": true,
          "displayOrder": 34,
          "columnSpan": 1,
          "screenId": "temp_screen_4",
          "fieldGroupId": "temp_grp_4",
          "validation": "Required()"
        },
        {
          "name": "paymentMethod",
          "label": "Payout Method",
          "fieldType": "SELECT",
          "displayOrder": 40,
          "columnSpan": 1,
          "screenId": "temp_screen_4",
          "fieldGroupId": "temp_grp_5",
          "visibilityExpression": "@{netPayable} > 0",
          "options": [
            {
              "value": "BANK_TRANSFER",
              "label": "Bank Transfer",
              "displayOrder": 0
            },
            {
              "value": "MOBILE_MONEY",
              "label": "Mobile Money",
              "displayOrder": 1
            },
            {
              "value": "CHEQUE",
              "label": "Cheque",
              "displayOrder": 2
            },
            {
              "value": "CASH",
              "label": "Cash",
              "displayOrder": 3
            }
          ],
          "validation": "ValidWhen(@{netPayable} <= 0 OR IS_NOT_EMPTY(@{paymentMethod}), \"Payout method required\")"
        },
        {
          "name": "bankAccount",
          "label": "Account / Mobile Number",
          "fieldType": "TEXT",
          "displayOrder": 41,
          "columnSpan": 1,
          "screenId": "temp_screen_4",
          "fieldGroupId": "temp_grp_5",
          "visibilityExpression": "@{netPayable} > 0 AND (@{paymentMethod} == 'BANK_TRANSFER' OR @{paymentMethod} == 'MOBILE_MONEY')",
          "validation": "ValidWhen(@{netPayable} <= 0 OR @{paymentMethod} != 'BANK_TRANSFER' AND @{paymentMethod} != 'MOBILE_MONEY' OR IS_NOT_EMPTY(@{bankAccount}), \"Account details required\")"
        },
        {
          "name": "bankName",
          "label": "Bank Name",
          "fieldType": "TEXT",
          "displayOrder": 42,
          "columnSpan": 1,
          "screenId": "temp_screen_4",
          "fieldGroupId": "temp_grp_5",
          "visibilityExpression": "@{paymentMethod} == 'BANK_TRANSFER'"
        },
        {
          "name": "cancellationForm",
          "label": "Signed Cancellation Request",
          "fieldType": "FILE",
          "isMandatory": true,
          "displayOrder": 50,
          "columnSpan": 2,
          "screenId": "temp_screen_5",
          "fieldGroupId": "temp_grp_6",
          "allowedFileTypes": "pdf,jpg,jpeg,png",
          "maxFileSize": 10485760,
          "validation": "Required(\"Signed cancellation request required\")"
        },
        {
          "name": "idCopy",
          "label": "Policyholder ID Copy",
          "fieldType": "FILE",
          "isMandatory": true,
          "displayOrder": 51,
          "columnSpan": 2,
          "screenId": "temp_screen_5",
          "fieldGroupId": "temp_grp_6",
          "allowedFileTypes": "pdf,jpg,jpeg,png",
          "maxFileSize": 10485760,
          "validation": "Required()"
        },
        {
          "name": "proofOfBanking",
          "label": "Proof of Banking",
          "fieldType": "FILE",
          "displayOrder": 52,
          "columnSpan": 2,
          "screenId": "temp_screen_5",
          "fieldGroupId": "temp_grp_6",
          "visibilityExpression": "@{paymentMethod} == 'BANK_TRANSFER'",
          "allowedFileTypes": "pdf,jpg,jpeg,png",
          "maxFileSize": 10485760
        }
      ]
    }
  ],
  "approvers": [
    {
      "level": 1,
      "name": "Policy Services Officer",
      "approverType": "ROLE",
      "roleName": "POLICY_OFFICER",
      "amountLimit": null,
      "canEscalate": true,
      "requireComment": false,
      "emailNotification": true
    },
    {
      "level": 2,
      "name": "Policy Services Manager",
      "approverType": "ROLE",
      "roleName": "POLICY_MANAGER",
      "amountLimit": 2500,
      "canEscalate": true,
      "requireComment": false,
      "emailNotification": true
    },
    {
      "level": 3,
      "name": "Head of Policy Admin",
      "approverType": "ROLE",
      "roleName": "HEAD_POLICY_ADMIN",
      "amountLimit": null,
      "canEscalate": false,
      "requireComment": true,
      "emailNotification": true
    }
  ],
  "industryCode": "FUNERAL",
  "workflowTypeCode": "FINANCE"
}