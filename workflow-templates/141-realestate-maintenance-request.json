      { "name": "issueType", "label": "Issue Category", "fieldType": "SELECT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "PLUMBING", "label": "Plumbing", "displayOrder": 0 }, { "value": "ELECTRICAL", "label": "Electrical", "displayOrder": 1 }, { "value": "HVAC", "label": "HVAC / Aircon", "displayOrder": 2 }, { "value": "STRUCTURAL", "label": "Structural / Roof", "displayOrder": 3 }, { "value": "APPLIANCE", "label": "Appliance", "displayOrder": 4 }, { "value": "PEST", "label": "Pest Control", "displayOrder": 5 }, { "value": "LANDSCAPING", "label": "Landscaping", "displayOrder": 6 }, { "value": "LOCKSMITH", "label": "Locks / Security", "displayOrder": 7 }, { "value": "OTHER", "label": "Other", "displayOrder": 8 } ], "validation": "Required()" },
      { "name": "description", "label": "Issue Description", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 21, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required() AND MinLength(20)" },
      { "name": "contractorName", "label": "Contractor Assigned", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required()" },
      { "name": "contractorPhone", "label": "Contractor Phone", "fieldType": "PHONE", "isMandatory": true, "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Phone()" },
      { "name": "scheduledDate", "label": "Scheduled Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required()" },
      { "name": "accessArranged", "label": "Access Arranged with Tenant", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 33, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "quotedCost", "label": "Quoted Cost", "fieldType": "CURRENCY", "isMandatory": true, "isLimited": true, "inSummary": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "Required() AND Min(0)" },
      { "name": "costAllocation", "label": "Cost Borne By", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5",
        "options": [ { "value": "LANDLORD", "label": "Landlord", "displayOrder": 0 }, { "value": "TENANT", "label": "Tenant (breakage)", "displayOrder": 1 }, { "value": "SPLIT", "label": "Split", "displayOrder": 2 }, { "value": "INSURANCE", "label": "Insurance", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "withinBudget", "label": "Within Maintenance Budget", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "true", "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5" },
      { "name": "landlordApproval", "label": "Landlord Approval Required?", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 43, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Property Administrator", "approverType": "ROLE", "roleName": "PROPERTY_ADMIN", "amountLimit": 500, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Property Manager", "approverType": "ROLE", "roleName": "PROPERTY_MANAGER", "amountLimit": 5000, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 3, "name": "Landlord / Portfolio Manager", "approverType": "ROLE", "roleName": "LANDLORD", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
