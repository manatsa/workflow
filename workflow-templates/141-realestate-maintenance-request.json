      { "name": "loggedDate", "label": "Logged Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "priority", "label": "Priority", "fieldType": "SELECT", "isMandatory": true, "defaultValue": "NORMAL", "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [ { "value": "EMERGENCY", "label": "Emergency (4 hrs)", "displayOrder": 0 }, { "value": "URGENT", "label": "Urgent (24 hrs)", "displayOrder": 1 }, { "value": "NORMAL", "label": "Normal (5 days)", "displayOrder": 2 }, { "value": "ROUTINE", "label": "Routine / Scheduled", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "source", "label": "Source", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [ { "value": "TENANT", "label": "Tenant Request", "displayOrder": 0 }, { "value": "INSPECTION", "label": "Routine Inspection", "displayOrder": 1 }, { "value": "PREVENTIVE", "label": "Preventive", "displayOrder": 2 }, { "value": "LANDLORD", "label": "Landlord-Initiated", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "property", "label": "Property Address", "fieldType": "TEXTAREA", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "tenantName", "label": "Tenant Name", "fieldType": "TEXT", "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2" },
