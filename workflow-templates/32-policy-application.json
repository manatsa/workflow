          "tableColumns": "[{\"name\":\"fullName\",\"label\":\"Full Name\",\"type\":\"TEXT\",\"width\":220,\"required\":true},{\"name\":\"relationship\",\"label\":\"Relationship\",\"type\":\"SELECT\",\"width\":150,\"required\":true,\"options\":[\"Spouse\",\"Child\",\"Parent\",\"Sibling\",\"Grandparent\",\"Grandchild\",\"Other\"]},{\"name\":\"idNumber\",\"label\":\"ID / Birth Cert\",\"type\":\"TEXT\",\"width\":160},{\"name\":\"dateOfBirth\",\"label\":\"DOB\",\"type\":\"DATE\",\"width\":130,\"required\":true},{\"name\":\"gender\",\"label\":\"Gender\",\"type\":\"SELECT\",\"width\":90,\"options\":[\"M\",\"F\"]},{\"name\":\"sumAssured\",\"label\":\"Sum Assured\",\"type\":\"NUMBER\",\"width\":130,\"required\":true}]"
