{
  "_comment": "Player Transfer / Signing — sign or transfer a player including fee and contract terms.",
  "name": "Player Transfer / Signing",
  "code": "SPT",
  "description": "Sign or transfer a player including transfer fee, salary and contract length.",
  "icon": "sports",
  "displayOrder": 175,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "SPORTS",
  "workflowTypeCode": "FINANCE",
  "titleTemplate": "@{transferRef} - @{playerName} (@{transferFee})",
  "reminderEnabled": true, "reminderFrequencyHours": 24, "reminderMaxCount": 3, "reminderStartAfterHours": 24,
  "escalationEnabled": true, "escalationAfterHours": 72, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Player", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Contract & Compliance", "displayOrder": 1, "icon": "gavel" },
      { "id": "temp_screen_3", "title": "Review", "displayOrder": 2, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Player Detail", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Origin Club", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_4", "title": "Contract Terms", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Compliance & Medical", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" }
    ],
    "fields": [
      { "name": "transferRef", "label": "Transfer Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"SPT-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "submissionDate", "label": "Submission Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "raisedBy", "label": "Raised By (Sporting Director)", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "playerName", "label": "Player Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "dob", "label": "Date of Birth", "fieldType": "DATE", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "nationality", "label": "Nationality", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "position", "label": "Position", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "agent", "label": "Player Agent", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 14, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "agentFee", "label": "Agent Fee", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 15, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Min(0)" },
      { "name": "originClub", "label": "Origin Club", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "transferType", "label": "Transfer Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "PERMANENT", "label": "Permanent", "displayOrder": 0 }, { "value": "LOAN", "label": "Loan", "displayOrder": 1 }, { "value": "FREE", "label": "Free Agent", "displayOrder": 2 }, { "value": "SWAP", "label": "Player Swap", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "transferFee", "label": "Transfer Fee", "fieldType": "CURRENCY", "isMandatory": true, "isLimited": true, "inSummary": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Min(0)" },
      { "name": "annualSalary", "label": "Annual Salary", "fieldType": "CURRENCY", "isMandatory": true, "isLimited": true, "inSummary": true, "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Min(0)" },
      { "name": "contractYears", "label": "Contract Length (years)", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Min(1) AND Max(10)" },
      { "name": "signOnBonus", "label": "Sign-On Bonus", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 33, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Min(0)" },
      { "name": "performanceClauses", "label": "Performance / Image Rights Clauses", "fieldType": "TEXTAREA", "displayOrder": 34, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "totalPackage", "label": "Total Deal Value (incl salary x years)", "fieldType": "CURRENCY", "isReadonly": true, "isLimited": true, "inSummary": true, "displayOrder": 35, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "defaultValue": "SUM(@{transferFee}, @{signOnBonus}, @{agentFee}, MULTIPLY(@{annualSalary}, @{contractYears}))" },
      { "name": "medicalPassed", "label": "Medical Passed", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{medicalPassed} == true, \"Medical must pass\")" },
      { "name": "workPermit", "label": "Work Permit / Visa Cleared", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{workPermit} == true, \"Work permit required\")" },
      { "name": "ffpCompliant", "label": "Within FFP / Salary Cap", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{ffpCompliant} == true, \"Must comply with FFP / cap\")" },
      { "name": "registrationWindowOpen", "label": "Registration Window Open", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 43, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{registrationWindowOpen} == true, \"Window must be open\")" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Sporting Director", "approverType": "ROLE", "roleName": "SPORTING_DIRECTOR", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 2, "name": "Head Coach", "approverType": "ROLE", "roleName": "HEAD_COACH", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "CFO", "approverType": "ROLE", "roleName": "CFO", "amountLimit": 5000000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 4, "name": "President / Chairman", "approverType": "ROLE", "roleName": "CHAIRMAN", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
