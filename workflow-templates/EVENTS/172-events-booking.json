{
  "_comment": "Event Booking Confirmation — confirm a corporate / private event booking.",
  "name": "Event Booking Confirmation",
  "code": "EBC",
  "description": "Confirm a corporate / private event booking with venue, date and pricing.",
  "icon": "event",
  "displayOrder": 172,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "EVENTS",
  "workflowTypeCode": "FINANCE",
  "titleTemplate": "@{bookingRef} - @{eventName} (@{eventDate})",
  "reminderEnabled": true, "reminderFrequencyHours": 12, "reminderMaxCount": 3, "reminderStartAfterHours": 12,
  "escalationEnabled": true, "escalationAfterHours": 48, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Booking", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Pricing & Logistics", "displayOrder": 1, "icon": "payments" },
      { "id": "temp_screen_3", "title": "Review", "displayOrder": 2, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Client", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Event Detail", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_4", "title": "Charges", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Logistics & Compliance", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" }
    ],
    "fields": [
      { "name": "bookingRef", "label": "Booking Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"EBC-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "submissionDate", "label": "Submission Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "eventCoordinator", "label": "Event Coordinator", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "clientName", "label": "Client Name", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "clientContact", "label": "Client Contact", "fieldType": "PHONE", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND Phone()" },
      { "name": "clientEmail", "label": "Client Email", "fieldType": "EMAIL", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND IS_EMAIL()" },
      { "name": "eventName", "label": "Event Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 20, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "eventType", "label": "Event Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "WEDDING", "label": "Wedding", "displayOrder": 0 }, { "value": "CONFERENCE", "label": "Conference", "displayOrder": 1 }, { "value": "GALA", "label": "Gala / Awards", "displayOrder": 2 }, { "value": "PRIVATE", "label": "Private Party", "displayOrder": 3 }, { "value": "TRADESHOW", "label": "Trade Show / Expo", "displayOrder": 4 }, { "value": "CONCERT", "label": "Concert / Festival", "displayOrder": 5 } ], "validation": "Required()" },
      { "name": "eventDate", "label": "Event Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required() AND DateAfter(\"today\", \"Must be future\")" },
      { "name": "venue", "label": "Venue", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "guestCount", "label": "Guest Count", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 24, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required() AND Min(1)" },
      { "name": "venueFee", "label": "Venue Fee", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Min(0)" },
      { "name": "cateringPerHead", "label": "Catering per Head", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Min(0)" },
      { "name": "cateringTotal", "label": "Catering Total", "fieldType": "CURRENCY", "isReadonly": true, "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "defaultValue": "MULTIPLY(@{cateringPerHead}, @{guestCount})" },
      { "name": "extras", "label": "Extras / AV / Decor", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 33, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Min(0)" },
      { "name": "totalCost", "label": "Total Booking Value", "fieldType": "CURRENCY", "isReadonly": true, "isLimited": true, "inSummary": true, "displayOrder": 34, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "defaultValue": "SUM(@{venueFee}, @{cateringTotal}, @{extras})" },
      { "name": "depositPaid", "label": "Deposit Paid", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 35, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "ValidWhen(@{depositPaid} == true, \"Deposit required\")" },
      { "name": "venueAvailable", "label": "Venue Confirmed Available", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{venueAvailable} == true, \"Venue availability must be confirmed\")" },
      { "name": "permitsRequired", "label": "Permits / Licenses Required?", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5" },
      { "name": "insuranceArranged", "label": "Public Liability Insurance Arranged", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{insuranceArranged} == true, \"Insurance required\")" },
      { "name": "contractSigned", "label": "Contract Signed by Client", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 43, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{contractSigned} == true, \"Contract must be signed\")" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Event Coordinator", "approverType": "ROLE", "roleName": "EVENT_COORDINATOR", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Operations Manager", "approverType": "ROLE", "roleName": "OPS_MANAGER", "amountLimit": 50000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Director of Events", "approverType": "ROLE", "roleName": "DIR_EVENTS", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
