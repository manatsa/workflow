{
  "_comment": "Security Clearance Request — vet personnel for access to classified information or facilities.",
  "name": "Security Clearance Request",
  "code": "DSC",
  "description": "Vet personnel for access to classified information or secured facilities.",
  "icon": "shield",
  "displayOrder": 71,
  "requiresApproval": true,
  "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "NON_FINANCIAL",
  "industryCode": "DEFENCE",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{clearanceRef} - @{applicantName} (@{level})",
  "reminderEnabled": true, "reminderFrequencyHours": 48, "reminderMaxCount": 3, "reminderStartAfterHours": 48,
  "escalationEnabled": true, "escalationAfterHours": 168, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Applicant", "displayOrder": 0, "icon": "person" },
      { "id": "temp_screen_2", "title": "Clearance", "displayOrder": 1, "icon": "shield" },
      { "id": "temp_screen_3", "title": "Background Check", "displayOrder": 2, "icon": "search" },
      { "id": "temp_screen_4", "title": "Documents", "displayOrder": 3, "icon": "attach_file" },
      { "id": "temp_screen_5", "title": "Review", "displayOrder": 4, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Applicant", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Clearance Level", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_3", "title": "Vetting Results", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_4", "title": "Documents", "displayOrder": 3, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_4" }
    ],
    "fields": [
      { "name": "clearanceRef", "label": "Clearance Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"DSC-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "submissionDate", "label": "Submission Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "applicantName", "label": "Applicant Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required() AND MinLength(2)" },
      { "name": "serviceNumber", "label": "Service / Employee Number", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "rankOrGrade", "label": "Rank / Grade", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 4, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()" },
      { "name": "unit", "label": "Unit / Department", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 5, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()" },
      { "name": "idNumber", "label": "National ID", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 6, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()" },
      { "name": "level", "label": "Clearance Level Requested", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "CONFIDENTIAL", "label": "Confidential", "displayOrder": 0 }, { "value": "SECRET", "label": "Secret", "displayOrder": 1 }, { "value": "TOP_SECRET", "label": "Top Secret", "displayOrder": 2 }, { "value": "TOP_SECRET_SCI", "label": "Top Secret / SCI", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "reason", "label": "Reason / Assignment", "fieldType": "TEXTAREA", "isMandatory": true, "inSummary": true, "displayOrder": 11, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2", "validation": "Required() AND MinLength(30)" },
      { "name": "validityYears", "label": "Validity (years)", "fieldType": "NUMBER", "isMandatory": true, "defaultValue": "5", "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2", "validation": "Required() AND Min(1) AND Max(10)" },
      { "name": "previousClearance", "label": "Previous Clearance?", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2" },
      { "name": "criminalRecordCheck", "label": "Criminal Record Check", "fieldType": "SELECT", "isMandatory": true, "defaultValue": "CLEAR", "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "CLEAR", "label": "Clear", "displayOrder": 0 }, { "value": "RECORD", "label": "Record Found", "displayOrder": 1 } ], "validation": "Required()" },
      { "name": "creditCheck", "label": "Financial / Credit Check", "fieldType": "SELECT", "isMandatory": true, "defaultValue": "CLEAR", "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "CLEAR", "label": "Clear", "displayOrder": 0 }, { "value": "CONCERNS", "label": "Concerns", "displayOrder": 1 } ], "validation": "Required()" },
      { "name": "foreignTiesCheck", "label": "Foreign Ties Assessment", "fieldType": "SELECT", "isMandatory": true, "defaultValue": "CLEAR", "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "CLEAR", "label": "Clear", "displayOrder": 0 }, { "value": "FLAGS", "label": "Flags Present", "displayOrder": 1 } ], "validation": "Required()" },
      { "name": "referencesVerified", "label": "References Verified", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3", "validation": "ValidWhen(@{referencesVerified} == true, \"References must be verified\")" },
      { "name": "polygraphRequired", "label": "Polygraph Required?", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 24, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3" },
      { "name": "vettingNotes", "label": "Vetting Officer Notes", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 25, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3", "validation": "Required() AND MinLength(30)" },
      { "name": "applicationForm", "label": "Signed SF-86 / Application Form", "fieldType": "FILE", "isMandatory": true, "displayOrder": 30, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_4", "allowedFileTypes": "pdf", "maxFileSize": 10485760, "validation": "Required()" },
      { "name": "vettingReport", "label": "Vetting Report", "fieldType": "FILE", "isMandatory": true, "displayOrder": 31, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_4", "allowedFileTypes": "pdf,doc,docx", "maxFileSize": 10485760, "validation": "Required()" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Security Vetting Officer", "approverType": "ROLE", "roleName": "VETTING_OFFICER", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 2, "name": "Unit Commander", "approverType": "ROLE", "roleName": "UNIT_COMMANDER", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Director of Security", "approverType": "ROLE", "roleName": "DIRECTOR_SECURITY", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
