{
  "_comment": "Pharma Batch Release — QP release of a pharmaceutical manufacturing batch for market.",
  "name": "Pharma Batch Release",
  "code": "PBR",
  "description": "Qualified-Person release of a pharmaceutical manufacturing batch for distribution.",
  "icon": "verified",
  "displayOrder": 78,
  "requiresApproval": true,
  "commentsMandatoryOnReject": true, "commentsMandatoryOnEscalate": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "NON_FINANCIAL",
  "industryCode": "PHARMA",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{batchRef} - @{productName} (@{batchNumber})",
  "reminderEnabled": true, "reminderFrequencyHours": 24, "reminderMaxCount": 3, "reminderStartAfterHours": 24,
  "escalationEnabled": true, "escalationAfterHours": 96, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Batch", "displayOrder": 0, "icon": "inventory" },
      { "id": "temp_screen_2", "title": "Quality Results", "displayOrder": 1, "icon": "science" },
      { "id": "temp_screen_3", "title": "Deviations & Controls", "displayOrder": 2, "icon": "gpp_good" },
      { "id": "temp_screen_4", "title": "Documents", "displayOrder": 3, "icon": "attach_file" },
      { "id": "temp_screen_5", "title": "Review", "displayOrder": 4, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Batch Identity", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Manufacture & Expiry", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "QC Results", "displayOrder": 2, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Deviations / CAPA", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_5", "title": "Release Checks", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_6", "title": "Documents", "displayOrder": 5, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_4" }
    ],
    "fields": [
      { "name": "batchRef", "label": "Release Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"PBR-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "requestDate", "label": "Request Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "productName", "label": "Product Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()" },
      { "name": "productCode", "label": "Product Code / SKU", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "batchNumber", "label": "Batch Number", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 4, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "batchSize", "label": "Batch Size (units)", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 5, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required() AND Min(1)" },
      { "name": "mfgDate", "label": "Manufacture Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "expiryDate", "label": "Expiry Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND DateAfter(\"today\", \"Expiry must be future\")" },
      { "name": "manufacturingSite", "label": "Manufacturing Site", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "marketCountries", "label": "Intended Markets", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "qcTests", "label": "QC Test Results", "fieldType": "TABLE", "isMandatory": true, "displayOrder": 20, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "tableMinRows": 1, "tableMaxRows": 50, "tableStriped": true, "tableBordered": true,
        "tableColumns": "[{\"name\":\"testName\",\"label\":\"Test\",\"type\":\"TEXT\",\"width\":220,\"required\":true},{\"name\":\"specification\",\"label\":\"Specification\",\"type\":\"TEXT\",\"width\":220,\"required\":true},{\"name\":\"result\",\"label\":\"Result\",\"type\":\"TEXT\",\"width\":180,\"required\":true},{\"name\":\"passFail\",\"label\":\"Pass/Fail\",\"type\":\"SELECT\",\"width\":120,\"required\":true,\"options\":[\"PASS\",\"FAIL\"]}]" },
      { "name": "hasDeviations", "label": "Any Deviations / OOS?", "fieldType": "YES_NO", "defaultValue": "false", "inSummary": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4" },
      { "name": "deviationRefs", "label": "Deviation / CAPA References", "fieldType": "TEXT", "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4", "visibilityExpression": "@{hasDeviations} == true" },
      { "name": "deviationImpact", "label": "Impact Assessment", "fieldType": "TEXTAREA", "displayOrder": 32, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "visibilityExpression": "@{hasDeviations} == true",
        "validation": "ValidWhen(@{hasDeviations} == false OR HAS_MIN_LENGTH(@{deviationImpact}, 30), \"Impact assessment required\")" },
      { "name": "gmpCompliant", "label": "GMP Compliant", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{gmpCompliant} == true, \"Batch must be GMP-compliant\")" },
      { "name": "stabilityDataOk", "label": "Stability Data Acceptable", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{stabilityDataOk} == true, \"Stability data required\")" },
      { "name": "labelsApproved", "label": "Labels & Leaflets Approved", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{labelsApproved} == true, \"Labels must be approved\")" },
      { "name": "recallSimReady", "label": "Recall Procedure Ready", "fieldType": "YES_NO", "defaultValue": "true", "displayOrder": 43, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5" },
      { "name": "coa", "label": "Certificate of Analysis (COA)", "fieldType": "FILE", "isMandatory": true, "displayOrder": 50, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_6", "allowedFileTypes": "pdf", "maxFileSize": 10485760, "validation": "Required()" },
      { "name": "bmrFile", "label": "Batch Manufacturing Record (BMR)", "fieldType": "FILE", "isMandatory": true, "displayOrder": 51, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_6", "allowedFileTypes": "pdf", "maxFileSize": 20971520, "validation": "Required()" },
      { "name": "deviationReports", "label": "Deviation / CAPA Reports", "fieldType": "FILE", "multiple": true, "displayOrder": 52, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_6", "allowedFileTypes": "pdf,doc,docx", "maxFileSize": 10485760, "maxFiles": 10, "visibilityExpression": "@{hasDeviations} == true" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "QA Officer", "approverType": "ROLE", "roleName": "QA_OFFICER", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "QA Manager", "approverType": "ROLE", "roleName": "QA_MANAGER", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Qualified Person (QP)", "approverType": "ROLE", "roleName": "QUALIFIED_PERSON", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
