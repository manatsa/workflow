{
  "_comment": "Stock Transfer — move stock between stores / warehouses with dispatch and receipt controls.",
  "name": "Retail Stock Transfer",
  "code": "RST",
  "description": "Transfer stock between stores, warehouses or DCs with dispatch and receipt controls.",
  "icon": "local_shipping",
  "displayOrder": 87,
  "requiresApproval": true,
  "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "RETAIL",
  "workflowTypeCode": "REQUISITION",
  "titleTemplate": "@{transferRef} - @{fromLocation} → @{toLocation}",
  "reminderEnabled": true, "reminderFrequencyHours": 4, "reminderMaxCount": 4, "reminderStartAfterHours": 2,
  "escalationEnabled": true, "escalationAfterHours": 24, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Transfer", "displayOrder": 0, "icon": "swap_horiz" },
      { "id": "temp_screen_2", "title": "Items", "displayOrder": 1, "icon": "inventory" },
      { "id": "temp_screen_3", "title": "Logistics", "displayOrder": 2, "icon": "local_shipping" },
      { "id": "temp_screen_4", "title": "Documents", "displayOrder": 3, "icon": "attach_file" },
      { "id": "temp_screen_5", "title": "Review", "displayOrder": 4, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "From / To", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Stock Lines", "displayOrder": 2, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Transport", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_5", "title": "Documents", "displayOrder": 4, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_4" }
    ],
    "fields": [
      { "name": "transferRef", "label": "Transfer Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"RST-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "requestDate", "label": "Request Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "requestedBy", "label": "Requested By", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "transferType", "label": "Transfer Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [ { "value": "DC_TO_STORE", "label": "DC → Store", "displayOrder": 0 }, { "value": "STORE_TO_STORE", "label": "Store → Store", "displayOrder": 1 }, { "value": "STORE_TO_DC", "label": "Store → DC", "displayOrder": 2 }, { "value": "DC_TO_DC", "label": "DC → DC", "displayOrder": 3 }, { "value": "RETURN_TO_SUPPLIER", "label": "Return to Supplier", "displayOrder": 4 } ], "validation": "Required()" },
      { "name": "fromLocation", "label": "From Location", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "toLocation", "label": "To Location", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "requiredBy", "label": "Required By Date", "fieldType": "DATE", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "reason", "label": "Reason", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "REPLENISHMENT", "label": "Replenishment", "displayOrder": 0 }, { "value": "OVERSTOCK_REBAL", "label": "Overstock Rebalance", "displayOrder": 1 }, { "value": "PROMOTION", "label": "Promotion Setup", "displayOrder": 2 }, { "value": "NEW_STORE", "label": "New Store Opening", "displayOrder": 3 }, { "value": "RECALL", "label": "Recall / Return", "displayOrder": 4 }, { "value": "CUSTOMER_ORDER", "label": "Customer Order", "displayOrder": 5 } ], "validation": "Required()" },
      { "name": "stockLines", "label": "Stock Lines", "fieldType": "TABLE", "isMandatory": true, "displayOrder": 20, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "tableMinRows": 1, "tableMaxRows": 500, "tableStriped": true, "tableBordered": true,
        "tableColumns": "[{\"name\":\"sku\",\"label\":\"SKU\",\"type\":\"TEXT\",\"width\":140,\"required\":true},{\"name\":\"productName\",\"label\":\"Product\",\"type\":\"TEXT\",\"width\":280,\"required\":true},{\"name\":\"qtyRequested\",\"label\":\"Qty Requested\",\"type\":\"NUMBER\",\"width\":130,\"required\":true},{\"name\":\"qtyShipped\",\"label\":\"Qty Shipped\",\"type\":\"NUMBER\",\"width\":130},{\"name\":\"qtyReceived\",\"label\":\"Qty Received\",\"type\":\"NUMBER\",\"width\":130},{\"name\":\"unitCost\",\"label\":\"Unit Cost\",\"type\":\"NUMBER\",\"width\":120}]", "validation": "MinRows(1, \"At least one stock line required\")" },
      { "name": "totalUnitsRequested", "label": "Total Units Requested", "fieldType": "NUMBER", "isReadonly": true, "inSummary": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "defaultValue": "SUM_COLUMN(\"stockLines\", \"qtyRequested\")" },
      { "name": "totalValue", "label": "Total Transfer Value", "fieldType": "CURRENCY", "isLimited": true, "inSummary": true, "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3" },
      { "name": "transportMode", "label": "Transport Mode", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "options": [ { "value": "OWN_FLEET", "label": "Own Fleet", "displayOrder": 0 }, { "value": "3PL", "label": "3PL / Contract Carrier", "displayOrder": 1 }, { "value": "COURIER", "label": "Courier / Parcel", "displayOrder": 2 }, { "value": "COLLECTION", "label": "Self-Collection", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "carrier", "label": "Carrier", "fieldType": "TEXT", "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4" },
      { "name": "dispatchDate", "label": "Planned Dispatch Date", "fieldType": "DATE", "isMandatory": true, "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4", "validation": "Required()" },
      { "name": "vehicleReg", "label": "Vehicle Reg. / Waybill", "fieldType": "TEXT", "displayOrder": 33, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4" },
      { "name": "packingList", "label": "Packing List", "fieldType": "FILE", "displayOrder": 40, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5", "allowedFileTypes": "pdf,xls,xlsx", "maxFileSize": 10485760 },
      { "name": "deliveryNote", "label": "Delivery Note / GRN", "fieldType": "FILE", "displayOrder": 41, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5", "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 10485760 }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Store / Warehouse Manager", "approverType": "ROLE", "roleName": "WAREHOUSE_MANAGER", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Regional Operations Manager", "approverType": "ROLE", "roleName": "REGIONAL_OPS_MANAGER", "amountLimit": 50000, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 3, "name": "Head of Supply Chain", "approverType": "ROLE", "roleName": "HEAD_SUPPLY_CHAIN", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
