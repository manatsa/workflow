{
  "_comment": "Store Opening — open a new retail outlet with fit-out, staffing and licensing.",
  "name": "Retail Store Opening",
  "code": "RSO",
  "description": "Open a new retail outlet: site approval, fit-out, staffing, licensing and opening inventory.",
  "icon": "storefront",
  "displayOrder": 84,
  "requiresApproval": true,
  "commentsMandatoryOnReject": true, "commentsMandatoryOnEscalate": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "RETAIL",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{storeRef} - @{storeName} (@{city})",
  "reminderEnabled": true, "reminderFrequencyHours": 48, "reminderMaxCount": 3, "reminderStartAfterHours": 48,
  "escalationEnabled": true, "escalationAfterHours": 168, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Store Details", "displayOrder": 0, "icon": "storefront" },
      { "id": "temp_screen_2", "title": "Site & Fit-Out", "displayOrder": 1, "icon": "construction" },
      { "id": "temp_screen_3", "title": "Staffing & Licensing", "displayOrder": 2, "icon": "groups" },
      { "id": "temp_screen_4", "title": "Financials", "displayOrder": 3, "icon": "payments" },
      { "id": "temp_screen_5", "title": "Documents", "displayOrder": 4, "icon": "attach_file" },
      { "id": "temp_screen_6", "title": "Review", "displayOrder": 5, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference & Store", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Format & Location", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Site / Lease", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Fit-Out & IT", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Staffing", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_6", "title": "Licensing", "displayOrder": 5, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_7", "title": "Capex & OpEx", "displayOrder": 6, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_4" },
      { "id": "temp_grp_8", "title": "Documents", "displayOrder": 7, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_5" }
    ],
    "fields": [
      { "name": "storeRef", "label": "Store Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"RSO-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "proposalDate", "label": "Proposal Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "storeName", "label": "Store / Brand Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()" },
      { "name": "storeCode", "label": "Store Code", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "storeFormat", "label": "Format", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "FLAGSHIP", "label": "Flagship", "displayOrder": 0 }, { "value": "STANDARD", "label": "Standard", "displayOrder": 1 }, { "value": "EXPRESS", "label": "Express / Convenience", "displayOrder": 2 }, { "value": "KIOSK", "label": "Kiosk", "displayOrder": 3 }, { "value": "POP_UP", "label": "Pop-Up", "displayOrder": 4 }, { "value": "OUTLET", "label": "Outlet", "displayOrder": 5 } ], "validation": "Required()" },
      { "name": "city", "label": "City", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "address", "label": "Address", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 12, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND MinLength(10)" },
      { "name": "plannedOpening", "label": "Planned Opening Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 13, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND DateAfter(\"today\", \"Opening must be future\")" },
      { "name": "leaseType", "label": "Lease Type", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "OWNED", "label": "Owned", "displayOrder": 0 }, { "value": "LONG_LEASE", "label": "Long Lease (>5 yrs)", "displayOrder": 1 }, { "value": "SHORT_LEASE", "label": "Short Lease (<5 yrs)", "displayOrder": 2 }, { "value": "CONCESSION", "label": "Concession / Shop-in-Shop", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "monthlyRent", "label": "Monthly Rent", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Min(0)" },
      { "name": "areaSqm", "label": "Area (m²)", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required() AND Min(1)" },
      { "name": "leaseExpiry", "label": "Lease Expiry", "fieldType": "DATE", "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3" },
      { "name": "fitoutComplete", "label": "Fit-Out Complete", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "posInstalled", "label": "POS / EPOS Installed", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "networkLive", "label": "Network / Connectivity Live", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "securitySystemInstalled", "label": "CCTV / Alarm Installed", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 33, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "staffHired", "label": "Staff Hired", "fieldType": "NUMBER", "isMandatory": true, "defaultValue": "0", "inSummary": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "Required() AND Min(0)" },
      { "name": "staffRequired", "label": "Staff Required", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "Required() AND Min(1)" },
      { "name": "storeManagerName", "label": "Store Manager", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 42, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "Required()" },
      { "name": "businessLicence", "label": "Business Licence Obtained", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 50, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "validation": "ValidWhen(@{businessLicence} == true, \"Business licence required\")" },
      { "name": "fireSafetyCert", "label": "Fire Safety Certificate", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 51, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "validation": "ValidWhen(@{fireSafetyCert} == true, \"Fire certificate required\")" },
      { "name": "healthCert", "label": "Health Certificate (if F&B)", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 52, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6" },
      { "name": "capexBudget", "label": "Total Capex Budget", "fieldType": "CURRENCY", "isMandatory": true, "isLimited": true, "inSummary": true, "displayOrder": 60, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_7", "validation": "Required() AND Min(0)" },
      { "name": "openingStockValue", "label": "Opening Inventory Value", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 61, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_7", "validation": "Required() AND Min(0)" },
      { "name": "year1SalesForecast", "label": "Year 1 Sales Forecast", "fieldType": "CURRENCY", "isMandatory": true, "inSummary": true, "displayOrder": 62, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_7", "validation": "Required() AND Min(0)" },
      { "name": "paybackMonths", "label": "Projected Payback (months)", "fieldType": "NUMBER", "displayOrder": 63, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_7", "validation": "Min(1)" },
      { "name": "feasibility", "label": "Feasibility Study / Business Case", "fieldType": "FILE", "isMandatory": true, "displayOrder": 70, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_8", "allowedFileTypes": "pdf,doc,docx,xls,xlsx", "maxFileSize": 20971520, "validation": "Required()" },
      { "name": "leaseAgreement", "label": "Signed Lease Agreement", "fieldType": "FILE", "isMandatory": true, "displayOrder": 71, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_8", "allowedFileTypes": "pdf", "maxFileSize": 20971520, "validation": "Required()" },
      { "name": "licences", "label": "Licences & Certificates", "fieldType": "FILE", "multiple": true, "displayOrder": 72, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_8", "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 10485760, "maxFiles": 10 }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Regional Manager", "approverType": "ROLE", "roleName": "REGIONAL_MANAGER", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Head of Operations", "approverType": "ROLE", "roleName": "HEAD_OF_OPERATIONS", "amountLimit": 500000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "CFO", "approverType": "ROLE", "roleName": "CFO", "amountLimit": 5000000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 4, "name": "CEO / Board", "approverType": "ROLE", "roleName": "CEO", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
