          "name": "transactions",
          "label": "Suspicious Transactions",
          "fieldType": "TABLE",
          "isMandatory": true,
          "displayOrder": 40,
          "columnSpan": 2,
          "screenId": "temp_screen_4",
          "fieldGroupId": "temp_grp_5",
          "tableMinRows": 1,
          "tableMaxRows": 100,
          "tableStriped": true,
          "tableBordered": true,
          "tableColumns": "[{\"name\":\"date\",\"label\":\"Date\",\"type\":\"DATE\",\"width\":120,\"required\":true},{\"name\":\"reference\",\"label\":\"Reference\",\"type\":\"TEXT\",\"width\":160,\"required\":true},{\"name\":\"channel\",\"label\":\"Channel\",\"type\":\"TEXT\",\"width\":120},{\"name\":\"counterparty\",\"label\":\"Counterparty\",\"type\":\"TEXT\",\"width\":200},{\"name\":\"amount\",\"label\":\"Amount\",\"type\":\"NUMBER\",\"width\":120,\"required\":true},{\"name\":\"currency\",\"label\":\"Cur\",\"type\":\"TEXT\",\"width\":70,\"defaultValue\":\"USD\"}]",
          "validation": "MinRows(1, \"Add at least one suspicious transaction\")"
        },
        {
          "name": "totalSuspiciousAmount",
          "label": "Total Suspicious Amount",
          "fieldType": "CURRENCY",
          "isReadonly": true,
          "isLimited": true,
          "inSummary": true,
          "displayOrder": 41,
          "columnSpan": 2,
          "screenId": "temp_screen_4",
          "fieldGroupId": "temp_grp_5",
          "defaultValue": "SUM_COLUMN(\"transactions\", \"amount\")"
        },
        {
          "name": "narrative",
          "label": "Narrative — what makes this suspicious?",
          "fieldType": "TEXTAREA",
          "tooltip": "Describe who, what, when, where, why suspicious, and impact. Be factual and detailed.",
          "isMandatory": true,
          "inSummary": true,
          "displayOrder": 50,
          "columnSpan": 2,
          "screenId": "temp_screen_5",
          "fieldGroupId": "temp_grp_6",
          "validation": "Required() AND MinLength(100, \"Narrative must be at least 100 characters\") AND MaxLength(10000)"
        },
        {
          "name": "actionTaken",
          "label": "Action Already Taken",
          "fieldType": "TEXTAREA",
          "displayOrder": 51,
          "columnSpan": 2,
          "screenId": "temp_screen_5",
          "fieldGroupId": "temp_grp_6"
        },
        {
          "name": "recommendedAction",
