          "fieldGroupId": "temp_grp_2",
          "options": [
            {
              "value": "INDIVIDUAL",
              "label": "Individual",
              "displayOrder": 0
            },
            {
              "value": "ENTITY",
              "label": "Legal Entity",
              "displayOrder": 1
            },
            {
              "value": "NON_CUSTOMER",
              "label": "Non-Customer",
              "displayOrder": 2
            }
          ],
          "validation": "Required()"
        },
        {
          "name": "subjectName",
          "label": "Subject Name",
          "fieldType": "TEXT",
          "isMandatory": true,
          "isTitle": true,
          "inSummary": true,
          "displayOrder": 11,
          "columnSpan": 1,
          "screenId": "temp_screen_2",
          "fieldGroupId": "temp_grp_2",
          "validation": "Required() AND MinLength(2)"
        },
        {
          "name": "customerNumber",
          "label": "Customer Number (if any)",
