{
  "_comment": "Suspicious Transaction Report (STR) — internal AML escalation to MLRO for regulator filing decision.",
  "name": "Suspicious Transaction Report (STR)",
  "code": "STR",
  "description": "Raise an internal AML alert/STR to MLRO for review and possible filing with the FIU/regulator.",
  "icon": "warning_amber",
  "displayOrder": 28,
  "requiresApproval": true,
  "commentsMandatory": false,
  "commentsMandatoryOnReject": true,
  "commentsMandatoryOnEscalate": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "NON_FINANCIAL",
  "titleTemplate": "@{strRef} - @{subjectName} (@{suspicionType})",
  "reminderEnabled": true,
  "reminderFrequencyHours": 24,
  "reminderMaxCount": 5,
  "reminderStartAfterHours": 12,
  "escalationEnabled": true,
  "escalationAfterHours": 48,
  "escalationAction": "NOTIFY_ADMIN",
  "reminderEmailSubject": "STR @{referenceNumber} - urgent review required",
  "reminderEmailBody": "<p>An STR <strong>@{referenceNumber}</strong> requires your urgent review. Confidentiality applies.</p>",
  "forms": [
    {
      "name": "Main Form",
      "displayOrder": 0,
      "screens": [
        {
          "id": "temp_screen_1",
          "title": "Report Info",
          "displayOrder": 0,
          "icon": "info"
        },
        {
          "id": "temp_screen_2",
          "title": "Subject",
          "displayOrder": 1,
          "icon": "person"
        },
        {
          "id": "temp_screen_3",
          "title": "Suspicious Activity",
          "displayOrder": 2,
          "icon": "warning"
        },
        {
          "id": "temp_screen_4",
