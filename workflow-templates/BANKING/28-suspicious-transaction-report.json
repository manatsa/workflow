        {
          "name": "evidence",
          "label": "Supporting Evidence",
          "fieldType": "FILE",
          "multiple": true,
          "displayOrder": 60,
          "columnSpan": 2,
          "screenId": "temp_screen_5",
          "fieldGroupId": "temp_grp_7",
          "allowedFileTypes": "pdf,jpg,jpeg,png,doc,docx,xls,xlsx,csv",
          "maxFileSize": 20971520,
          "maxFiles": 30
        }
      ]
