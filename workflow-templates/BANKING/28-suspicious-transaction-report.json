            },
            {
              "value": "FREEZE",
              "label": "Freeze Account",
              "displayOrder": 1
            },
            {
              "value": "EXIT",
              "label": "Exit Relationship",
              "displayOrder": 2
            },
            {
              "value": "FILE_STR",
              "label": "File STR with FIU",
              "displayOrder": 3
            }
          ],
          "validation": "Required()"
