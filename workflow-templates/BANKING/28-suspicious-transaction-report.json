            {
              "value": "HIGH_RISK_JURISDICTION",
              "label": "High-Risk Jurisdiction",
              "displayOrder": 2
            },
            {
              "value": "TERRORISM_FINANCING",
              "label": "Suspected Terrorism Financing",
              "displayOrder": 3
            },
            {
              "value": "FRAUD",
              "label": "Suspected Fraud",
              "displayOrder": 4
            },
            {
              "value": "TAX_EVASION",
              "label": "Suspected Tax Evasion",
              "displayOrder": 5
            },
            {
              "value": "CASH_INTENSIVE",
