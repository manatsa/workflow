          "isTitle": true,
          "inSummary": true,
          "displayOrder": 0,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_1"
        },
        {
          "name": "reportDate",
          "label": "Report Date",
          "fieldType": "DATE",
          "defaultValue": "TODAY()",
          "isReadonly": true,
          "inSummary": true,
          "displayOrder": 1,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_1"
        },
        {
          "name": "reportedBy",
          "label": "Reported By",
          "fieldType": "TEXT",
          "defaultValue": "CURRENT_USER()",
          "isReadonly": true,
          "inSummary": true,
          "displayOrder": 2,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_1"
        },
        {
          "name": "branch",
          "label": "Branch / Unit",
