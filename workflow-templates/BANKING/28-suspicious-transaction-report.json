          "isMandatory": true,
          "displayOrder": 4,
          "columnSpan": 2,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_1",
          "validation": "IsTrue(\"You must acknowledge the confidentiality notice\")"
        },
        {
          "name": "subjectType",
          "label": "Subject Type",
