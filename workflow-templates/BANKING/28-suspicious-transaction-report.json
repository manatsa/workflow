          "displayOrder": 31,
          "columnSpan": 1,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_4"
        },
        {
          "name": "activityStartDate",
          "label": "Activity Started",
          "fieldType": "DATE",
          "isMandatory": true,
          "displayOrder": 32,
          "columnSpan": 1,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_4",
          "validation": "Required()"
        },
        {
          "name": "activityEndDate",
          "label": "Activity Ended (or ongoing)",
          "fieldType": "DATE",
          "displayOrder": 33,
          "columnSpan": 1,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_4"
        },
