          "visibilityExpression": "@{hasDisputedTxns} == true",
          "tableMinRows": 0,
          "tableMaxRows": 50,
          "tableStriped": true,
          "tableBordered": true,
          "tableColumns": "[{\"name\":\"txnDate\",\"label\":\"Date\",\"type\":\"DATE\",\"width\":120,\"required\":true},{\"name\":\"txnRef\",\"label\":\"Reference\",\"type\":\"TEXT\",\"width\":160,\"required\":true},{\"name\":\"description\",\"label\":\"Description\",\"type\":\"TEXT\",\"width\":250},{\"name\":\"amount\",\"label\":\"Amount\",\"type\":\"NUMBER\",\"width\":120,\"required\":true},{\"name\":\"reason\",\"label\":\"Dispute Reason\",\"type\":\"TEXT\",\"width\":200,\"required\":true}]"
        },
