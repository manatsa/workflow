          "fieldType": "CURRENCY",
          "isReadonly": true,
          "isLimited": true,
          "inSummary": true,
          "displayOrder": 42,
          "columnSpan": 2,
          "screenId": "temp_screen_4",
          "fieldGroupId": "temp_grp_5",
          "visibilityExpression": "@{hasDisputedTxns} == true",
