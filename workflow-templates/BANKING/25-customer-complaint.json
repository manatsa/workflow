{
  "_comment": "Customer Complaint & Dispute Resolution — capture, classify, investigate and resolve customer issues with SLA tracking.",
  "name": "Customer Complaint & Dispute",
  "code": "CMP",
  "description": "Log and route customer complaints (including transaction disputes) through investigation and resolution.",
  "icon": "support_agent",
  "displayOrder": 25,
  "requiresApproval": true,
  "commentsMandatory": false,
  "commentsMandatoryOnReject": true,
  "commentsMandatoryOnEscalate": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "titleTemplate": "@{caseNumber} - @{customerName} (@{category})",
  "reminderEnabled": true,
  "reminderFrequencyHours": 24,
  "reminderMaxCount": 5,
  "reminderStartAfterHours": 24,
  "escalationEnabled": true,
  "escalationAfterHours": 96,
  "escalationAction": "NOTIFY_ADMIN",
  "reminderEmailSubject": "Reminder: Complaint @{referenceNumber} approaching SLA",
  "reminderEmailBody": "<p>Complaint <strong>@{referenceNumber}</strong> from @{submitterName} is awaiting action (pending @{daysPending} day(s)).</p>",
