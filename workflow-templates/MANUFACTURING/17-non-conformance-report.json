          "inSummary": true,
          "displayOrder": 52,
          "columnSpan": 1,
          "screenId": "temp_s3",
          "fieldGroupId": "temp_g6",
          "validation": "Min(0)"
        },
        {
          "name": "customerNotificationRequired",
          "label": "Customer Notification Required?",
