        {
          "name": "supplier",
          "label": "Supplier (if applicable)",
          "fieldType": "TEXT",
          "displayOrder": 27,
          "columnSpan": 1,
          "screenId": "temp_s2",
          "fieldGroupId": "temp_g3",
          "visibilityExpression": "@{source} == 'INCOMING' OR @{source} == 'SUPPLIER'"
        },
        {
          "name": "poNumber",
          "label": "PO Number (if applicable)",
          "fieldType": "TEXT",
          "displayOrder": 28,
          "columnSpan": 1,
          "screenId": "temp_s2",
          "fieldGroupId": "temp_g3",
          "visibilityExpression": "@{source} == 'INCOMING' OR @{source} == 'SUPPLIER'"
        },
