          "name": "preventiveAction",
          "label": "Preventive Action (prevent recurrence)",
          "fieldType": "TEXTAREA",
          "isMandatory": true,
          "displayOrder": 73,
          "columnSpan": 1,
          "screenId": "temp_s4",
          "fieldGroupId": "temp_g8",
          "validation": "Required() AND MinLength(30)"
        },
