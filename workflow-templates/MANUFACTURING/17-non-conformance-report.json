              "displayOrder": 2
            },
            {
              "value": "MATERIAL",
              "label": "Material Issue",
              "displayOrder": 3
            },
            {
              "value": "ASSEMBLY",
              "label": "Assembly Error",
              "displayOrder": 4
            },
            {
              "value": "DOCUMENTATION",
              "label": "Documentation Error",
              "displayOrder": 5
            },
            {
              "value": "PACKAGING",
              "label": "Packaging / Labeling",
              "displayOrder": 6
