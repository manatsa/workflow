{
  "_comment": "Non-Conformance Report (NCR) — record defects, deviations, and initiate corrective action.",
  "name": "Non-Conformance Report",
  "code": "NCR",
  "description": "Report a quality non-conformance. Captures details, disposition, and corrective/preventive action (CAPA).",
  "icon": "report",
  "displayOrder": 210,
  "requiresApproval": true,
  "commentsMandatory": true,
  "commentsMandatoryOnReject": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "workflowCategory": "NON_FINANCIAL",
  "titleTemplate": "@{ncrNumber} - @{partNumber} (@{severity})",
  "reminderEnabled": true,
  "reminderFrequencyHours": 12,
  "reminderMaxCount": 4,
  "escalationEnabled": true,
  "escalationAfterHours": 48,
  "escalationAction": "NOTIFY_ADMIN",
