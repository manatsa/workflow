              "displayOrder": 0
            },
            {
              "value": "IN_PROCESS",
              "label": "In-Process Inspection",
              "displayOrder": 1
            },
            {
              "value": "FINAL",
              "label": "Final Inspection",
              "displayOrder": 2
            },
            {
              "value": "AUDIT",
              "label": "Internal Audit",
              "displayOrder": 3
            },
            {
              "value": "CUSTOMER",
              "label": "Customer Complaint",
              "displayOrder": 4
            },
            {
              "value": "FIELD",
              "label": "Field Failure",
              "displayOrder": 5
            },
            {
              "value": "SUPPLIER",
              "label": "Supplier Return",
              "displayOrder": 6
            }
