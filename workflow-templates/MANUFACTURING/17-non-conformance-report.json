          "fieldType": "TEXT",
          "isMandatory": true,
          "inSummary": true,
          "displayOrder": 74,
          "columnSpan": 1,
          "screenId": "temp_s4",
          "fieldGroupId": "temp_g8",
          "validation": "Required()"
        },
