        },
        {
          "name": "quantityInspected",
          "label": "Quantity Inspected",
          "fieldType": "NUMBER",
          "isMandatory": true,
          "inSummary": true,
          "displayOrder": 25,
          "columnSpan": 1,
          "screenId": "temp_s2",
          "fieldGroupId": "temp_g3",
          "validation": "Required() AND Min(1)"
        },
        {
          "name": "quantityDefective",
          "label": "Quantity Defective",
          "fieldType": "NUMBER",
          "isMandatory": true,
          "inSummary": true,
          "displayOrder": 26,
          "columnSpan": 1,
          "screenId": "temp_s2",
          "fieldGroupId": "temp_g3",
          "validation": "Required() AND Min(1)"
