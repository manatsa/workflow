            {
              "value": "MACHINE",
              "label": "Machine (Equipment / Tooling)",
              "displayOrder": 1
            },
            {
              "value": "MATERIAL",
              "label": "Material (Supplier / Raw material)",
              "displayOrder": 2
            },
            {
              "value": "METHOD",
              "label": "Method (Procedure / Process)",
              "displayOrder": 3
            },
            {
              "value": "MEASUREMENT",
              "label": "Measurement (Inspection / Gauge)",
              "displayOrder": 4
            },
            {
              "value": "ENVIRONMENT",
              "label": "Environment (Conditions)",
              "displayOrder": 5
            }
