          "tableBordered": true,
          "tableColumns": "[{\"name\":\"characteristic\",\"label\":\"Characteristic\",\"type\":\"TEXT\",\"width\":200,\"required\":true},{\"name\":\"specified\",\"label\":\"Specified\",\"type\":\"TEXT\",\"width\":150},{\"name\":\"actual\",\"label\":\"Actual\",\"type\":\"TEXT\",\"width\":150},{\"name\":\"result\",\"label\":\"Result\",\"type\":\"SELECT\",\"width\":120,\"options\":[\"Pass\",\"Fail\",\"Marginal\"]}]"
        },
