{
  "_comment": "Funeral Service Delivery — coordinate delivery of funeral service package on an approved claim.",
  "name": "Funeral Service Delivery",
  "code": "FSD",
  "description": "Coordinate casket, hearse, catering, tent and other service elements for a funeral on an approved claim.",
  "icon": "local_florist",
  "displayOrder": 37,
  "requiresApproval": true,
  "commentsMandatory": false,
  "commentsMandatoryOnReject": true,
  "commentsMandatoryOnEscalate": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "titleTemplate": "@{serviceRef} - @{deceasedName} (@{serviceDate})",
  "reminderEnabled": true,
  "reminderFrequencyHours": 2,
  "reminderMaxCount": 8,
  "reminderStartAfterHours": 1,
  "escalationEnabled": true,
  "escalationAfterHours": 12,
  "escalationAction": "NOTIFY_ADMIN",
  "reminderEmailSubject": "URGENT: Funeral Service @{referenceNumber} coordination",
  "reminderEmailBody": "<p>Funeral service delivery <strong>@{referenceNumber}</strong> requires immediate coordination.</p>",
