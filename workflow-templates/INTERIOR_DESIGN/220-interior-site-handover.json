{
  "_comment": "Site Handover Inspection — inspect and approve an interior project site for handover to the client.",
  "name": "Site Handover Inspection",
  "code": "ISH",
  "description": "Conduct final site handover inspection for completed interior design projects, verifying workmanship, punch list items, cleaning, and client acceptance.",
  "icon": "home",
  "displayOrder": 220,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "NON_FINANCIAL",
  "industryCode": "INTERIOR_DESIGN",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{handoverRef} - @{projectName}",
  "reminderEnabled": true, "reminderFrequencyHours": 12, "reminderMaxCount": 3, "reminderStartAfterHours": 12,
  "escalationEnabled": true, "escalationAfterHours": 48, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Project Details", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Inspection Checklist", "displayOrder": 1, "icon": "checklist" },
      { "id": "temp_screen_3", "title": "Punch List & Sign-Off", "displayOrder": 2, "icon": "assignment" },
      { "id": "temp_screen_4", "title": "Review", "displayOrder": 3, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Project Information", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Workmanship Checks", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Systems & Functionality", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Punch List Items", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_6", "title": "Sign-Off & Evidence", "displayOrder": 5, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" }
    ],
    "fields": [
      { "name": "handoverRef", "label": "Handover Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"ISH-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "inspectionDate", "label": "Inspection Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "projectName", "label": "Project Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "clientName", "label": "Client Name", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "projectAddress", "label": "Project Address", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 4, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "inspectorName", "label": "Inspector Name", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 5, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "contractorName", "label": "Main Contractor", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 6, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "paintFinish", "label": "Paint & Wall Finishes", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "PASS", "label": "Pass", "displayOrder": 0 }, { "value": "MINOR_DEFECT", "label": "Minor Defects", "displayOrder": 1 }, { "value": "FAIL", "label": "Fail", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "flooringCheck", "label": "Flooring", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "PASS", "label": "Pass", "displayOrder": 0 }, { "value": "MINOR_DEFECT", "label": "Minor Defects", "displayOrder": 1 }, { "value": "FAIL", "label": "Fail", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "carpentryCheck", "label": "Carpentry / Millwork", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "PASS", "label": "Pass", "displayOrder": 0 }, { "value": "MINOR_DEFECT", "label": "Minor Defects", "displayOrder": 1 }, { "value": "FAIL", "label": "Fail", "displayOrder": 2 }, { "value": "NA", "label": "N/A", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "tileWork", "label": "Tile Work", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "PASS", "label": "Pass", "displayOrder": 0 }, { "value": "MINOR_DEFECT", "label": "Minor Defects", "displayOrder": 1 }, { "value": "FAIL", "label": "Fail", "displayOrder": 2 }, { "value": "NA", "label": "N/A", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "ceilingCheck", "label": "Ceiling", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 14, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "PASS", "label": "Pass", "displayOrder": 0 }, { "value": "MINOR_DEFECT", "label": "Minor Defects", "displayOrder": 1 }, { "value": "FAIL", "label": "Fail", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "furnitureCheck", "label": "Furniture Placement & Condition", "fieldType": "SELECT", "displayOrder": 15, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "options": [ { "value": "PASS", "label": "Pass", "displayOrder": 0 }, { "value": "MINOR_DEFECT", "label": "Minor Defects", "displayOrder": 1 }, { "value": "FAIL", "label": "Fail", "displayOrder": 2 }, { "value": "NA", "label": "N/A", "displayOrder": 3 } ] },
      { "name": "electricalCheck", "label": "Electrical / Lighting", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 16, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "options": [ { "value": "PASS", "label": "Pass", "displayOrder": 0 }, { "value": "MINOR_DEFECT", "label": "Minor Defects", "displayOrder": 1 }, { "value": "FAIL", "label": "Fail", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "plumbingCheck", "label": "Plumbing / Sanitary", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 17, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "options": [ { "value": "PASS", "label": "Pass", "displayOrder": 0 }, { "value": "MINOR_DEFECT", "label": "Minor Defects", "displayOrder": 1 }, { "value": "FAIL", "label": "Fail", "displayOrder": 2 }, { "value": "NA", "label": "N/A", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "hvacCheck", "label": "HVAC / Air Conditioning", "fieldType": "SELECT", "displayOrder": 18, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "options": [ { "value": "PASS", "label": "Pass", "displayOrder": 0 }, { "value": "MINOR_DEFECT", "label": "Minor Defects", "displayOrder": 1 }, { "value": "FAIL", "label": "Fail", "displayOrder": 2 }, { "value": "NA", "label": "N/A", "displayOrder": 3 } ] },
      { "name": "cleaningDone", "label": "Final Cleaning Completed", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 19, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "ValidWhen(@{cleaningDone} == true, \"Final cleaning must be completed before handover\")" },
      { "name": "punchListItems", "label": "Punch List / Snag Items", "fieldType": "TEXTAREA", "displayOrder": 20, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5" },
      { "name": "punchListCount", "label": "Number of Punch List Items", "fieldType": "NUMBER", "inSummary": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5" },
      { "name": "rectificationDeadline", "label": "Rectification Deadline", "fieldType": "DATE", "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5" },
      { "name": "overallVerdict", "label": "Overall Verdict", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5",
        "options": [ { "value": "APPROVED", "label": "Approved for Handover", "displayOrder": 0 }, { "value": "CONDITIONAL", "label": "Conditional Acceptance", "displayOrder": 1 }, { "value": "REJECTED", "label": "Rejected - Rectification Required", "displayOrder": 2 } ], "validation": "Required()" },
      { "name": "warrantyProvided", "label": "Warranty Documentation Provided", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 24, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6" },
      { "name": "manualProvided", "label": "Maintenance Manual Provided", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 25, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6" },
      { "name": "sitePhotos", "label": "Completion Photographs", "fieldType": "FILE", "isMandatory": true, "displayOrder": 26, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "allowedFileTypes": "jpg,png,pdf", "maxFileSize": 52428800, "validation": "Required()" },
      { "name": "handoverReport", "label": "Handover Report", "fieldType": "FILE", "displayOrder": 27, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "allowedFileTypes": "pdf,doc,docx", "maxFileSize": 10485760 }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Project Designer", "approverType": "ROLE", "roleName": "PROJECT_DESIGNER", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Design Director", "approverType": "ROLE", "roleName": "DESIGN_DIRECTOR", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true }
  ]
}
