{
  "_comment": "HSE Incident — report and investigate an HSE incident on an oil / gas facility.",
  "name": "Oil & Gas HSE Incident",
  "code": "OGH",
  "description": "Report and investigate an HSE incident (injury, spill, fire, loss of containment) on an oil & gas facility.",
  "icon": "warning",
  "displayOrder": 134,
  "requiresApproval": true, "commentsMandatoryOnReject": true, "commentsMandatoryOnEscalate": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "NON_FINANCIAL",
  "industryCode": "OIL_GAS",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{incidentRef} - @{incidentType} (@{severity})",
  "reminderEnabled": true, "reminderFrequencyHours": 2, "reminderMaxCount": 5, "reminderStartAfterHours": 1,
  "escalationEnabled": true, "escalationAfterHours": 8, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Incident", "displayOrder": 0, "icon": "warning" },
      { "id": "temp_screen_2", "title": "Consequence", "displayOrder": 1, "icon": "groups" },
      { "id": "temp_screen_3", "title": "Investigation", "displayOrder": 2, "icon": "search" },
      { "id": "temp_screen_4", "title": "Review", "displayOrder": 3, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "What & Where", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Injuries / Spill", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Impact & Loss", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Root Cause & Actions", "displayOrder": 4, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_3" }
    ],
    "fields": [
      { "name": "incidentRef", "label": "Incident Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"OGH-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "reportedBy", "label": "Reported By", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "incidentDate", "label": "Incident Date/Time", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()" },
      { "name": "severity", "label": "Severity (Tier)", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [ { "value": "NEAR_MISS", "label": "Near Miss", "displayOrder": 0 }, { "value": "TIER_1", "label": "Tier 1 - Minor", "displayOrder": 1 }, { "value": "TIER_2", "label": "Tier 2 - Moderate", "displayOrder": 2 }, { "value": "TIER_3", "label": "Tier 3 - Major", "displayOrder": 3 }, { "value": "TIER_4", "label": "Tier 4 - Catastrophic", "displayOrder": 4 } ], "validation": "Required()" },
      { "name": "incidentType", "label": "Incident Type", "fieldType": "SELECT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "LOC", "label": "Loss of Containment (Oil/Gas)", "displayOrder": 0 }, { "value": "FIRE", "label": "Fire / Explosion", "displayOrder": 1 }, { "value": "BLOWOUT", "label": "Blowout / Kick", "displayOrder": 2 }, { "value": "INJURY", "label": "Personal Injury", "displayOrder": 3 }, { "value": "ROAD", "label": "Road Accident", "displayOrder": 4 }, { "value": "MARINE", "label": "Marine / Vessel", "displayOrder": 5 }, { "value": "ENVIRONMENT", "label": "Environmental", "displayOrder": 6 }, { "value": "SECURITY", "label": "Security Event", "displayOrder": 7 } ], "validation": "Required()" },
      { "name": "facility", "label": "Facility / Asset", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "location", "label": "Specific Location", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "description", "label": "Incident Description", "fieldType": "TEXTAREA", "isMandatory": true, "inSummary": true, "displayOrder": 13, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND MinLength(50)" },
      { "name": "numInjured", "label": "Persons Injured", "fieldType": "NUMBER", "isMandatory": true, "defaultValue": "0", "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required() AND Min(0)" },
      { "name": "numFatalities", "label": "Fatalities", "fieldType": "NUMBER", "isMandatory": true, "defaultValue": "0", "inSummary": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "validation": "Required() AND Min(0)" },
      { "name": "hasSpill", "label": "Hydrocarbon / Chemical Release?", "fieldType": "YES_NO", "defaultValue": "false", "inSummary": true, "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3" },
      { "name": "spillVolume", "label": "Release Volume (bbl/m³)", "fieldType": "NUMBER", "defaultValue": "0", "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3", "visibilityExpression": "@{hasSpill} == true", "validation": "Min(0)" },
      { "name": "productionLoss", "label": "Production Impact (BOE/day)", "fieldType": "NUMBER", "defaultValue": "0", "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Min(0)" },
      { "name": "estimatedLoss", "label": "Estimated Financial Loss", "fieldType": "CURRENCY", "defaultValue": "0", "isLimited": true, "inSummary": true, "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Min(0)" },
      { "name": "shutdownHours", "label": "Shutdown Hours", "fieldType": "NUMBER", "defaultValue": "0", "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Min(0)" },
      { "name": "regulatorNotified", "label": "Regulator Notified", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 33, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "ValidWhen((@{severity} != 'TIER_3' AND @{severity} != 'TIER_4' AND @{numFatalities} == 0) OR @{regulatorNotified} == true, \"Regulator notification required for major incidents\")" },
      { "name": "rootCause", "label": "Root Cause Analysis", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 40, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "Required() AND MinLength(50)" },
      { "name": "correctiveActions", "label": "Corrective / Preventive Actions", "fieldType": "TEXTAREA", "isMandatory": true, "displayOrder": 41, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5", "validation": "Required() AND MinLength(50)" },
      { "name": "lessonsLearned", "label": "Lessons Learned / Bulletins", "fieldType": "TEXTAREA", "displayOrder": 42, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "OIM / Facility Lead", "approverType": "ROLE", "roleName": "OIM", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 2, "name": "HSE Manager", "approverType": "ROLE", "roleName": "HSE_MANAGER", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Asset Manager", "approverType": "ROLE", "roleName": "ASSET_MANAGER", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 4, "name": "Country / MD", "approverType": "ROLE", "roleName": "COUNTRY_MANAGER", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
