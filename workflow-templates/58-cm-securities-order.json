{
  "_comment": "Securities Order — capture and authorise a client's buy/sell order for equities / bonds.",
  "name": "Securities Order",
  "code": "SOR",
  "description": "Capture and authorise a client buy/sell order for equities, bonds or other securities.",
  "icon": "show_chart",
  "displayOrder": 58,
  "requiresApproval": true,
  "commentsMandatoryOnReject": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "CAPITAL_MARKETS",
  "workflowTypeCode": "FINANCE",
  "titleTemplate": "@{orderRef} - @{side} @{quantity} @{symbol}",
  "reminderEnabled": true,
  "reminderFrequencyHours": 1,
  "reminderMaxCount": 6,
  "reminderStartAfterHours": 1,
  "escalationEnabled": true,
  "escalationAfterHours": 4,
  "escalationAction": "NOTIFY_ADMIN",

  "forms": [{
    "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Order", "displayOrder": 0, "icon": "receipt_long" },
      { "id": "temp_screen_2", "title": "Client & Funding", "displayOrder": 1, "icon": "person" },
      { "id": "temp_screen_3", "title": "Compliance Checks", "displayOrder": 2, "icon": "verified_user" },
      { "id": "temp_screen_4", "title": "Review & Submit", "displayOrder": 3, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Order Header", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Security & Pricing", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Client", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Funding / Settlement", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Compliance", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" }
    ],
    "fields": [
      { "name": "orderRef", "label": "Order Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"SOR-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "orderDateTime", "label": "Order Date/Time", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "dealer", "label": "Dealer", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "side", "label": "Side", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [ { "value": "BUY", "label": "Buy", "displayOrder": 0 }, { "value": "SELL", "label": "Sell", "displayOrder": 1 } ], "validation": "Required()" },
      { "name": "orderType", "label": "Order Type", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 4, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [ { "value": "MARKET", "label": "Market", "displayOrder": 0 }, { "value": "LIMIT", "label": "Limit", "displayOrder": 1 }, { "value": "STOP", "label": "Stop", "displayOrder": 2 }, { "value": "FOK", "label": "Fill or Kill", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "timeInForce", "label": "Time in Force", "fieldType": "SELECT", "defaultValue": "DAY", "displayOrder": 5, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "options": [ { "value": "DAY", "label": "Day", "displayOrder": 0 }, { "value": "GTC", "label": "Good till Cancel", "displayOrder": 1 }, { "value": "IOC", "label": "IOC", "displayOrder": 2 } ] },
      { "name": "symbol", "label": "Symbol / ISIN", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "assetClass", "label": "Asset Class", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "EQUITY", "label": "Equity", "displayOrder": 0 }, { "value": "BOND", "label": "Bond", "displayOrder": 1 }, { "value": "ETF", "label": "ETF", "displayOrder": 2 }, { "value": "DERIVATIVE", "label": "Derivative", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "quantity", "label": "Quantity", "fieldType": "NUMBER", "isMandatory": true, "inSummary": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "validation": "Required() AND Min(1)" },
      { "name": "limitPrice", "label": "Limit Price", "fieldType": "CURRENCY", "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "visibilityExpression": "@{orderType} == 'LIMIT' OR @{orderType} == 'STOP'",
        "validation": "ValidWhen(@{orderType} == 'MARKET' OR @{orderType} == 'FOK' OR @{limitPrice} > 0, \"Price required\")" },
      { "name": "notionalValue", "label": "Estimated Notional", "fieldType": "CURRENCY", "isReadonly": true, "isLimited": true, "inSummary": true, "displayOrder": 14, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "defaultValue": "MULTIPLY(@{quantity}, @{limitPrice})" },
      { "name": "clientRef", "label": "Client Reference", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "clientName", "label": "Client Name", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Required()" },
      { "name": "csdAccount", "label": "CSD Account", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Required()" },
      { "name": "availableBalance", "label": "Available Balance / Holding", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "validation": "Required() AND Min(0)" },
      { "name": "sufficientFunds", "label": "Sufficient Funds / Holdings", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "validation": "ValidWhen(@{sufficientFunds} == true, \"Insufficient funds/holdings to support order\")" },
      { "name": "settlementDate", "label": "Settlement Date (T+X)", "fieldType": "DATE", "isMandatory": true, "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "validation": "Required()" },
      { "name": "suitabilityOk", "label": "Suitability Check Passed", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5",
        "validation": "ValidWhen(@{suitabilityOk} == true, \"Order not suitable for client's risk profile\")" },
      { "name": "marketAbuseCheck", "label": "Market Abuse Screening Passed", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5",
        "validation": "ValidWhen(@{marketAbuseCheck} == true, \"Market abuse check required\")" },
      { "name": "insiderCheck", "label": "No Insider Trading Flags", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5",
        "validation": "ValidWhen(@{insiderCheck} == true, \"Insider trading flag present\")" },
      { "name": "notes", "label": "Dealer Notes", "fieldType": "TEXTAREA", "displayOrder": 43, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_5" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Dealer (Maker)", "approverType": "ROLE", "roleName": "DEALER", "amountLimit": 50000, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Head Dealer", "approverType": "ROLE", "roleName": "HEAD_DEALER", "amountLimit": 500000, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 3, "name": "Compliance", "approverType": "ROLE", "roleName": "COMPLIANCE_OFFICER", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
