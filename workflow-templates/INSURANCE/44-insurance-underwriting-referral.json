{
  "_comment": "Underwriting Referral — escalate a risk that exceeds an underwriter's authority to a senior/committee.",
  "name": "Underwriting Referral",
  "code": "UWR",
  "description": "Refer a risk outside the underwriter's authority to a senior underwriter or committee.",
  "icon": "report",
  "displayOrder": 44,
  "requiresApproval": true,
  "commentsMandatory": false,
  "commentsMandatoryOnReject": true,
  "commentsMandatoryOnEscalate": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "INSURANCE",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{referralRef} - @{prospectName} (@{productClass})",

  "reminderEnabled": true,
  "reminderFrequencyHours": 12,
  "reminderMaxCount": 5,
  "reminderStartAfterHours": 12,
  "escalationEnabled": true,
  "escalationAfterHours": 48,
  "escalationAction": "NOTIFY_ADMIN",
  "reminderEmailSubject": "Reminder: UW Referral @{referenceNumber} pending",
  "reminderEmailBody": "<p>Underwriting referral <strong>@{referenceNumber}</strong> awaiting your decision.</p>",

  "forms": [{
    "name": "Main Form",
    "displayOrder": 0,

    "screens": [
      { "id": "temp_screen_1", "title": "Reference", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Risk", "displayOrder": 1, "icon": "security" },
      { "id": "temp_screen_3", "title": "Referral Reason", "displayOrder": 2, "icon": "report" },
      { "id": "temp_screen_4", "title": "Proposed Terms", "displayOrder": 3, "icon": "tune" },
      { "id": "temp_screen_5", "title": "Documents", "displayOrder": 4, "icon": "attach_file" },
      { "id": "temp_screen_6", "title": "Review & Submit", "displayOrder": 5, "icon": "fact_check", "isSummaryScreen": true }
    ],

    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Prospect & Risk", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_3", "title": "Reason for Referral", "displayOrder": 2, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_4", "title": "Proposed Cover & Pricing", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_4" },
      { "id": "temp_grp_5", "title": "Reinsurance", "displayOrder": 4, "columns": 2, "isCollapsible": true, "isCollapsedByDefault": true, "screenId": "temp_screen_4" },
      { "id": "temp_grp_6", "title": "Documents", "displayOrder": 5, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_5" }
    ],

    "fields": [
      { "name": "referralRef", "label": "Referral Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"UWR-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "requestDate", "label": "Request Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "referredBy", "label": "Referred By", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "linkedQuote", "label": "Linked Quote Reference", "fieldType": "TEXT", "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "customValidationRule": "TRIM() AND UPPER()" },

      { "name": "prospectName", "label": "Prospect Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "productClass", "label": "Class of Business", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "options": [
          { "value": "MOTOR", "label": "Motor", "displayOrder": 0 },
          { "value": "PROPERTY", "label": "Property / Fire", "displayOrder": 1 },
          { "value": "LIABILITY", "label": "Liability", "displayOrder": 2 },
          { "value": "MARINE", "label": "Marine", "displayOrder": 3 },
          { "value": "ENGINEERING", "label": "Engineering", "displayOrder": 4 },
          { "value": "LIFE", "label": "Life", "displayOrder": 5 },
          { "value": "HEALTH", "label": "Health", "displayOrder": 6 }
        ],
        "validation": "Required()" },
      { "name": "riskDescription", "label": "Risk Description", "fieldType": "TEXTAREA", "isMandatory": true, "inSummary": true, "displayOrder": 12, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required() AND MinLength(30)" },
      { "name": "sumInsured", "label": "Sum Insured", "fieldType": "CURRENCY", "isMandatory": true, "isLimited": true, "inSummary": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required() AND Min(1)" },
      { "name": "riskLocation", "label": "Risk Location", "fieldType": "TEXT", "displayOrder": 14, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2" },

      { "name": "referralReason", "label": "Reason for Referral", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "options": [
          { "value": "OUT_OF_AUTHORITY", "label": "Exceeds Underwriter Authority", "displayOrder": 0 },
          { "value": "HIGH_RISK", "label": "High-Risk Profile", "displayOrder": 1 },
          { "value": "POOR_CLAIMS_HISTORY", "label": "Poor Claims History", "displayOrder": 2 },
          { "value": "SPECIAL_TERMS", "label": "Requires Special Terms", "displayOrder": 3 },
          { "value": "REINSURANCE", "label": "Requires Reinsurance", "displayOrder": 4 },
          { "value": "OTHER", "label": "Other", "displayOrder": 5 }
        ],
        "validation": "Required()" },
      { "name": "reasonDetails", "label": "Referral Narrative", "fieldType": "TEXTAREA", "isMandatory": true, "inSummary": true, "displayOrder": 21, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "validation": "Required() AND MinLength(30)" },

      { "name": "proposedPremium", "label": "Proposed Premium", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_4",
        "validation": "Required() AND Min(0)" },
      { "name": "proposedExcess", "label": "Proposed Excess / Deductible", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_4",
        "validation": "Min(0)" },
      { "name": "proposedWarranties", "label": "Proposed Warranties / Exclusions", "fieldType": "TEXTAREA", "displayOrder": 32, "columnSpan": 2, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_4" },

      { "name": "reinsuranceRequired", "label": "Reinsurance Required?", "fieldType": "YES_NO", "defaultValue": "false", "inSummary": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5" },
      { "name": "reinsuranceType", "label": "Reinsurance Type", "fieldType": "SELECT", "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "visibilityExpression": "@{reinsuranceRequired} == true",
        "options": [
          { "value": "FACULTATIVE", "label": "Facultative", "displayOrder": 0 },
          { "value": "TREATY", "label": "Treaty", "displayOrder": 1 }
        ] },
      { "name": "cedingPercent", "label": "% Ceded to Reinsurer", "fieldType": "NUMBER", "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "visibilityExpression": "@{reinsuranceRequired} == true",
        "validation": "Min(0) AND Max(100)" },
      { "name": "reinsurerName", "label": "Preferred Reinsurer", "fieldType": "TEXT", "displayOrder": 43, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "visibilityExpression": "@{reinsuranceRequired} == true" },

      { "name": "quote", "label": "Quotation / Slip", "fieldType": "FILE", "displayOrder": 50, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "pdf,doc,docx,jpg,jpeg,png", "maxFileSize": 10485760 },
      { "name": "riskSurvey", "label": "Risk Survey / Inspection Report", "fieldType": "FILE", "displayOrder": 51, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "pdf,doc,docx,jpg,jpeg,png", "maxFileSize": 10485760 },
      { "name": "additionalDocs", "label": "Supporting Documents", "fieldType": "FILE", "multiple": true, "displayOrder": 52, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "pdf,doc,docx,jpg,jpeg,png,xls,xlsx", "maxFileSize": 10485760, "maxFiles": 10 }
    ]
  }],

  "approvers": [
    { "level": 1, "name": "Senior Underwriter", "approverType": "ROLE", "roleName": "SENIOR_UNDERWRITER", "amountLimit": 500000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 2, "name": "Head of Underwriting", "approverType": "ROLE", "roleName": "HEAD_OF_UNDERWRITING", "amountLimit": 2500000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Underwriting Committee", "approverType": "ROLE", "roleName": "UW_COMMITTEE", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
