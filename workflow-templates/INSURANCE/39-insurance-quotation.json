{
  "_comment": "Insurance Quotation — capture risk, price the cover, issue quote to the prospect.",
  "name": "Insurance Quotation",
  "code": "INQ",
  "description": "Capture prospect and risk details, price cover and issue a binding quote.",
  "icon": "request_quote",
  "displayOrder": 39,
  "requiresApproval": true,
  "commentsMandatory": false,
  "commentsMandatoryOnReject": true,
  "commentsMandatoryOnEscalate": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "INSURANCE",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{quoteRef} - @{prospectName} (@{productClass})",

  "reminderEnabled": true,
  "reminderFrequencyHours": 24,
  "reminderMaxCount": 3,
  "reminderStartAfterHours": 24,
  "escalationEnabled": true,
  "escalationAfterHours": 48,
  "escalationAction": "NOTIFY_ADMIN",
  "reminderEmailSubject": "Reminder: Quotation @{referenceNumber} pending",
  "reminderEmailBody": "<p>Quotation <strong>@{referenceNumber}</strong> awaiting review.</p>",

  "forms": [{
    "name": "Main Form",
    "displayOrder": 0,

    "screens": [
      { "id": "temp_screen_1", "title": "Reference", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Prospect", "displayOrder": 1, "icon": "person" },
      { "id": "temp_screen_3", "title": "Risk & Cover", "displayOrder": 2, "icon": "security" },
      { "id": "temp_screen_4", "title": "Pricing", "displayOrder": 3, "icon": "payments" },
      { "id": "temp_screen_5", "title": "Documents", "displayOrder": 4, "icon": "attach_file" },
      { "id": "temp_screen_6", "title": "Review & Submit", "displayOrder": 5, "icon": "fact_check", "isSummaryScreen": true }
    ],

    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Prospect Info", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_3", "title": "Risk Information", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_4", "title": "Cover Selection", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_5", "title": "Premium Calculation", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_4" },
      { "id": "temp_grp_6", "title": "Supporting Documents", "displayOrder": 5, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_5" }
    ],

    "fields": [
      { "name": "quoteRef", "label": "Quote Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"INQ-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "quoteDate", "label": "Quote Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "quoteValidUntil", "label": "Valid Until", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1",
        "validation": "Required() AND DateAfter(\"today\", \"Validity must be in the future\")" },
      { "name": "agent", "label": "Agent / Broker", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "inSummary": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },

      { "name": "prospectType", "label": "Prospect Type", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "options": [
          { "value": "INDIVIDUAL", "label": "Individual", "displayOrder": 0 },
          { "value": "CORPORATE", "label": "Corporate / Business", "displayOrder": 1 }
        ],
        "validation": "Required()" },
      { "name": "prospectName", "label": "Prospect Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required() AND MinLength(2)", "customValidationRule": "TRIM()" },
      { "name": "idOrRegistration", "label": "ID / Registration Number", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "phone", "label": "Phone", "fieldType": "PHONE", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required() AND Phone()" },
      { "name": "email", "label": "Email", "fieldType": "EMAIL", "displayOrder": 14, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "ValidWhen(IS_EMPTY(@{email}) OR IS_EMAIL(@{email}), \"Enter a valid email\")" },

      { "name": "productClass", "label": "Product / Class of Business", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "options": [
          { "value": "MOTOR", "label": "Motor", "displayOrder": 0 },
          { "value": "PROPERTY", "label": "Property / Fire", "displayOrder": 1 },
          { "value": "LIABILITY", "label": "Liability", "displayOrder": 2 },
          { "value": "MARINE", "label": "Marine & Cargo", "displayOrder": 3 },
          { "value": "ENGINEERING", "label": "Engineering", "displayOrder": 4 },
          { "value": "LIFE", "label": "Life", "displayOrder": 5 },
          { "value": "HEALTH", "label": "Health / Medical", "displayOrder": 6 },
          { "value": "TRAVEL", "label": "Travel", "displayOrder": 7 }
        ],
        "validation": "Required()" },
      { "name": "riskDescription", "label": "Description of Risk", "fieldType": "TEXTAREA", "isMandatory": true, "inSummary": true, "displayOrder": 21, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "validation": "Required() AND MinLength(20)" },
      { "name": "riskLocation", "label": "Risk Location", "fieldType": "TEXT", "displayOrder": 22, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3" },
      { "name": "claimsHistory", "label": "Claims in last 3 years?", "fieldType": "YES_NO", "defaultValue": "false", "inSummary": true, "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3" },
      { "name": "claimsDetails", "label": "Claims Details", "fieldType": "TEXTAREA", "displayOrder": 24, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_3",
        "visibilityExpression": "@{claimsHistory} == true",
        "validation": "ValidWhen(@{claimsHistory} == false OR HAS_MIN_LENGTH(@{claimsDetails}, 20), \"Describe prior claims\")" },

      { "name": "sumInsured", "label": "Sum Insured", "fieldType": "CURRENCY", "isMandatory": true, "isLimited": true, "inSummary": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "validation": "Required() AND Min(1)" },
      { "name": "currency", "label": "Currency", "fieldType": "SELECT", "defaultValue": "USD", "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "options": [
          { "value": "USD", "label": "USD", "displayOrder": 0 },
          { "value": "EUR", "label": "EUR", "displayOrder": 1 },
          { "value": "GBP", "label": "GBP", "displayOrder": 2 },
          { "value": "ZAR", "label": "ZAR", "displayOrder": 3 },
          { "value": "ZWL", "label": "ZWL", "displayOrder": 4 }
        ] },
      { "name": "periodMonths", "label": "Cover Period (months)", "fieldType": "NUMBER", "isMandatory": true, "defaultValue": "12", "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "validation": "Required() AND Min(1) AND Max(60)" },
      { "name": "extensions", "label": "Cover Extensions / Add-Ons", "fieldType": "TEXTAREA", "displayOrder": 33, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4" },

      { "name": "basePremium", "label": "Base Premium", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "Required() AND Min(0)" },
      { "name": "loadingPercent", "label": "Loading %", "fieldType": "NUMBER", "defaultValue": "0", "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "Min(0) AND Max(100)" },
      { "name": "discountPercent", "label": "Discount %", "fieldType": "NUMBER", "defaultValue": "0", "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "Min(0) AND Max(100)" },
      { "name": "commissionPercent", "label": "Commission %", "fieldType": "NUMBER", "defaultValue": "0", "displayOrder": 43, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "Min(0) AND Max(100)" },
      { "name": "netPremium", "label": "Net Premium", "fieldType": "CURRENCY", "isReadonly": true, "inSummary": true, "displayOrder": 44, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "defaultValue": "SUBTRACT(SUM(@{basePremium}, PERCENT_OF(@{basePremium}, @{loadingPercent})), PERCENT_OF(@{basePremium}, @{discountPercent}))" },
      { "name": "taxAmount", "label": "Tax / Stamp Duty", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 45, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "Min(0)" },
      { "name": "grossPremium", "label": "Gross Premium Payable", "fieldType": "CURRENCY", "isReadonly": true, "isLimited": true, "inSummary": true, "displayOrder": 46, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "defaultValue": "SUM(@{netPremium}, @{taxAmount})" },

      { "name": "riskSurvey", "label": "Risk Survey Report", "fieldType": "FILE", "displayOrder": 50, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "pdf,doc,docx,jpg,jpeg,png", "maxFileSize": 10485760 },
      { "name": "prospectId", "label": "Prospect ID / Business Registration", "fieldType": "FILE", "isMandatory": true, "displayOrder": 51, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 10485760,
        "validation": "Required()" },
      { "name": "additionalDocs", "label": "Additional Documents", "fieldType": "FILE", "multiple": true, "displayOrder": 52, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "pdf,doc,docx,jpg,jpeg,png,xls,xlsx", "maxFileSize": 10485760, "maxFiles": 10 }
    ]
  }],

  "approvers": [
    { "level": 1, "name": "Underwriter", "approverType": "ROLE", "roleName": "UNDERWRITER", "amountLimit": 50000, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Senior Underwriter", "approverType": "ROLE", "roleName": "SENIOR_UNDERWRITER", "amountLimit": 500000, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Head of Underwriting", "approverType": "ROLE", "roleName": "HEAD_OF_UNDERWRITING", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
