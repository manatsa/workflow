{
  "_comment": "Insurance Policy Renewal — renew an expiring policy with updated risk and premium.",
  "name": "Insurance Policy Renewal",
  "code": "INR",
  "description": "Renew an expiring insurance policy with updated risk profile and premium.",
  "icon": "autorenew",
  "displayOrder": 42,
  "requiresApproval": true,
  "commentsMandatory": false,
  "commentsMandatoryOnReject": true,
  "commentsMandatoryOnEscalate": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "industryCode": "INSURANCE",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{renewalRef} - @{insuredName} (@{policyNumber})",

  "reminderEnabled": true,
  "reminderFrequencyHours": 24,
  "reminderMaxCount": 3,
  "reminderStartAfterHours": 24,
  "escalationEnabled": true,
  "escalationAfterHours": 72,
  "escalationAction": "NOTIFY_ADMIN",
  "reminderEmailSubject": "Reminder: Renewal @{referenceNumber} pending",
  "reminderEmailBody": "<p>Policy renewal <strong>@{referenceNumber}</strong> awaiting your action.</p>",

  "forms": [{
    "name": "Main Form",
    "displayOrder": 0,

    "screens": [
      { "id": "temp_screen_1", "title": "Reference", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Expiring Policy", "displayOrder": 1, "icon": "policy" },
      { "id": "temp_screen_3", "title": "Renewal Terms", "displayOrder": 2, "icon": "edit" },
      { "id": "temp_screen_4", "title": "Premium", "displayOrder": 3, "icon": "payments" },
      { "id": "temp_screen_5", "title": "Documents", "displayOrder": 4, "icon": "attach_file" },
      { "id": "temp_screen_6", "title": "Review & Submit", "displayOrder": 5, "icon": "fact_check", "isSummaryScreen": true }
    ],

    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Expiring Policy", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_3", "title": "Claims & Loss Ratio", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_4", "title": "Renewal Changes", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_3" },
      { "id": "temp_grp_5", "title": "New Premium", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_4" },
      { "id": "temp_grp_6", "title": "Documents", "displayOrder": 5, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_5" }
    ],

    "fields": [
      { "name": "renewalRef", "label": "Renewal Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"INR-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "requestDate", "label": "Request Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "officer", "label": "Officer", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },

      { "name": "policyNumber", "label": "Policy Number", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "insuredName", "label": "Insured Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "productClass", "label": "Class of Business", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },
      { "name": "oldSumInsured", "label": "Current Sum Insured", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required() AND Min(0)" },
      { "name": "oldPremium", "label": "Current Gross Premium", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 14, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required() AND Min(0)" },
      { "name": "expiryDate", "label": "Current Expiry Date", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 15, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_2",
        "validation": "Required()" },

      { "name": "claimsInPeriod", "label": "Claims in Period", "fieldType": "NUMBER", "defaultValue": "0", "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Min(0)" },
      { "name": "claimsAmount", "label": "Total Claims Paid", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "validation": "Min(0)" },
      { "name": "lossRatioPercent", "label": "Loss Ratio %", "fieldType": "NUMBER", "isReadonly": true, "inSummary": true, "displayOrder": 22, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_3",
        "defaultValue": "PERCENTAGE(@{claimsAmount}, @{oldPremium})" },

      { "name": "renewalDecision", "label": "Renewal Decision", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "options": [
          { "value": "RENEW_SAME", "label": "Renew - Same Terms", "displayOrder": 0 },
          { "value": "RENEW_AMENDED", "label": "Renew - Amended Terms", "displayOrder": 1 },
          { "value": "DECLINE", "label": "Decline Renewal", "displayOrder": 2 }
        ],
        "validation": "Required()" },
      { "name": "newSumInsured", "label": "New Sum Insured", "fieldType": "CURRENCY", "isMandatory": true, "isLimited": true, "inSummary": true, "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "validation": "Required() AND Min(0)" },
      { "name": "newInceptionDate", "label": "New Inception", "fieldType": "DATE", "isMandatory": true, "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "validation": "Required()" },
      { "name": "newExpiryDate", "label": "New Expiry", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 33, "columnSpan": 1, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "validation": "Required() AND DateAfter(\"today\", \"Expiry must be future\")" },
      { "name": "amendmentNotes", "label": "Amendment Notes", "fieldType": "TEXTAREA", "displayOrder": 34, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_4",
        "visibilityExpression": "@{renewalDecision} == 'RENEW_AMENDED' OR @{renewalDecision} == 'DECLINE'",
        "validation": "ValidWhen(@{renewalDecision} == 'RENEW_SAME' OR HAS_MIN_LENGTH(@{amendmentNotes}, 20), \"Provide amendment/decline notes\")" },

      { "name": "newBasePremium", "label": "New Base Premium", "fieldType": "CURRENCY", "isMandatory": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "Required() AND Min(0)" },
      { "name": "newLoadingPercent", "label": "Loading %", "fieldType": "NUMBER", "defaultValue": "0", "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "Min(0) AND Max(100)" },
      { "name": "newDiscountPercent", "label": "Discount %", "fieldType": "NUMBER", "defaultValue": "0", "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "Min(0) AND Max(100)" },
      { "name": "newTaxAmount", "label": "Tax", "fieldType": "CURRENCY", "defaultValue": "0", "displayOrder": 43, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "validation": "Min(0)" },
      { "name": "newGrossPremium", "label": "New Gross Premium", "fieldType": "CURRENCY", "isReadonly": true, "inSummary": true, "displayOrder": 44, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "defaultValue": "SUM(SUBTRACT(SUM(@{newBasePremium}, PERCENT_OF(@{newBasePremium}, @{newLoadingPercent})), PERCENT_OF(@{newBasePremium}, @{newDiscountPercent})), @{newTaxAmount})" },
      { "name": "premiumChangePercent", "label": "Premium Change %", "fieldType": "NUMBER", "isReadonly": true, "displayOrder": 45, "columnSpan": 1, "screenId": "temp_screen_4", "fieldGroupId": "temp_grp_5",
        "defaultValue": "PERCENTAGE(SUBTRACT(@{newGrossPremium}, @{oldPremium}), @{oldPremium})" },

      { "name": "renewalNotice", "label": "Renewal Notice Sent to Client", "fieldType": "FILE", "isMandatory": true, "displayOrder": 50, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 10485760,
        "validation": "Required()" },
      { "name": "clientConfirmation", "label": "Client Acceptance / Instruction", "fieldType": "FILE", "displayOrder": 51, "columnSpan": 2, "screenId": "temp_screen_5", "fieldGroupId": "temp_grp_6",
        "allowedFileTypes": "pdf,jpg,jpeg,png", "maxFileSize": 10485760 }
    ]
  }],

  "approvers": [
    { "level": 1, "name": "Underwriter", "approverType": "ROLE", "roleName": "UNDERWRITER", "amountLimit": 100000, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Senior Underwriter", "approverType": "ROLE", "roleName": "SENIOR_UNDERWRITER", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
