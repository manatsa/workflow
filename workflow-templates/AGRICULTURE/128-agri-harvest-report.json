{
  "_comment": "Harvest Yield Report — record harvest output from a field block.",
  "name": "Harvest Yield Report",
  "code": "AHY",
  "description": "Record harvest output from a field / block with weight, quality grade and losses.",
  "icon": "agriculture",
  "displayOrder": 128,
  "requiresApproval": true, "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "NON_FINANCIAL",
  "industryCode": "AGRICULTURE",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{harvestRef} - @{block} (@{crop})",
  "reminderEnabled": true, "reminderFrequencyHours": 24, "reminderMaxCount": 3, "reminderStartAfterHours": 24,
  "escalationEnabled": true, "escalationAfterHours": 72, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Harvest Info", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Yield & Quality", "displayOrder": 1, "icon": "assessment" },
      { "id": "temp_screen_3", "title": "Review", "displayOrder": 2, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Block & Crop", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Harvest Dates", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_4", "title": "Yield", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Quality & Destination", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" }
    ],
    "fields": [
      { "name": "harvestRef", "label": "Harvest Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"AHY-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "submissionDate", "label": "Submission Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "reportedBy", "label": "Reported By", "fieldType": "TEXT", "defaultValue": "CURRENT_USER()", "isReadonly": true, "displayOrder": 2, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "farm", "label": "Farm / Estate", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 3, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1", "validation": "Required()" },
      { "name": "block", "label": "Block / Field", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "hectares", "label": "Hectares Harvested", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required() AND Min(0.01)" },
      { "name": "crop", "label": "Crop", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "variety", "label": "Variety / Cultivar", "fieldType": "TEXT", "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2" },
      { "name": "plantingDate", "label": "Planting Date", "fieldType": "DATE", "isMandatory": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "harvestStart", "label": "Harvest Start", "fieldType": "DATE", "isMandatory": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "harvestEnd", "label": "Harvest End", "fieldType": "DATE", "isMandatory": true, "displayOrder": 22, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "grossYieldTonnes", "label": "Gross Yield (tonnes)", "fieldType": "NUMBER", "isMandatory": true, "inSummary": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Min(0)" },
      { "name": "moisturePercent", "label": "Moisture %", "fieldType": "NUMBER", "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Min(0) AND Max(100)" },
      { "name": "lossesTonnes", "label": "Post-Harvest Losses (t)", "fieldType": "NUMBER", "defaultValue": "0", "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Min(0)" },
      { "name": "netYield", "label": "Net Yield (t)", "fieldType": "NUMBER", "isReadonly": true, "inSummary": true, "displayOrder": 33, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "defaultValue": "SUBTRACT(@{grossYieldTonnes}, @{lossesTonnes})" },
      { "name": "yieldPerHa", "label": "Yield per Ha (t/ha)", "fieldType": "NUMBER", "isReadonly": true, "displayOrder": 34, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4",
        "defaultValue": "DIVIDE(@{netYield}, @{hectares})" },
      { "name": "budgetYieldPerHa", "label": "Budget Yield per Ha", "fieldType": "NUMBER", "isMandatory": true, "displayOrder": 35, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "Required() AND Min(0)" },
      { "name": "grade", "label": "Quality Grade", "fieldType": "SELECT", "isMandatory": true, "inSummary": true, "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5",
        "options": [ { "value": "A", "label": "Grade A", "displayOrder": 0 }, { "value": "B", "label": "Grade B", "displayOrder": 1 }, { "value": "C", "label": "Grade C", "displayOrder": 2 }, { "value": "REJECT", "label": "Reject", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "destination", "label": "Destination", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5",
        "options": [ { "value": "FARM_STORE", "label": "Farm Storage", "displayOrder": 0 }, { "value": "GRAIN_MARKETING", "label": "Grain Marketing Board", "displayOrder": 1 }, { "value": "BUYER", "label": "Private Buyer", "displayOrder": 2 }, { "value": "PROCESSOR", "label": "Processor", "displayOrder": 3 }, { "value": "EXPORT", "label": "Export", "displayOrder": 4 } ], "validation": "Required()" },
      { "name": "buyer", "label": "Buyer / Consignee", "fieldType": "TEXT", "displayOrder": 42, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5" },
      { "name": "notes", "label": "Notes / Observations", "fieldType": "TEXTAREA", "displayOrder": 43, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5" }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Block / Crop Supervisor", "approverType": "ROLE", "roleName": "CROP_SUPERVISOR", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Farm Manager", "approverType": "ROLE", "roleName": "FARM_MANAGER", "amountLimit": null, "canEscalate": false, "requireComment": false, "emailNotification": true }
  ]
}
