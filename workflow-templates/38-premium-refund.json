{
  "_comment": "Premium Refund — refund over-paid, duplicate or incorrectly collected premiums to a policyholder.",
  "name": "Premium Refund Request",
  "code": "PRF",
  "description": "Refund over-paid, duplicate or wrongly-collected premiums to a policyholder.",
  "icon": "currency_exchange",
  "displayOrder": 38,
  "requiresApproval": true,
  "commentsMandatory": false,
  "commentsMandatoryOnReject": true,
  "commentsMandatoryOnEscalate": true,
  "showSummary": true,
  "showApprovalMatrix": true,
  "lockApproved": true,
  "workflowCategory": "FINANCIAL",
  "titleTemplate": "@{refundRef} - @{policyholderName} (@{refundAmount})",
  "reminderEnabled": true,
  "reminderFrequencyHours": 24,
  "reminderMaxCount": 3,
  "reminderStartAfterHours": 24,
  "escalationEnabled": true,
  "escalationAfterHours": 72,
  "escalationAction": "NOTIFY_ADMIN",
  "reminderEmailSubject": "Reminder: Premium Refund @{referenceNumber} pending",
  "reminderEmailBody": "<p>Premium refund <strong>@{referenceNumber}</strong> awaiting your action.</p>",
  "forms": [
    {
      "name": "Main Form",
      "displayOrder": 0,
      "screens": [
        {
          "id": "temp_screen_1",
          "title": "Reference",
          "displayOrder": 0,
          "icon": "info"
        },
        {
          "id": "temp_screen_2",
          "title": "Policy",
          "displayOrder": 1,
          "icon": "policy"
        },
        {
          "id": "temp_screen_3",
          "title": "Refund Details",
          "displayOrder": 2,
          "icon": "payments"
        },
        {
          "id": "temp_screen_4",
          "title": "Payout Destination",
          "displayOrder": 3,
          "icon": "account_balance"
        },
        {
          "id": "temp_screen_5",
          "title": "Documents",
          "displayOrder": 4,
          "icon": "attach_file"
        },
        {
          "id": "temp_screen_6",
          "title": "Review & Submit",
          "displayOrder": 5,
          "icon": "fact_check",
          "isSummaryScreen": true
        }
      ],
      "fieldGroups": [
        {
          "id": "temp_grp_1",
          "title": "Reference",
          "displayOrder": 0,
          "columns": 2,
          "isCollapsible": false,
          "screenId": "temp_screen_1"
        },
        {
          "id": "temp_grp_2",
          "title": "Policy",
          "displayOrder": 1,
          "columns": 2,
          "isCollapsible": false,
          "screenId": "temp_screen_2"
        },
        {
          "id": "temp_grp_3",
          "title": "Refund Reason & Calculation",
          "displayOrder": 2,
          "columns": 2,
          "isCollapsible": false,
          "screenId": "temp_screen_3"
        },
        {
          "id": "temp_grp_4",
          "title": "Premium Items Being Refunded",
          "displayOrder": 3,
          "columns": 1,
          "isCollapsible": false,
          "screenId": "temp_screen_3"
        },
        {
          "id": "temp_grp_5",
          "title": "Payout Method",
          "displayOrder": 4,
          "columns": 2,
          "isCollapsible": false,
          "screenId": "temp_screen_4"
        },
        {
          "id": "temp_grp_6",
          "title": "Documents",
          "displayOrder": 5,
          "columns": 1,
          "isCollapsible": false,
          "screenId": "temp_screen_5"
        }
      ],
      "fields": [
        {
          "name": "refundRef",
          "label": "Refund Reference",
          "fieldType": "TEXT",
          "defaultValue": "SEQUENCE(\"PRF-\")",
          "isReadonly": true,
          "isTitle": true,
          "inSummary": true,
          "displayOrder": 0,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_1"
        },
        {
          "name": "requestDate",
          "label": "Request Date",
          "fieldType": "DATE",
          "defaultValue": "TODAY()",
          "isReadonly": true,
          "inSummary": true,
          "displayOrder": 1,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_1"
        },
        {
          "name": "officer",
          "label": "Officer",
          "fieldType": "TEXT",
          "defaultValue": "CURRENT_USER()",
          "isReadonly": true,
          "displayOrder": 2,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_1"
        },
        {
          "name": "branch",
          "label": "Branch",
          "fieldType": "TEXT",
          "isMandatory": true,
          "displayOrder": 3,
          "columnSpan": 1,
          "screenId": "temp_screen_1",
          "fieldGroupId": "temp_grp_1",
          "validation": "Required()"
        },
        {
          "name": "policyNumber",
          "label": "Policy Number",
          "fieldType": "TEXT",
          "isMandatory": true,
          "inSummary": true,
          "displayOrder": 10,
          "columnSpan": 1,
          "screenId": "temp_screen_2",
          "fieldGroupId": "temp_grp_2",
          "validation": "Required()",
          "customValidationRule": "TRIM() AND UPPER()"
        },
        {
          "name": "policyholderName",
          "label": "Policyholder Name",
          "fieldType": "TEXT",
          "isMandatory": true,
          "isTitle": true,
          "inSummary": true,
          "displayOrder": 11,
          "columnSpan": 1,
          "screenId": "temp_screen_2",
          "fieldGroupId": "temp_grp_2",
          "validation": "Required()"
        },
        {
          "name": "policyholderId",
          "label": "Policyholder ID",
          "fieldType": "TEXT",
          "isMandatory": true,
          "displayOrder": 12,
          "columnSpan": 1,
          "screenId": "temp_screen_2",
          "fieldGroupId": "temp_grp_2",
          "validation": "Required()"
        },
        {
          "name": "policyholderPhone",
          "label": "Phone",
          "fieldType": "PHONE",
          "isMandatory": true,
          "displayOrder": 13,
          "columnSpan": 1,
          "screenId": "temp_screen_2",
          "fieldGroupId": "temp_grp_2",
          "validation": "Required() AND Phone()"
        },
        {
          "name": "refundReason",
          "label": "Refund Reason",
          "fieldType": "SELECT",
          "isMandatory": true,
          "inSummary": true,
          "displayOrder": 20,
          "columnSpan": 1,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_3",
          "options": [
            {
              "value": "DUPLICATE_PAYMENT",
              "label": "Duplicate Payment",
              "displayOrder": 0
            },
            {
              "value": "OVERPAYMENT",
              "label": "Overpayment",
              "displayOrder": 1
            },
            {
              "value": "INCORRECT_POLICY",
              "label": "Paid to Wrong Policy",
              "displayOrder": 2
            },
            {
              "value": "POST_CANCEL_DEDUCTION",
              "label": "Deducted after Cancellation",
              "displayOrder": 3
            },
            {
              "value": "COOLING_OFF",
              "label": "Cooling-Off Refund",
              "displayOrder": 4
            },
            {
              "value": "SYSTEM_ERROR",
              "label": "System Error",
              "displayOrder": 5
            },
            {
              "value": "OTHER",
              "label": "Other",
              "displayOrder": 6
            }
          ],
          "validation": "Required()"
        },
        {
          "name": "reasonDetails",
          "label": "Reason Detail",
          "fieldType": "TEXTAREA",
          "isMandatory": true,
          "inSummary": true,
          "displayOrder": 21,
          "columnSpan": 2,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_3",
          "validation": "Required() AND MinLength(20)"
        },
        {
          "name": "refundAmount",
          "label": "Refund Amount",
          "fieldType": "CURRENCY",
          "isMandatory": true,
          "isLimited": true,
          "inSummary": true,
          "displayOrder": 22,
          "columnSpan": 1,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_3",
          "validation": "Required() AND Min(0.01)"
        },
        {
          "name": "currency",
          "label": "Currency",
          "fieldType": "SELECT",
          "defaultValue": "USD",
          "displayOrder": 23,
          "columnSpan": 1,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_3",
          "options": [
            {
              "value": "USD",
              "label": "USD",
              "displayOrder": 0
            },
            {
              "value": "EUR",
              "label": "EUR",
              "displayOrder": 1
            },
            {
              "value": "GBP",
              "label": "GBP",
              "displayOrder": 2
            },
            {
              "value": "ZAR",
              "label": "ZAR",
              "displayOrder": 3
            },
            {
              "value": "ZWL",
              "label": "ZWL",
              "displayOrder": 4
            }
          ]
        },
        {
          "name": "premiumItems",
          "label": "Premium Items to Refund",
          "fieldType": "TABLE",
          "isMandatory": true,
          "displayOrder": 30,
          "columnSpan": 2,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_4",
          "tableMinRows": 1,
          "tableMaxRows": 24,
          "tableStriped": true,
          "tableBordered": true,
          "tableColumns": "[{\"name\":\"paymentDate\",\"label\":\"Payment Date\",\"type\":\"DATE\",\"width\":140,\"required\":true},{\"name\":\"receipt\",\"label\":\"Receipt / Ref\",\"type\":\"TEXT\",\"width\":180,\"required\":true},{\"name\":\"channel\",\"label\":\"Channel\",\"type\":\"TEXT\",\"width\":130},{\"name\":\"amount\",\"label\":\"Amount\",\"type\":\"NUMBER\",\"width\":120,\"required\":true}]",
          "validation": "MinRows(1, \"Add at least one premium item\")"
        },
        {
          "name": "totalItemsAmount",
          "label": "Total of Items",
          "fieldType": "CURRENCY",
          "isReadonly": true,
          "displayOrder": 31,
          "columnSpan": 2,
          "screenId": "temp_screen_3",
          "fieldGroupId": "temp_grp_4",
          "defaultValue": "SUM_COLUMN(\"premiumItems\", \"amount\")",
          "validation": "ValidWhen(@{totalItemsAmount} == @{refundAmount}, \"Items total must equal refund amount\")"
        },
        {
          "name": "paymentMethod",
          "label": "Payment Method",
          "fieldType": "SELECT",
          "isMandatory": true,
          "displayOrder": 40,
          "columnSpan": 1,
          "screenId": "temp_screen_4",
          "fieldGroupId": "temp_grp_5",
          "options": [
            {
              "value": "BANK_TRANSFER",
              "label": "Bank Transfer",
              "displayOrder": 0
            },
            {
              "value": "MOBILE_MONEY",
              "label": "Mobile Money",
              "displayOrder": 1
            },
            {
              "value": "CHEQUE",
              "label": "Cheque",
              "displayOrder": 2
            },
            {
              "value": "CASH",
              "label": "Cash",
              "displayOrder": 3
            },
            {
              "value": "CREDIT_TO_POLICY",
              "label": "Credit to Policy Premium Ledger",
              "displayOrder": 4
            }
          ],
          "validation": "Required()"
        },
        {
          "name": "bankAccount",
          "label": "Account / Mobile Number",
          "fieldType": "TEXT",
          "displayOrder": 41,
          "columnSpan": 1,
          "screenId": "temp_screen_4",
          "fieldGroupId": "temp_grp_5",
          "visibilityExpression": "@{paymentMethod} == 'BANK_TRANSFER' OR @{paymentMethod} == 'MOBILE_MONEY'",
          "validation": "ValidWhen(@{paymentMethod} != 'BANK_TRANSFER' AND @{paymentMethod} != 'MOBILE_MONEY' OR IS_NOT_EMPTY(@{bankAccount}), \"Account required\")"
        },
        {
          "name": "bankName",
          "label": "Bank / Mobile Money Provider",
          "fieldType": "TEXT",
          "displayOrder": 42,
          "columnSpan": 1,
          "screenId": "temp_screen_4",
          "fieldGroupId": "temp_grp_5",
          "visibilityExpression": "@{paymentMethod} == 'BANK_TRANSFER' OR @{paymentMethod} == 'MOBILE_MONEY'"
        },
        {
          "name": "accountHolder",
          "label": "Account Holder Name",
          "fieldType": "TEXT",
          "displayOrder": 43,
          "columnSpan": 1,
          "screenId": "temp_screen_4",
          "fieldGroupId": "temp_grp_5",
          "visibilityExpression": "@{paymentMethod} == 'BANK_TRANSFER'"
        },
        {
          "name": "refundRequest",
          "label": "Signed Refund Request",
          "fieldType": "FILE",
          "isMandatory": true,
          "displayOrder": 50,
          "columnSpan": 2,
          "screenId": "temp_screen_5",
          "fieldGroupId": "temp_grp_6",
          "allowedFileTypes": "pdf,jpg,jpeg,png",
          "maxFileSize": 10485760,
          "validation": "Required(\"Signed request required\")"
        },
        {
          "name": "paymentEvidence",
          "label": "Evidence of Premium Payments",
          "fieldType": "FILE",
          "isMandatory": true,
          "multiple": true,
          "displayOrder": 51,
          "columnSpan": 2,
          "screenId": "temp_screen_5",
          "fieldGroupId": "temp_grp_6",
          "allowedFileTypes": "pdf,jpg,jpeg,png",
          "maxFileSize": 10485760,
          "maxFiles": 20,
          "validation": "Required(\"Provide evidence of payments\")"
        },
        {
          "name": "idCopy",
          "label": "Policyholder ID",
          "fieldType": "FILE",
          "isMandatory": true,
          "displayOrder": 52,
          "columnSpan": 2,
          "screenId": "temp_screen_5",
          "fieldGroupId": "temp_grp_6",
          "allowedFileTypes": "pdf,jpg,jpeg,png",
          "maxFileSize": 10485760,
          "validation": "Required()"
        },
        {
          "name": "proofOfBanking",
          "label": "Proof of Banking",
          "fieldType": "FILE",
          "displayOrder": 53,
          "columnSpan": 2,
          "screenId": "temp_screen_5",
          "fieldGroupId": "temp_grp_6",
          "visibilityExpression": "@{paymentMethod} == 'BANK_TRANSFER'",
          "allowedFileTypes": "pdf,jpg,jpeg,png",
          "maxFileSize": 10485760,
          "validation": "ValidWhen(@{paymentMethod} != 'BANK_TRANSFER' OR IS_NOT_EMPTY(@{proofOfBanking}), \"Proof of banking required\")"
        }
      ]
    }
  ],
  "approvers": [
    {
      "level": 1,
      "name": "Finance Officer",
