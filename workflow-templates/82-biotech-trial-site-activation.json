{
  "_comment": "Clinical Trial Site Activation — activate an investigator site for participant enrolment.",
  "name": "Clinical Trial Site Activation",
  "code": "BSA",
  "description": "Activate a clinical trial site for participant enrolment after regulatory, ethics and contract approvals.",
  "icon": "flag",
  "displayOrder": 82,
  "requiresApproval": true,
  "commentsMandatoryOnReject": true,
  "showSummary": true, "showApprovalMatrix": true, "lockApproved": true,
  "workflowCategory": "NON_FINANCIAL",
  "industryCode": "BIOTECH",
  "workflowTypeCode": "APPROVAL",
  "titleTemplate": "@{activationRef} - @{siteName} (@{protocolNumber})",
  "reminderEnabled": true, "reminderFrequencyHours": 24, "reminderMaxCount": 3, "reminderStartAfterHours": 24,
  "escalationEnabled": true, "escalationAfterHours": 96, "escalationAction": "NOTIFY_ADMIN",

  "forms": [{ "name": "Main Form", "displayOrder": 0,
    "screens": [
      { "id": "temp_screen_1", "title": "Site & Trial", "displayOrder": 0, "icon": "info" },
      { "id": "temp_screen_2", "title": "Readiness Checks", "displayOrder": 1, "icon": "checklist" },
      { "id": "temp_screen_3", "title": "Documents", "displayOrder": 2, "icon": "attach_file" },
      { "id": "temp_screen_4", "title": "Review", "displayOrder": 3, "icon": "fact_check", "isSummaryScreen": true }
    ],
    "fieldGroups": [
      { "id": "temp_grp_1", "title": "Reference", "displayOrder": 0, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_2", "title": "Trial Details", "displayOrder": 1, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_3", "title": "Site Details", "displayOrder": 2, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_1" },
      { "id": "temp_grp_4", "title": "Regulatory & Ethics", "displayOrder": 3, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_5", "title": "Operational Readiness", "displayOrder": 4, "columns": 2, "isCollapsible": false, "screenId": "temp_screen_2" },
      { "id": "temp_grp_6", "title": "Documents", "displayOrder": 5, "columns": 1, "isCollapsible": false, "screenId": "temp_screen_3" }
    ],
    "fields": [
      { "name": "activationRef", "label": "Activation Reference", "fieldType": "TEXT", "defaultValue": "SEQUENCE(\"BSA-\")", "isReadonly": true, "isTitle": true, "inSummary": true, "displayOrder": 0, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "requestDate", "label": "Request Date", "fieldType": "DATE", "defaultValue": "TODAY()", "isReadonly": true, "inSummary": true, "displayOrder": 1, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_1" },
      { "name": "protocolNumber", "label": "Protocol Number", "fieldType": "TEXT", "isMandatory": true, "inSummary": true, "displayOrder": 10, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "sponsor", "label": "Sponsor / CRO", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 11, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "phase", "label": "Phase", "fieldType": "SELECT", "isMandatory": true, "displayOrder": 12, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2",
        "options": [ { "value": "I", "label": "Phase I", "displayOrder": 0 }, { "value": "II", "label": "Phase II", "displayOrder": 1 }, { "value": "III", "label": "Phase III", "displayOrder": 2 }, { "value": "IV", "label": "Phase IV", "displayOrder": 3 } ], "validation": "Required()" },
      { "name": "therapeuticArea", "label": "Therapeutic Area", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 13, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_2", "validation": "Required()" },
      { "name": "siteName", "label": "Site Name", "fieldType": "TEXT", "isMandatory": true, "isTitle": true, "inSummary": true, "displayOrder": 20, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "siteId", "label": "Site Number", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 21, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()", "customValidationRule": "TRIM() AND UPPER()" },
      { "name": "investigatorName", "label": "Principal Investigator", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 22, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "country", "label": "Country", "fieldType": "TEXT", "isMandatory": true, "displayOrder": 23, "columnSpan": 1, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required()" },
      { "name": "targetEnrolment", "label": "Target Enrolment", "fieldType": "NUMBER", "isMandatory": true, "inSummary": true, "displayOrder": 24, "columnSpan": 2, "screenId": "temp_screen_1", "fieldGroupId": "temp_grp_3", "validation": "Required() AND Min(1)" },
      { "name": "ethicsApproved", "label": "Ethics / IRB Approval Received", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 30, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "ValidWhen(@{ethicsApproved} == true, \"Ethics approval required\")" },
      { "name": "regulatoryApproved", "label": "Regulatory (NRA) Approval Received", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "inSummary": true, "displayOrder": 31, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "ValidWhen(@{regulatoryApproved} == true, \"Regulatory approval required\")" },
      { "name": "importPermit", "label": "Import Permit (if applicable)", "fieldType": "YES_NO", "defaultValue": "true", "displayOrder": 32, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4" },
      { "name": "contractSigned", "label": "Clinical Trial Agreement Signed", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 33, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_4", "validation": "ValidWhen(@{contractSigned} == true, \"CTA must be signed\")" },
      { "name": "siteInitiationVisitDone", "label": "Site Initiation Visit (SIV) Completed", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 40, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{siteInitiationVisitDone} == true, \"SIV required\")" },
      { "name": "staffTrained", "label": "Site Staff Trained on Protocol & GCP", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 41, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "ValidWhen(@{staffTrained} == true, \"Staff training required\")" },
      { "name": "drugSupplyReceived", "label": "Investigational Product Supplied", "fieldType": "YES_NO", "isMandatory": true, "defaultValue": "false", "displayOrder": 42, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5" },
      { "name": "equipmentCalibrated", "label": "Equipment Calibrated", "fieldType": "YES_NO", "defaultValue": "false", "displayOrder": 43, "columnSpan": 1, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5" },
      { "name": "firstSubjectDate", "label": "Planned First Subject Visit", "fieldType": "DATE", "isMandatory": true, "inSummary": true, "displayOrder": 44, "columnSpan": 2, "screenId": "temp_screen_2", "fieldGroupId": "temp_grp_5", "validation": "Required() AND DateAfter(\"today\", \"Must be future\")" },
      { "name": "ethicsApprovalLetter", "label": "Ethics Approval Letter", "fieldType": "FILE", "isMandatory": true, "displayOrder": 50, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "allowedFileTypes": "pdf", "maxFileSize": 10485760, "validation": "Required()" },
      { "name": "regulatoryApprovalLetter", "label": "Regulatory Approval Letter", "fieldType": "FILE", "isMandatory": true, "displayOrder": 51, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "allowedFileTypes": "pdf", "maxFileSize": 10485760, "validation": "Required()" },
      { "name": "sivReport", "label": "SIV Report", "fieldType": "FILE", "displayOrder": 52, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "allowedFileTypes": "pdf,doc,docx", "maxFileSize": 10485760 },
      { "name": "trainingLog", "label": "Training Log", "fieldType": "FILE", "displayOrder": 53, "columnSpan": 2, "screenId": "temp_screen_3", "fieldGroupId": "temp_grp_6", "allowedFileTypes": "pdf,xls,xlsx", "maxFileSize": 10485760 }
    ]
  }],
  "approvers": [
    { "level": 1, "name": "Clinical Project Manager", "approverType": "ROLE", "roleName": "CPM", "amountLimit": null, "canEscalate": true, "requireComment": false, "emailNotification": true },
    { "level": 2, "name": "Clinical Operations Lead", "approverType": "ROLE", "roleName": "CLIN_OPS_LEAD", "amountLimit": null, "canEscalate": true, "requireComment": true, "emailNotification": true },
    { "level": 3, "name": "Head of Clinical Development", "approverType": "ROLE", "roleName": "HEAD_CLINICAL", "amountLimit": null, "canEscalate": false, "requireComment": true, "emailNotification": true }
  ]
}
